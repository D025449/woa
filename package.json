{
  "name": "simple-nodejs-app",
  "version": "1.0.0",
  "description": "Research about a person",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "worker": "node src/workers/import-worker.js",
    "migrate": "node src/migrate.js",
    "account-deletion:sweep": "node src/scripts/run-account-deletion-sweep.js",
    "db:rebuild": "node src/db-rebuild.js",
    "bench:persistence": "node src/scripts/benchmark-workout-persistence.js",
    "bench:workout-insert-loop": "node src/scripts/benchmark-workout-insert-loop.js",
    "bench:segment-recompute": "node src/scripts/benchmark-segment-recompute.js",
    "bench:fit-typed-arrays": "node src/scripts/benchmark-fit-record-typed-arrays.js",
    "bench:fit-import-path": "node src/scripts/benchmark-fit-import-path.js",
    "db:explain-workout-insert": "node src/scripts/explain-workout-insert.js",
    "validate:fit-typed-arrays": "node src/scripts/validate-fit-typed-arrays.js",
    "validate:fit-typed-import-path": "node src/scripts/validate-fit-typed-import-path.js",
    "profile:fit-parser": "node src/scripts/profile-fit-parser.js",
    "generate:fit-golden": "node src/scripts/generate-fit-parser-golden.js",
    "migrate:workout-streams:absolute": "node src/scripts/migrate-workout-streams-to-absolute.js",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-push && echo 'Git hooks installed (.githooks)'",
    "check:syntax": "rg --files src -g '*.js' | xargs -n1 node --check",
    "check:lint": "eslint src",
    "check:types": "tsc --noEmit -p tsconfig.checkjs.json",
    "check": "npm run check:syntax && npm run check:lint",
    "test": "node --test tests/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rat9615/simple-nodejs-app.git"
  },
  "author": "Rohan R",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rat9615/simple-nodejs-app/issues"
  },
  "homepage": "https://github.com/rat9615/simple-nodejs-app#readme",
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1008.0",
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "aws-jwt-verify": "^5.1.1",
    "bullmq": "^5.71.0",
    "connect-pg-simple": "^10.0.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.10",
    "express": "^4.17.3",
    "express-session": "^1.18.1",
    "fit-file-parser": "^2.3.3",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "multer": "^2.0.2",
    "node-fetch": "^2.6.7",
    "nodemon": "^2.0.20",
    "openid-client": "^5.7.0",
    "p-limit": "^7.3.0",
    "pg": "^8.18.0",
    "pg-copy-streams": "^7.0.0",
    "pg-promise": "^12.6.2",
    "redis": "^5.11.0",
    "tabulator-tables": "^6.3.1",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "wiki-infobox-parser": "^0.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
