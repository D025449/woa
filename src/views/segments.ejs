<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("segmentsPage.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/segments.css">

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

</head>

<body class="segments-page" data-current-user-id="<%= userInfo?.id || '' %>">

    <% if (isAuthenticated) { %>

        <%- include("partials/app-topbar", {
            title: t("segmentsPage.topbarTitle"),
            currentPage: "segments",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <!-- Content -->

        <div class="container-fluid px-3 px-xl-4 py-4">

            <div class="segments-shell ui-page-shell">

                <section class="segments-hero ui-hero ui-hero--compact">
                    <div>
                        <p class="segments-kicker ui-hero__kicker"><%= t("segmentsPage.kicker") %></p>
                        <h1 class="segments-title ui-hero__title"><%= t("segmentsPage.titleMain") %></h1>
                        <p class="segments-subtitle ui-hero__subtitle">
                            <%= t("segmentsPage.subtitle") %>
                        </p>
                        <div id="segments-quick-access" class="segments-quick-access" hidden>
                            <div class="segments-quick-access__group">
                                <span class="segments-quick-access__label"><%= t("segmentsPage.quickRecent") %></span>
                                <div id="segments-recent-list" class="segments-quick-access__chips"></div>
                            </div>
                            <div class="segments-quick-access__group">
                                <span class="segments-quick-access__label"><%= t("segmentsPage.quickFavorites") %></span>
                                <div id="segments-favorite-list" class="segments-quick-access__chips"></div>
                            </div>
                        </div>
                    </div>

                    <div class="segments-hero-meta ui-hero__meta">
                        <div class="segments-scope-toggle ui-toggle-group ui-toggle-group--light" role="group" aria-label="<%= t('segmentsPage.scopeAria') %>">
                            <button id="segments-scope-mine" class="btn btn-sm btn-outline-secondary" type="button" data-segment-scope="mine">
                                <%= t("segmentsPage.scopeMine") %>
                            </button>
                            <button id="segments-scope-shared" class="btn btn-sm btn-outline-secondary" type="button" data-segment-scope="shared">
                                <%= t("segmentsPage.scopeShared") %>
                            </button>
                            <button id="segments-scope-all" class="btn btn-sm btn-outline-secondary" type="button" data-segment-scope="all">
                                <%= t("segmentsPage.scopeAll") %>
                            </button>
                        </div>
                        <button id="segments-favorites-filter" class="segments-favorite-filter" type="button" aria-pressed="false" title="<%= t('segmentsPage.favoriteFilterLabel') %>">
                            <svg viewBox="0 0 20 20" aria-hidden="true">
                                <path d="M10 2.9l2.15 4.36 4.81.7-3.48 3.39.82 4.79L10 14.02 5.7 16.14l.82-4.79L3.04 7.96l4.81-.7L10 2.9z" fill="currentColor"></path>
                            </svg>
                        </button>
                        <div class="ui-hero__art" aria-hidden="true">
                            <svg viewBox="0 0 64 64" fill="none">
                                <defs>
                                    <linearGradient id="segmentsHeroGradient" x1="12" y1="46" x2="52" y2="18" gradientUnits="userSpaceOnUse">
                                        <stop stop-color="#0f766e" />
                                        <stop offset="1" stop-color="#2563eb" />
                                    </linearGradient>
                                </defs>
                                <path d="M14 46C19 38 22 34 28 34C32 34 35 38 39 38C45 38 48 31 50 20" stroke="url(#segmentsHeroGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                <circle cx="14" cy="46" r="5" fill="#ffffff" stroke="#0f766e" stroke-width="3" />
                                <circle cx="50" cy="20" r="5" fill="#ffffff" stroke="#2563eb" stroke-width="3" />
                                <path d="M28 48H50" stroke="rgba(148,163,184,0.34)" stroke-width="3" stroke-linecap="round" stroke-dasharray="4 6" />
                            </svg>
                        </div>
                    </div>
                </section>

                <section id="segments-workspace" class="segments-workspace">
                    <article class="segments-surface ui-surface ui-surface--gradient segments-workspace-panel segments-map-panel">
                        <div class="segments-section-header ui-section-header">
                            <div>
                                <span class="segments-eyebrow ui-eyebrow"><%= t("segmentsPage.mapEyebrow") %></span>
                                <h2 class="segments-section-title ui-title"><%= t("segmentsPage.mapTitle") %></h2>
                                <p class="segments-section-copy ui-copy">
                                    <%= t("segmentsPage.mapCopy") %>
                                </p>
                            </div>

                            <div class="segments-toolbar ui-toolbar ui-toolbar--end">
                                <details id="segments-map-tools-menu" class="segments-map-actions-menu">
                                    <summary class="segments-map-actions-menu__trigger" aria-label="<%= t('segmentsPage.btnCreate') %> / <%= t('segmentsPage.lookup') %>">
                                        <span aria-hidden="true">•••</span>
                                    </summary>
                                    <div class="segments-map-actions-menu__panel">
                                        <button
                                            id="draw-segment-map-toggle"
                                            class="segments-map-actions-menu__item segments-map-actions-menu__item--primary"
                                            type="button"
                                            title="<%= t('segmentsPage.btnCreateTitle') %>">
                                            <span class="segments-map-actions-menu__icon" aria-hidden="true">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                                                    <circle cx="12" cy="12" r="6.5" />
                                                    <path d="M12 2.5V5.2" />
                                                    <path d="M12 18.8V21.5" />
                                                    <path d="M2.5 12H5.2" />
                                                    <path d="M18.8 12H21.5" />
                                                </svg>
                                            </span>
                                            <span><%= t("segmentsPage.btnCreate") %></span>
                                        </button>

                                        <button
                                            id="draw-segment-map-lookup"
                                            class="segments-map-actions-menu__item segments-map-actions-menu__item--secondary"
                                            type="button"
                                            disabled
                                            title="<%= t('segmentsPage.lookupTitle') %>">
                                            <span class="segments-map-actions-menu__icon" aria-hidden="true">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                                                    <circle cx="6.5" cy="17.5" r="1.8" />
                                                    <circle cx="17.5" cy="6.5" r="1.8" />
                                                    <path d="M8.4 16.2C11 13.6 13.2 11.5 15.7 8.9" />
                                                    <path d="M11.9 8.4H15.9V12.4" />
                                                </svg>
                                            </span>
                                            <span><%= t("segmentsPage.lookup") %></span>
                                        </button>

                                        <div class="segments-map-actions-menu__group">
                                            <div class="segments-map-actions-menu__label"><%= t("segmentsPage.mapStyleLabel") %></div>
                                            <div id="segments-map-style-slot" class="segments-map-actions-menu__styles"></div>
                                        </div>
                                    </div>
                                </details>
                            </div>
                        </div>

                        <div class="segments-body segments-map-body">
                            <div id="workout-map"></div>
                        </div>
                    </article>

                    <div
                        id="segments-splitter"
                        class="segments-splitter"
                        role="separator"
                        aria-orientation="vertical"
                        aria-label="<%= t('segmentsPage.workspaceSplitterAria') %>">
                    </div>

                    <aside class="segments-surface ui-surface ui-surface--gradient segments-workspace-panel segments-detail-surface">
                        <div class="segments-section-header ui-section-header">
                            <div>
                                <span class="segments-eyebrow ui-eyebrow"><%= t("segmentsPage.insightsEyebrow") %></span>
                                <h2 id="segment-header" class="segments-section-title ui-title"><%= t("segmentsPage.insightsTitle") %></h2>
                            </div>

                            <div class="segments-toolbar ui-toolbar ui-toolbar--end">
                                <div class="segments-detail-nav" role="group" aria-label="<%= t('segmentsPage.detailNavigationAria') %>">
                                    <button id="segment-prev" class="segments-detail-nav__button" type="button" aria-label="<%= t('segmentsPage.previousItem') %>">‹</button>
                                    <button id="segment-next" class="segments-detail-nav__button" type="button" aria-label="<%= t('segmentsPage.nextItem') %>">›</button>
                                </div>
                                <button id="segment-favorite-toggle" class="segments-favorite-toggle d-none" type="button" aria-pressed="false" title="<%= t('segmentsPage.favoriteToggleTitle') %>">
                                    <span aria-hidden="true">★</span>
                                </button>
                                <details class="segments-detail-actions-menu">
                                    <summary class="segments-detail-actions-menu__trigger" aria-label="<%= t('segmentsPage.share') %> / <%= t('segmentsPage.deleteSegment') %>">
                                        <span aria-hidden="true">•••</span>
                                    </summary>
                                    <div class="segments-detail-actions-menu__panel">
                                        <button id="share-segment-toggle" class="segments-detail-actions-menu__item segments-detail-actions-menu__item--secondary d-none" type="button">
                                            <span class="segments-detail-actions-menu__icon" aria-hidden="true">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                                                    <circle cx="18" cy="5" r="2.25" />
                                                    <circle cx="6" cy="12" r="2.25" />
                                                    <circle cx="18" cy="19" r="2.25" />
                                                    <path d="M8 11L15.8 6.4" />
                                                    <path d="M8 13L15.8 17.6" />
                                                </svg>
                                            </span>
                                            <span><%= t("segmentsPage.share") %></span>
                                        </button>
                                        <button id="delete-selected-segment" class="segments-detail-actions-menu__item segments-detail-actions-menu__item--danger d-none" type="button">
                                            <span class="segments-detail-actions-menu__icon" aria-hidden="true">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M4 7H20" />
                                                    <path d="M9 7V5.5C9 4.67 9.67 4 10.5 4H13.5C14.33 4 15 4.67 15 5.5V7" />
                                                    <path d="M7.5 7L8.4 18.1C8.48 19.03 9.25 19.75 10.19 19.75H13.81C14.75 19.75 15.52 19.03 15.6 18.1L16.5 7" />
                                                    <path d="M10 10.5V16" />
                                                    <path d="M14 10.5V16" />
                                                </svg>
                                            </span>
                                            <span><%= t("segmentsPage.deleteSegment") %></span>
                                        </button>
                                    </div>
                                </details>
                                <div id="segment-share-inline" class="segment-share-inline">
                                    <span class="small text-muted"><%= t("segmentsPage.visibility") %></span>
                                    <select id="segment-share-mode" class="form-select form-select-sm" style="width: 130px;">
                                        <option value="private"><%= t("segmentsPage.sharePrivate") %></option>
                                        <option value="groups"><%= t("segmentsPage.shareGroups") %></option>
                                    </select>
                                    <div id="segment-share-groups" class="segment-share-inline__groups"></div>
                                    <span id="segment-share-status" class="segment-share-status"></span>
                                    <button id="segment-share-save" class="btn btn-sm btn-primary" type="button"><%= t("segmentsPage.apply") %></button>
                                </div>
                            </div>
                        </div>

                        <div class="segments-detail-grid">
                            <div class="segments-panel segments-panel--elevation">
                                <div class="segments-panel-header">
                                    <h3 class="segments-panel-title"><%= t("segmentsPage.elevationTitle") %></h3>
                                    <div id="segment-elevation-stats" class="small text-muted"></div>
                                </div>
                                <div id="segment-elevation-panel" class="d-none h-100">
                                    <div id="segment-elevation-chart"></div>
                                </div>
                                <div id="segment-elevation-empty"
                                    class="small text-muted d-flex align-items-center justify-content-center h-100">
                                    <%= t("segmentsPage.elevationEmpty") %>
                                </div>
                            </div>

                            <div class="segments-panel segments-panel--table">
                                <div class="segments-panel-header">
                                    <h3 class="segments-panel-title"><%= t("segmentsPage.bestEffortsTitle") %></h3>
                                    <div class="segments-best-efforts-header-controls">
                                        <details class="segments-best-efforts-menu">
                                            <summary class="segments-best-efforts-menu__trigger" aria-label="<%= t('segmentsPage.bestEffortsMenuAria') %>">
                                                <span aria-hidden="true">•••</span>
                                            </summary>
                                            <div class="segments-best-efforts-menu__panel">
                                                <div class="segments-best-efforts-menu__group">
                                                    <div class="segments-best-efforts-menu__label"><%= t("segmentsPage.bestEffortsViewLabel") %></div>
                                                    <div class="segments-best-efforts-view-toggle ui-toggle-group ui-toggle-group--light" role="group" aria-label="<%= t('segmentsPage.bestEffortsViewAria') %>">
                                                        <button id="segment-bestefforts-view-table" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-view="table">
                                                            <%= t("segmentsPage.bestEffortsViewTable") %>
                                                        </button>
                                                        <button id="segment-bestefforts-view-cards" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-view="cards">
                                                            <%= t("segmentsPage.bestEffortsViewCards") %>
                                                        </button>
                                                    </div>
                                                </div>
                                                <div class="segments-best-efforts-menu__group">
                                                    <div class="segments-best-efforts-menu__label"><%= t("segmentsPage.bestEffortsScopeLabel") %></div>
                                                    <div class="segment-bestefforts-scope-toggle ui-toggle-group ui-toggle-group--light" role="group" aria-label="<%= t('segmentsPage.bestEffortsScopeAria') %>">
                                                        <button id="segment-bestefforts-scope-mine" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-scope="mine">
                                                            <%= t("segmentsPage.bestEffortsScopeMine") %>
                                                        </button>
                                                        <button id="segment-bestefforts-scope-shared" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-scope="shared">
                                                            <%= t("segmentsPage.bestEffortsScopeShared") %>
                                                        </button>
                                                        <button id="segment-bestefforts-scope-all" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-scope="all">
                                                            <%= t("segmentsPage.bestEffortsScopeAll") %>
                                                        </button>
                                                    </div>
                                                </div>
                                                <div class="segments-best-efforts-menu__group">
                                                    <div class="segments-best-efforts-menu__label"><%= t("segmentsPage.bestEffortsPerUserLabel") %></div>
                                                    <div class="segments-best-efforts-per-user-toggle ui-toggle-group ui-toggle-group--light" role="group" aria-label="<%= t('segmentsPage.bestEffortsPerUserAria') %>">
                                                        <button id="segment-bestefforts-per-user-all" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-per-user="all">
                                                            <%= t("segmentsPage.bestEffortsPerUserAll") %>
                                                        </button>
                                                        <button id="segment-bestefforts-per-user-1" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-per-user="1">
                                                            <%= t("segmentsPage.bestEffortsPerUserOne") %>
                                                        </button>
                                                        <button id="segment-bestefforts-per-user-3" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-per-user="3">
                                                            <%= t("segmentsPage.bestEffortsPerUserThree") %>
                                                        </button>
                                                    </div>
                                                </div>
                                                <div class="segments-best-efforts-menu__group">
                                                    <button id="segment-bestefforts-my-pr" class="segments-best-efforts-menu__action" type="button">
                                                        <%= t("segmentsPage.bestEffortsMyPr") %>
                                                    </button>
                                                </div>
                                            </div>
                                        </details>
                                    </div>
                                </div>
                                <div class="segments-panel-body segments-panel-body--table">
                                    <div id="segment-table" class="segments-best-efforts-surface"></div>
                                    <div id="segment-best-efforts-cards" class="segments-best-efforts-cards d-none"></div>
                                    <div id="segment-best-efforts-load-more" class="segments-best-efforts-load-more d-none">
                                        <button class="btn btn-outline-secondary btn-sm" type="button"><%= t("dashboardNewPage.loadMore") %></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </aside>
                </section>
            </div>

        </div>

        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="segments-toast" class="toast dashboard-toast border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-body" id="segments-toast-body"></div>
            </div>
        </div>

    <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4"><%= t("common.auth.pleaseSignIn") %></h3>

                <a class="btn btn-primary" href="/login">
                    <%= t("segmentsPage.signIn") %>
                </a>

            </div>

            <% } %>
                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
                <script>
                    window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
                </script>

                <script type="module" src="/js/segments-ui.js"></script>

</body>

</html>
