<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Segments</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

</head>

<body class="bg-light">

    <% if (isAuthenticated) { %>

        <!-- Navbar -->

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">

                <span class="navbar-brand">Segments</span>

                <div class="ms-auto d-flex align-items-center gap-3">

                    <span class="text-white">
                        <%= userInfo.username %>
                    </span>

                    <a class="btn btn-outline-light btn-sm" href="/files/uploadUI">
                        Upload
                    </a>
                    <a class="btn btn-outline-light btn-sm" href="/analytics">
                        Analytics
                    </a>
                    <a class="btn btn-outline-light btn-sm" href="/dashboard">
                        Dashboard
                    </a>

                    <a class="btn btn-outline-danger btn-sm" href="/logout">
                        Logout
                    </a>

                </div>

            </div>
        </nav>

        <!-- Content -->

        <div class="container py-4">

            <div class="row g-4">
                <!-- Map -->
                <div class="col-12">

                    <div class="card shadow-sm h-100">

                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Segments Map</h5>
                            <div class="d-flex gap-2">
                                <!--div id="segment-editor" class="d-none d-flex align-items-center gap-2">

                                    <span class="small text-muted">Segment:</span>

                                    <input id="segment-name-input" type="text" class="form-control form-control-sm"
                                        style="width:150px;" />
                                </div-->
                                <button id="draw-segment-map-toggle" class="btn btn-sm">
                                    ✏️
                                </button>

                                <button id="draw-segment-map-lookup" class="btn btn-sm">
                                    📍➡️📍 Lookup
                                </button>

                                <!--button id="delete-segments" class="btn btn-sm btn-outline-danger">
                                    🗑️
                                </button-->
                                <button id="save-map-segments" class="btn btn-sm ">
                                    💾
                                </button>
                            </div>
                        </div>

                        <div class="card-body p-0">
                            <div id="workout-map" style="height:500px;"></div>
                        </div>

                    </div>

                </div>

                <!-- Workout Table -->
                <div class="col-12">
                    <div class="card shadow-sm">

                        <div class="card-header">
                            <h5 id="segment-header" class="mb-0">Segments</h5>
                        </div>

                        <div class="card-body">

                            <div id="segment-table"></div>

                        </div>

                    </div>

                </div>

                <!-- Chart -->

                <div class="col-12">

                    <div class="card shadow-sm h-100">

                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 id="files_header" class="mb-0">Workout Data</h5>

                            <div class="d-flex gap-2">
                                <div id="segment-editor" class="d-none d-flex align-items-center gap-2">

                                    <span class="small text-muted">Segment:</span>

                                    <input id="segment-name-input" type="text" class="form-control form-control-sm"
                                        style="width:150px;" />
                                </div>
                                <button id="draw-segment-toggle" class="btn btn-sm">
                                    ✏️
                                </button>
                                <button id="delete-segments" class="btn btn-sm btn-outline-danger">
                                    🗑️
                                </button>
                                <button id="save-segments" class="btn btn-sm ">
                                    💾
                                </button>
                            </div>
                        </div>

                        <div class="card-body">
                            <div id="workout-chart" style="height:500px;"></div>
                        </div>

                    </div>

                    <!--/div-->
                </div>
            </div>

        </div>

        </div>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4">Please log in</h3>

                <a class="btn btn-primary" href="/login">
                    Login
                </a>

            </div>

            <% } %>
                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

                <script type="module" src="/js/segments-ui.js"></script>

</body>

</html>