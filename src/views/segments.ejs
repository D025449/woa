<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("segmentsPage.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        body.segments-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 28%),
                radial-gradient(circle at top right, rgba(13, 148, 136, 0.10), transparent 22%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .app-topbar {
            background: linear-gradient(180deg, #0f172a 0%, #172235 100%) !important;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
        }

        .app-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .app-topbar-profile {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.3rem;
            height: 2.3rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
            color: #e2e8f0;
            transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
        }

        .app-topbar-profile:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar-profile__icon {
            width: 1rem;
            height: 1rem;
        }

        .app-topbar .nav-link {
            color: rgba(226, 232, 240, 0.82);
            font-weight: 600;
            padding: 0.35rem 0.25rem;
            border-bottom: 2px solid transparent;
        }

        .app-topbar .nav-link:hover,
        .app-topbar .nav-link.active {
            color: #ffffff;
            border-bottom-color: rgba(226, 232, 240, 0.8);
        }

        .app-topbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            border-color: rgba(148, 163, 184, 0.28);
        }

        .app-topbar .btn-outline-light {
            color: #e2e8f0;
            border-color: rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
        }

        .app-topbar .btn-outline-light:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar .btn-outline-danger {
            color: #fecaca;
            border-color: rgba(248, 113, 113, 0.32);
            background: rgba(127, 29, 29, 0.18);
        }

        .app-topbar .btn-outline-danger:hover {
            color: #fff1f2;
            background: rgba(220, 38, 38, 0.28);
            border-color: rgba(248, 113, 113, 0.45);
        }

        .segments-shell {
            display: grid;
            gap: 1.5rem;
        }

        .app-footer {
            margin-top: 1.5rem;
            text-align: center;
            color: #64748b;
            font-size: 0.88rem;
        }

        .app-footer a {
            color: #475569;
            text-decoration: none;
        }

        .app-footer a:hover {
            color: #0f172a;
            text-decoration: underline;
        }

        .segments-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 1.5rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92)),
                linear-gradient(135deg, rgba(15, 23, 42, 0.02), rgba(30, 64, 175, 0.04));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
            backdrop-filter: blur(10px);
        }

        .segments-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .segments-title {
            margin: 0;
            font-size: clamp(2rem, 2.5vw, 2.85rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .segments-subtitle {
            margin: 0.75rem 0 0;
            max-width: 46rem;
            font-size: 0.98rem;
            color: #475569;
        }

        .segments-hero-meta {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .segments-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .segments-chip-label {
            color: #64748b;
        }

        .segments-surface {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .segments-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.1rem 1.4rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.88));
        }

        .segments-eyebrow {
            display: block;
            margin-bottom: 0.2rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .segments-section-title {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .segments-section-copy {
            margin: 0.35rem 0 0;
            font-size: 0.9rem;
            color: #64748b;
        }

        .segments-shared-meta {
            margin-top: 0.55rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
            padding: 0.42rem 0.72rem;
            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 999px;
            background: rgba(248, 250, 252, 0.92);
            color: #334155;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .segments-shared-meta__eyebrow {
            color: #64748b;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .segments-toolbar {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 0.55rem;
        }

        .segments-toolbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            box-shadow: none;
        }

        .segments-scope-toggle {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.28rem;
            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
        }

        .segments-scope-toggle .btn {
            border-radius: 999px;
            padding-inline: 0.95rem;
        }

        .segment-share-inline {
            display: none;
            align-items: center;
            gap: 0.65rem;
            padding: 0.55rem 0.75rem;
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1rem;
            background: rgba(248, 250, 252, 0.82);
        }

        .segment-share-inline.is-open {
            display: flex;
        }

        .segment-share-inline__groups {
            display: none;
            align-items: center;
            gap: 0.45rem;
            flex-wrap: wrap;
            max-width: 420px;
        }

        .segment-share-inline__groups.is-visible {
            display: flex;
        }

        .segment-share-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.28rem 0.6rem;
            border: 1px solid rgba(148, 163, 184, 0.26);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.92);
            font-size: 0.82rem;
            color: #334155;
        }

        .segment-share-status {
            font-size: 0.82rem;
            color: #64748b;
            white-space: nowrap;
        }

        .segments-body {
            padding: 0;
        }

        .segments-insight-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.7fr) minmax(340px, 1fr);
            gap: 1.5rem;
            align-items: stretch;
        }

        .segments-detail-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.8fr) minmax(320px, 1fr);
            gap: 1.5rem;
            padding: 1.2rem;
        }

        .segments-panel {
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 1.25rem;
            background: rgba(255, 255, 255, 0.75);
            padding: 1rem 1rem 1.1rem;
        }

        .segments-panel-title {
            margin: 0 0 0.85rem;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .segments-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 0.85rem;
        }

        .segments-panel-header .segments-panel-title {
            margin: 0;
        }

        .segment-bestefforts-scope-toggle {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.28rem;
            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
        }

        .segment-bestefforts-scope-toggle .btn {
            border-radius: 999px;
            padding-inline: 0.8rem;
        }

        .segment-bestefforts-scope-toggle.is-hidden {
            display: none;
        }

        #workout-map,
        #workout-chart {
            height: 560px !important;
        }

        #segment-elevation-chart,
        #segment-elevation-empty {
            height: 300px !important;
            min-height: 300px !important;
        }

        @media (max-width: 991.98px) {
            .segments-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .segments-hero-meta {
                justify-content: flex-start;
            }

            .segments-insight-grid,
            .segments-detail-grid {
                grid-template-columns: 1fr;
            }

            #workout-map,
            #workout-chart {
                height: 460px !important;
            }
        }
    </style>

</head>

<body class="segments-page" data-current-user-id="<%= userInfo?.id || '' %>">

    <% if (isAuthenticated) { %>

        <%- include("partials/app-topbar", {
            title: t("segmentsPage.topbarTitle"),
            currentPage: "segments",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <!-- Content -->

        <div class="container-fluid px-3 px-xl-4 py-4">

            <div class="segments-shell">

                <section class="segments-hero">
                    <div>
                        <p class="segments-kicker"><%= t("segmentsPage.kicker") %></p>
                        <h1 class="segments-title"><%= t("segmentsPage.titleMain") %></h1>
                        <p class="segments-subtitle">
                            Define segments on the map, review elevation profile and best efforts, and connect
                            the spatial view with workout data in the chart.
                        </p>
                    </div>

                    <div class="segments-hero-meta">
                        <div class="segments-scope-toggle" role="group" aria-label="<%= t('segmentsPage.scopeAria') %>">
                            <button id="segments-scope-mine" class="btn btn-sm btn-outline-secondary" type="button" data-segment-scope="mine">
                                <%= t("segmentsPage.scopeMine") %>
                            </button>
                            <button id="segments-scope-shared" class="btn btn-sm btn-outline-secondary" type="button" data-segment-scope="shared">
                                <%= t("segmentsPage.scopeShared") %>
                            </button>
                            <button id="segments-scope-all" class="btn btn-sm btn-outline-secondary" type="button" data-segment-scope="all">
                                <%= t("segmentsPage.scopeAll") %>
                            </button>
                        </div>
                        <span class="segments-chip">
                            <span class="segments-chip-label"><%= t("segmentsPage.chipUser") %></span>
                            <span><%= ((typeof userInfo !== "undefined" && userInfo) ? (userInfo.display_name || userInfo.email) : t("segmentsPage.chipUnknownUser")) %></span>
                        </span>
                        <span class="segments-chip">
                            <span class="segments-chip-label"><%= t("segmentsPage.chipWorkflowLabel") %></span>
                            <span><%= t("segmentsPage.chipWorkflowValue") %></span>
                        </span>
                        <span class="segments-chip">
                            <span class="segments-chip-label"><%= t("segmentsPage.chipFocusLabel") %></span>
                            <span><%= t("segmentsPage.chipFocusValue") %></span>
                        </span>
                    </div>
                </section>

                <section class="segments-surface">
                    <div class="segments-section-header">
                        <div>
                            <span class="segments-eyebrow"><%= t("segmentsPage.mapEyebrow") %></span>
                            <h2 class="segments-section-title"><%= t("segmentsPage.mapTitle") %></h2>
                            <p class="segments-section-copy">
                                Define new segments directly on the map and run lookup based on your
                                selected points.
                            </p>
                        </div>

                        <div class="segments-toolbar">
                            <button id="draw-segment-map-toggle" class="btn btn-sm btn-outline-primary"
                                title="Enter segment creation mode. Then click two points on the map to define a new segment.">
                                <%= t("segmentsPage.btnCreate") %>
                            </button>

                            <button id="draw-segment-map-lookup" class="btn btn-sm btn-outline-secondary" disabled
                                title="Select two points on the track first, then click to create the segment from the routed path.">
                                🧭 Lookup
                            </button>
                        </div>
                    </div>

                    <div class="segments-body">
                        <div id="workout-map"></div>
                    </div>
                </section>

                <section class="segments-surface">
                    <div class="segments-section-header">
                        <div>
                            <span class="segments-eyebrow"><%= t("segmentsPage.insightsEyebrow") %></span>
                            <h2 id="segment-header" class="segments-section-title"><%= t("segmentsPage.insightsTitle") %></h2>
                            <p class="segments-section-copy">
                                Compare best efforts and use the elevation profile of the selected segment as
                                a second reading next to the map.
                            </p>
                            <div id="segment-shared-meta" class="segments-shared-meta d-none">
                                <span class="segments-shared-meta__eyebrow"><%= t("segmentsPage.sharedSegmentEyebrow") %></span>
                                <span id="segment-shared-meta-text"></span>
                            </div>
                        </div>

                        <div class="segments-toolbar">
                            <button id="share-segment-toggle" class="btn btn-sm btn-outline-secondary d-none" type="button">
                                Share
                            </button>
                            <div id="segment-share-inline" class="segment-share-inline">
                                <span class="small text-muted">Visibility</span>
                                <select id="segment-share-mode" class="form-select form-select-sm" style="width: 130px;">
                                    <option value="private"><%= t("segmentsPage.sharePrivate") %></option>
                                    <option value="groups"><%= t("segmentsPage.shareGroups") %></option>
                                </select>
                                <div id="segment-share-groups" class="segment-share-inline__groups"></div>
                                <span id="segment-share-status" class="segment-share-status"></span>
                                <button id="segment-share-save" class="btn btn-sm btn-primary" type="button">Apply</button>
                            </div>
                            <button id="delete-selected-segment" class="btn btn-sm btn-outline-danger d-none">
                                <%= t("segmentsPage.deleteSegment") %>
                            </button>
                        </div>
                    </div>

                    <div class="segments-detail-grid">
                        <div class="segments-panel">
                            <div class="segments-panel-header">
                                <h3 class="segments-panel-title">Best Efforts</h3>
                                <div class="segment-bestefforts-scope-toggle" role="group" aria-label="Best-Efforts-Scope">
                                    <button id="segment-bestefforts-scope-mine" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-scope="mine">
                                        Mine
                                    </button>
                                    <button id="segment-bestefforts-scope-shared" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-scope="shared">
                                        <%= t("segmentsPage.bestEffortsScopeShared") %>
                                    </button>
                                    <button id="segment-bestefforts-scope-all" class="btn btn-sm btn-outline-secondary" type="button" data-segment-bestefforts-scope="all">
                                        All
                                    </button>
                                </div>
                            </div>
                            <div id="segment-table"></div>
                        </div>

                        <div class="segments-panel">
                            <h3 class="segments-panel-title"><%= t("segmentsPage.elevationTitle") %></h3>
                            <div id="segment-elevation-panel" class="d-none h-100">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="small text-muted fw-semibold"><%= t("segmentsPage.elevationLabel") %></div>
                                    <div id="segment-elevation-stats" class="small text-muted"></div>
                                </div>
                                <div id="segment-elevation-chart"></div>
                            </div>
                            <div id="segment-elevation-empty"
                                class="small text-muted d-flex align-items-center justify-content-center h-100">
                                Select a segment on the map to see its elevation profile.
                            </div>
                        </div>
                    </div>
                </section>

                <section class="segments-surface">
                    <div class="segments-section-header">
                        <div>
                            <span class="segments-eyebrow"><%= t("segmentsPage.workoutContextEyebrow") %></span>
                            <h2 id="files_header" class="segments-section-title"><%= t("segmentsPage.workoutContextTitle") %></h2>
                            <p class="segments-section-copy">
                                Use the chart as a complementary analysis surface for segment ranges and
                                manual editing inside the loaded workout.
                            </p>
                        </div>

                        <div class="segments-toolbar">
                            <div id="segment-editor" class="d-none d-flex align-items-center gap-2">
                                <span class="small text-muted"><%= t("segmentsPage.segmentLabel") %></span>
                                <input id="segment-name-input" type="text" class="form-control form-control-sm"
                                    style="width:150px;" />
                            </div>
                            <button id="draw-segment-toggle" class="btn btn-sm">
                                ✏️
                            </button>
                            <button id="delete-segments" class="btn btn-sm btn-outline-danger">
                                🗑️
                            </button>
                            <button id="save-segments" class="btn btn-sm ">
                                💾
                            </button>
                        </div>
                    </div>

                    <div class="segments-body">
                        <div id="workout-chart"></div>
                    </div>
                </section>
            </div>

        </div>

        <%- include("partials/app-footer") %>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4"><%= t("common.auth.pleaseSignIn") %></h3>

                <a class="btn btn-primary" href="/login">
                    <%= t("segmentsPage.signIn") %>
                </a>

            </div>

            <% } %>
                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

                <script type="module" src="/js/segments-ui.js"></script>

</body>

</html>
