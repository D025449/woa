<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("signup.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/auth.css">

</head>

<body class="auth-page">

    <nav class="navbar navbar-dark auth-topbar">
        <div class="container-fluid px-3 px-xl-4">
            <span class="navbar-brand"><%= t("signup.brand") %></span>
        </div>
    </nav>

    <div class="container py-4 py-lg-5">
        <div class="auth-shell">
            <section class="auth-hero mb-4">
                <div>
                    <p class="auth-kicker"><%= t("signup.heroKicker") %></p>
                    <h1 class="auth-title"><%= t("signup.heroTitle") %></h1>
                    <p class="auth-subtitle">
                        <%= t("signup.heroSubtitle") %>
                    </p>
                </div>

                <div>
                    <span class="auth-chip">
                        <span class="auth-chip-label"><%= t("signup.chipLabel") %></span>
                        <span><%= t("signup.chipValue") %></span>
                    </span>
                </div>
            </section>

            <div class="row justify-content-center">
                <div class="col-12">
                    <div class="auth-card">
                        <div class="auth-card-header">
                            <h5 class="auth-card-title"><%= t("signup.cardTitle") %></h5>
                        </div>

                        <div class="auth-card-body">

                            <form method="POST" action="/signup">

                                <div class="mb-3">
                                    <label class="form-label"><%= t("signup.userId") %></label>
                                    <input type="input" class="form-control" name="username" required>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label"><%= t("signup.email") %></label>
                                    <input type="email" class="form-control" name="email" required>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label"><%= t("signup.password") %></label>
                                    <input type="password" class="form-control" name="password" required>
                                </div>

                                <button class="btn btn-success w-100 auth-primary-btn">
                                    <%= t("signup.submit") %>
                                </button>

                            </form>

                            <div class="text-center mt-3">

                                <a href="/login">
                                    <%= t("signup.backToSignIn") %>
                                </a>

                            </div>

                        </div>
                    </div>

                </div>
            </div>

            <div class="text-center text-muted small mt-4">
                <a href="/impressum?<%= new URLSearchParams({ returnTo: currentUrl || "/signup" }).toString() %>" class="text-decoration-none"><%= t("common.footer.legalNotice") %></a>
                <span class="mx-2">·</span>
                <a href="/datenschutz?<%= new URLSearchParams({ returnTo: currentUrl || "/signup" }).toString() %>" class="text-decoration-none"><%= t("common.footer.privacy") %></a>
            </div>
        </div>
    </div>

</body>

</html>
