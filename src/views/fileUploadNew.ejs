<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WOA Upload</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/upload.css">
</head>

<body class="upload-page">

    <%- include("partials/app-topbar", {
        title: "WOA Upload",
        currentPage: "upload",
        userInfo,
        showDashboardNewLink: true
    }) %>

    <div class="container-fluid px-3 px-xl-4 py-4 upload-client-container">
        <div id="upload-shell" class="upload-shell ui-page-shell">
            <section class="upload-hero ui-hero ui-hero--compact">
                <div>
                    <p class="upload-kicker ui-hero__kicker"><%= t("uploadPage.heroKicker") %></p>
                    <h1 class="upload-title ui-hero__title">WOA Upload</h1>
                    <p class="upload-subtitle ui-hero__subtitle">
                        Browser-side preprocessing for FIT and FIT ZIP uploads. The browser converts the source into WOA transport artifacts and can upload the generated WOA ZIP directly to the backend.
                    </p>
                </div>
            </section>

            <section class="upload-stage ui-surface ui-surface--gradient">
                <div class="upload-stage-header ui-section-header">
                    <div>
                        <span class="upload-eyebrow ui-eyebrow"><%= t("uploadPage.headerEyebrow") %></span>
                        <h2 class="upload-section-title ui-title">Local Conversion For FIT And ZIP Inputs</h2>
                        <p class="upload-section-copy ui-copy">
                            This path keeps the old upload flow untouched. Here we preprocess in the browser, inspect the generated artifact, and optionally push the resulting WOA ZIP to the new backend import endpoint.
                        </p>
                    </div>
                </div>

                <div class="upload-stage-body">
                    <div id="upload-limit-alert" class="upload-limit-alert d-none" role="alert"></div>
                    <div class="row g-4 upload-workspace">
                        <div class="col-lg-6 upload-workspace__col">
                            <div class="upload-form-panel h-100">
                                <div class="upload-form-stack">
                                    <form id="uploadForm">
                                        <div class="mb-3">
                                            <label for="file" class="form-label">Select one FIT file or one ZIP file</label>
                                            <input type="file" class="d-none" id="file" name="files" accept=".fit,.zip" required>
                                            <div class="d-flex align-items-center gap-2">
                                                <button type="button" id="filePickerButton" class="btn btn-outline-secondary btn-sm">Choose file</button>
                                                <span id="filePickerLabel" class="small text-muted">No file selected</span>
                                            </div>
                                        </div>

                                        <div class="d-grid">
                                            <button type="submit" id="submitButton" class="btn btn-primary upload-primary-btn">
                                                Convert locally
                                            </button>
                                        </div>
                                    </form>

                                    <div id="response" class="mt-3"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 upload-workspace__col">
                            <div id="statusArea" class="upload-status-panel d-none h-100">
                                <div class="upload-status-stack">
                                    <div class="upload-phase-card">
                                        <span class="upload-phase-label">Current phase</span>
                                        <div id="phaseText" class="fw-semibold">Ready</div>
                                    </div>

                                    <div class="upload-progress-block">
                                        <div class="d-flex justify-content-between">
                                            <span>Read</span>
                                            <span id="uploadPercentText">0%</span>
                                        </div>
                                        <div class="progress">
                                            <div id="uploadProgressBar" class="progress-bar" role="progressbar"
                                                style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                                            </div>
                                        </div>
                                        <div id="uploadDetailText" class="small text-muted mt-1"></div>
                                    </div>

                                    <div class="upload-progress-block">
                                        <div class="d-flex justify-content-between">
                                            <span>Convert</span>
                                            <span id="processingPercentText">0%</span>
                                        </div>
                                        <div class="progress">
                                            <div id="processingProgressBar" class="progress-bar bg-success" role="progressbar"
                                                style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                                            </div>
                                        </div>
                                        <div id="processingDetailText" class="small text-muted mt-1"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <script>
        window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
    </script>
    <script type="module" src="/js/upload-new.js"></script>
</body>

</html>
