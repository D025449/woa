<!DOCTYPE html>
<html lang="<%= i18n?.locale || 'en' %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include("partials/favicon") %>
    <title><%= t("uploadPage.woaTitle") %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/ui-system.css?v=atlas-blue-4">
    <link rel="stylesheet" href="/css/upload.css?v=atlas-blue-5">
</head>

<body class="upload-page">

    <%- include("partials/app-topbar", {
        title: t("uploadPage.woaTopbarTitle"),
        currentPage: "upload",
        userInfo,
        showDashboardNewLink: true
    }) %>

    <div class="container-fluid px-3 px-xl-4 py-4 upload-client-container">
        <div id="upload-shell" class="upload-shell ui-page-shell">
            <section class="upload-hero ui-hero ui-hero--compact">
                <div>
                    <p class="upload-kicker ui-hero__kicker"><%= t("uploadPage.heroKicker") %></p>
                    <h1 class="upload-title ui-hero__title"><%= t("uploadPage.woaHeroTitle") %></h1>
                    <p class="upload-subtitle ui-hero__subtitle">
                        <%= t("uploadPage.woaHeroSubtitle") %>
                    </p>
                </div>
                <div class="ui-hero__art" aria-hidden="true">
                    <svg viewBox="0 0 64 64" fill="none">
                        <path d="M18 42.5h28a8 8 0 0 0 1.2-15.9A15.5 15.5 0 0 0 17.8 23 10 10 0 0 0 18 42.5Z" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M32 37V20M25.5 26.5 32 20l6.5 6.5" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
            </section>

            <section class="upload-stage ui-surface ui-surface--gradient">
                <div class="upload-stage-header ui-section-header">
                    <div>
                        <span class="upload-eyebrow ui-eyebrow"><%= t("uploadPage.headerEyebrow") %></span>
                        <h2 class="upload-section-title ui-title"><%= t("uploadPage.woaHeaderTitle") %></h2>
                        <p class="upload-section-copy ui-copy">
                            <%= t("uploadPage.woaHeaderCopy") %>
                        </p>
                    </div>
                </div>

                <div class="upload-stage-body">
                    <div id="upload-limit-alert" class="upload-limit-alert d-none" role="alert"></div>
                    <div class="row g-4 upload-workspace">
                        <div class="col-lg-6 upload-workspace__col">
                            <div class="upload-form-panel h-100">
                                <div class="upload-form-stack">
                                    <form id="uploadForm">
                                        <div class="mb-3">
                                            <input type="file" class="d-none" id="file" name="files" accept=".fit,.zip" multiple>
                                            <div id="uploadDropzone" class="upload-dropzone" role="button" tabindex="0"
                                                aria-describedby="filePickerLabel">
                                                <span class="upload-dropzone__icon" aria-hidden="true">
                                                    <svg viewBox="0 0 24 24" fill="none">
                                                        <path d="M4.5 18.5h15a2 2 0 0 0 2-2v-9a2 2 0 0 0-2-2h-7l-2-2h-6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
                                                        <path d="M12 16V9m0 0-3 3m3-3 3 3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                                                    </svg>
                                                </span>
                                                <strong id="uploadDropzoneTitle" class="upload-dropzone__title"><%= t("uploadPage.woaSelectFiles") %></strong>
                                                <span id="uploadDropzoneOr" class="upload-dropzone__or"><%= t("uploadPage.chooseFiles") %></span>
                                                <button type="button" id="filePickerButton" class="btn upload-dropzone__button"><%= t("uploadPage.chooseFiles") %></button>
                                                <span id="filePickerLabel" class="upload-dropzone__summary"><%= t("uploadPage.noFilesSelected") %></span>
                                            </div>
                                        </div>

                                        <div class="form-check mb-3">
                                            <input class="form-check-input" type="checkbox" id="overwriteExistingWorkouts">
                                            <label class="form-check-label" for="overwriteExistingWorkouts">
                                                <%= t("uploadPage.woaOverwriteExisting") %>
                                            </label>
                                            <div class="form-text"><%= t("uploadPage.woaOverwriteExistingHelp") %></div>
                                        </div>

                                        <div class="d-grid">
                                            <button type="submit" id="submitButton" class="btn upload-primary-btn">
                                                <%= t("uploadPage.woaSubmit") %>
                                            </button>
                                        </div>
                                    </form>

                                    <div id="response" class="mt-3"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 upload-workspace__col">
                            <div id="statusArea" class="upload-status-panel d-none h-100">
                                <div class="upload-status-stack">
                                    <div class="upload-phase-card">
                                        <span class="upload-phase-label"><%= t("uploadPage.currentPhase") %></span>
                                        <div id="phaseText" class="fw-semibold"><%= t("uploadPage.ready") %></div>
                                    </div>

                                    <div class="upload-progress-block">
                                        <div class="d-flex justify-content-between">
                                            <span><%= t("uploadPage.woaRead") %></span>
                                            <span id="uploadPercentText">0%</span>
                                        </div>
                                        <div class="progress">
                                            <div id="uploadProgressBar" class="progress-bar" role="progressbar"
                                                style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                                            </div>
                                        </div>
                                        <div id="uploadDetailText" class="small text-muted mt-1"></div>
                                    </div>

                                    <div class="upload-progress-block">
                                        <div class="d-flex justify-content-between">
                                            <span id="processingLabel"><%= t("uploadPage.woaConvert") %></span>
                                            <span id="processingPercentText">0%</span>
                                        </div>
                                        <div class="progress">
                                            <div id="processingProgressBar" class="progress-bar bg-success" role="progressbar"
                                                style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                                            </div>
                                        </div>
                                        <div id="processingDetailText" class="small text-muted mt-1"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="upload-guidance-panel h-100" aria-label="<%= t('uploadPage.chipFlowValue') %>">
                                <div class="upload-guidance-head">
                                    <span class="upload-eyebrow ui-eyebrow"><%= t("uploadPage.chipFlow") %></span>
                                    <h3 class="upload-guidance-title"><%= t("uploadPage.chipFlowValue") %></h3>
                                </div>
                                <ol class="upload-guidance-steps">
                                    <li>
                                        <span class="upload-guidance-number">1</span>
                                        <span>
                                            <strong><%= t("uploadPage.woaRead") %></strong>
                                            <small><%= t("uploadPage.woaPhaseReadingSources") %></small>
                                        </span>
                                    </li>
                                    <li>
                                        <span class="upload-guidance-number">2</span>
                                        <span>
                                            <strong><%= t("uploadPage.woaConvert") %></strong>
                                            <small><%= t("uploadPage.woaParsingFitDetail") %></small>
                                        </span>
                                    </li>
                                    <li>
                                        <span class="upload-guidance-number">3</span>
                                        <span>
                                            <strong><%= t("uploadPage.woaUploadAndStore") %></strong>
                                            <small><%= t("uploadPage.woaBackendUploadTrackedInProgress") %></small>
                                        </span>
                                    </li>
                                </ol>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <script>
        window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
    </script>
    <script type="module" src="/js/upload-new.js"></script>
</body>

</html>
