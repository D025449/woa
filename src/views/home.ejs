<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("home.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/home.css">
</head>

<body class="home-page">
    <% if (isAuthenticated) { %>
        <%- include("partials/app-topbar", {
            title: t("home.title"),
            currentPage: "home",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <%
            const rawHomeDisplayName = userInfo?.display_name || "";
            const homeDisplayName = typeof rawHomeDisplayName === "string" ? rawHomeDisplayName.trim() : "";
            const homeHeroTitle = homeDisplayName
                ? `${t("home.auth.heroTitle")}, ${homeDisplayName}`
                : t("home.auth.heroTitle");
        %>

        <div class="container-fluid px-3 px-xl-4 py-4 home-client-container">
            <div id="home-shell-frame" class="home-shell-frame">
            <div id="home-shell" class="home-shell">
                <section class="home-hero">
                    <div>
                        <h1 class="home-title"><%= homeHeroTitle %></h1>
                        <p class="home-subtitle">
                            <%= t("home.auth.heroSubtitle") %>
                        </p>
                    </div>
                </section>

                <section class="home-tile-grid">
                    <a class="home-tile" href="/dashboard-new">
                        <span class="home-tile__icon home-tile__icon--workouts" aria-hidden="true">
                            <svg viewBox="0 0 64 64" fill="none">
                                <defs>
                                    <linearGradient id="homeTileWorkoutsGradient" x1="8" y1="50" x2="56" y2="14" gradientUnits="userSpaceOnUse">
                                        <stop stop-color="#0f766e" />
                                        <stop offset="1" stop-color="#2563eb" />
                                    </linearGradient>
                                </defs>
                                <path d="M10 46C16 37 21 30 28 31C34 32 35 42 42 42C48 42 51 32 54 18" stroke="url(#homeTileWorkoutsGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M10 51H54" stroke="rgba(148,163,184,0.38)" stroke-width="3" stroke-linecap="round" />
                                <circle cx="28" cy="31" r="4" fill="#2563eb" />
                                <circle cx="42" cy="42" r="4" fill="#0f766e" />
                            </svg>
                        </span>
                        <span class="home-tile__eyebrow"><%= t("home.tiles.workoutEyebrow") %></span>
                        <h2 class="home-tile__title"><%= t("home.tiles.workoutTitle") %></h2>
                        <p class="home-tile__copy">
                            <%= t("home.tiles.workoutCopy") %>
                        </p>
                        <span class="home-tile__cta"><%= t("home.tiles.workoutCta") %></span>
                    </a>

                    <a class="home-tile" href="/segments">
                        <span class="home-tile__icon home-tile__icon--segments" aria-hidden="true">
                            <svg viewBox="0 0 64 64" fill="none">
                                <defs>
                                    <linearGradient id="homeTileSegmentsGradient" x1="12" y1="46" x2="52" y2="18" gradientUnits="userSpaceOnUse">
                                        <stop stop-color="#0f766e" />
                                        <stop offset="1" stop-color="#2563eb" />
                                    </linearGradient>
                                </defs>
                                <path d="M14 46C19 38 22 34 28 34C32 34 35 38 39 38C45 38 48 31 50 20" stroke="url(#homeTileSegmentsGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                <circle cx="14" cy="46" r="5" fill="#ffffff" stroke="#0f766e" stroke-width="3" />
                                <circle cx="50" cy="20" r="5" fill="#ffffff" stroke="#2563eb" stroke-width="3" />
                                <path d="M28 48H50" stroke="rgba(148,163,184,0.34)" stroke-width="3" stroke-linecap="round" stroke-dasharray="4 6" />
                            </svg>
                        </span>
                        <span class="home-tile__eyebrow"><%= t("home.tiles.segmentsEyebrow") %></span>
                        <h2 class="home-tile__title"><%= t("home.tiles.segmentsTitle") %></h2>
                        <p class="home-tile__copy">
                            <%= t("home.tiles.segmentsCopy") %>
                        </p>
                        <span class="home-tile__cta"><%= t("home.tiles.segmentsCta") %></span>
                    </a>

                    <a class="home-tile" href="/analytics">
                        <span class="home-tile__icon home-tile__icon--analytics" aria-hidden="true">
                            <svg viewBox="0 0 64 64" fill="none">
                                <defs>
                                    <linearGradient id="homeTileAnalyticsGradient" x1="10" y1="50" x2="54" y2="12" gradientUnits="userSpaceOnUse">
                                        <stop stop-color="#0f766e" />
                                        <stop offset="1" stop-color="#2563eb" />
                                    </linearGradient>
                                </defs>
                                <path d="M12 50H54" stroke="rgba(148,163,184,0.34)" stroke-width="3" stroke-linecap="round" />
                                <path d="M16 42L26 31L34 35L48 19" stroke="url(#homeTileAnalyticsGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M16 28L24 24L32 27L44 16" stroke="rgba(37,99,235,0.26)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                <circle cx="48" cy="19" r="4" fill="#2563eb" />
                            </svg>
                        </span>
                        <span class="home-tile__eyebrow"><%= t("home.tiles.analyticsEyebrow") %></span>
                        <h2 class="home-tile__title"><%= t("home.tiles.analyticsTitle") %></h2>
                        <p class="home-tile__copy">
                            <%= t("home.tiles.analyticsCopy") %>
                        </p>
                        <span class="home-tile__cta"><%= t("home.tiles.analyticsCta") %></span>
                    </a>

                    <a class="home-tile" href="/files/uploadUI">
                        <span class="home-tile__icon home-tile__icon--upload" aria-hidden="true">
                            <svg viewBox="0 0 64 64" fill="none">
                                <defs>
                                    <linearGradient id="homeTileUploadGradient" x1="18" y1="18" x2="46" y2="48" gradientUnits="userSpaceOnUse">
                                        <stop stop-color="#2563eb" />
                                        <stop offset="1" stop-color="#0f766e" />
                                    </linearGradient>
                                </defs>
                                <rect x="14" y="37" width="36" height="13" rx="6.5" stroke="rgba(148,163,184,0.38)" stroke-width="3" />
                                <path d="M32 16V39" stroke="url(#homeTileUploadGradient)" stroke-width="4" stroke-linecap="round" />
                                <path d="M23 26L32 16L41 26" stroke="url(#homeTileUploadGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                <path d="M18 44H46" stroke="rgba(37,99,235,0.22)" stroke-width="3" stroke-linecap="round" />
                            </svg>
                        </span>
                        <span class="home-tile__eyebrow"><%= t("home.tiles.uploadEyebrow") %></span>
                        <h2 class="home-tile__title"><%= t("home.tiles.uploadTitle") %></h2>
                        <p class="home-tile__copy">
                            <%= t("home.tiles.uploadCopy") %>
                        </p>
                        <span class="home-tile__cta"><%= t("home.tiles.uploadCta") %></span>
                    </a>
                </section>

                <section class="home-collab-grid">
                    <%- include("partials/activity-feed-panel", {
                        idPrefix: "home",
                        surfaceClass: "home-activity-panel",
                        headerClass: "home-section-header",
                        titleClass: "home-section-title",
                        copyClass: "home-section-copy",
                        toolbarClass: "home-section-toolbar ui-toolbar ui-toolbar--spacious",
                        toggleClass: "home-filter-toggle ui-toggle-group",
                        bodyClass: "home-surface-body ui-surface-body",
                        title: t("home.auth.activityTitle"),
                        copy: t("home.auth.activityCopy"),
                        feedLabels: {
                            rangeAria: t("groups.filters.activityRangeAria"),
                            sourceAria: t("groups.filters.activitySourceAria"),
                            lastDay: t("groups.filters.lastDay"),
                            last7Days: t("groups.filters.last7Days"),
                            all: t("groups.filters.all"),
                            allUsers: t("groups.filters.allUsers"),
                            othersOnly: t("groups.filters.othersOnly"),
                            loadMore: t("dashboardNewPage.loadMore")
                        },
                        loadMoreEnabled: true,
                        defaultRange: "7d",
                        defaultActorScope: "all"
                    }) %>

                    <section class="home-activity-panel">
                        <div class="home-section-header">
                            <div>
                                <a class="home-panel-icon home-panel-icon--invites home-panel-icon--link" href="/groups" aria-label="<%= t('home.auth.myInvitesTitle') %>">
                                    <svg viewBox="0 0 64 64" fill="none">
                                        <defs>
                                            <linearGradient id="homePanelInvitesGradient" x1="16" y1="46" x2="48" y2="18" gradientUnits="userSpaceOnUse">
                                                <stop stop-color="#0f766e" />
                                                <stop offset="1" stop-color="#2563eb" />
                                            </linearGradient>
                                        </defs>
                                        <rect x="14" y="20" width="36" height="24" rx="6" stroke="url(#homePanelInvitesGradient)" stroke-width="4" />
                                        <path d="M18 24L32 35L46 24" stroke="url(#homePanelInvitesGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                        <path d="M18 48H46" stroke="rgba(148,163,184,0.34)" stroke-width="3" stroke-linecap="round" />
                                    </svg>
                                </a>
                                <h2 class="home-section-title"><%= t("home.auth.myInvitesTitle") %></h2>
                                <p class="home-section-copy">
                                    <%= t("home.auth.myInvitesCopy") %>
                                </p>
                            </div>
                        </div>

                        <div class="home-surface-body ui-surface-body">
                            <div id="home-group-invites-list"></div>
                        </div>
                    </section>
                </section>
            </div>
            <%- include("partials/app-footer") %>
            </div>
        </div>
        <script>
            window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
        </script>
        <script type="module" src="/js/home-ui.js"></script>
    <% } else { %>
        <nav class="navbar navbar-dark home-topbar">
            <div class="container-fluid px-3 px-xl-4">
                <span class="navbar-brand"><%= t("home.guest.brand") %></span>
                <div class="d-flex align-items-center gap-2">
                    <div class="dropdown">
                        <button
                            class="btn btn-outline-light btn-sm dropdown-toggle"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">
                            <%= t("common.nav.about") %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end public-topbar-dropdown">
                            <li>
                                <a class="dropdown-item" href="/impressum">
                                    <%= t("common.footer.legalNotice") %>
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/datenschutz">
                                    <%= t("common.footer.privacy") %>
                                </a>
                            </li>
                        </ul>
                    </div>
                    <a class="btn btn-outline-light btn-sm" href="/login"><%= t("home.guest.login") %></a>
                    <a class="btn btn-light btn-sm" href="/signup"><%= t("home.guest.signUp") %></a>
                </div>
            </div>
        </nav>

        <div class="container py-4 py-lg-5">
            <div class="home-shell">
                <section class="home-hero">
                    <div>
                        <p class="home-kicker"><%= t("home.guest.heroKicker") %></p>
                        <h1 class="home-title"><%= t("home.guest.heroTitle") %></h1>
                        <p class="home-subtitle">
                            <%= t("home.guest.heroSubtitle") %>
                        </p>
                    </div>

                    <div class="home-chip-group">
                        <span class="home-chip">
                            <span class="home-chip-label"><%= t("home.guest.chipFocus") %></span>
                            <span><%= t("home.guest.chipFocusValue") %></span>
                        </span>
                    </div>
                </section>

                <section class="home-auth-grid">
                    <div class="home-auth-panel">
                        <p class="home-kicker"><%= t("home.guest.platformKicker") %></p>
                        <h2 class="home-title" style="font-size: clamp(1.7rem, 2.2vw, 2.3rem);"><%= t("home.guest.platformTitle") %></h2>
                        <p class="home-subtitle" style="max-width:none;">
                            <%= t("home.guest.platformCopy") %>
                        </p>

                        <div class="home-auth-features">
                            <div class="home-auth-feature">
                                <h3 class="home-auth-feature__title"><%= t("home.guest.featureUploadTitle") %></h3>
                                <p class="home-auth-feature__copy"><%= t("home.guest.featureUploadCopy") %></p>
                            </div>
                            <div class="home-auth-feature">
                                <h3 class="home-auth-feature__title"><%= t("home.guest.featureSegmentsTitle") %></h3>
                                <p class="home-auth-feature__copy"><%= t("home.guest.featureSegmentsCopy") %></p>
                            </div>
                            <div class="home-auth-feature">
                                <h3 class="home-auth-feature__title"><%= t("home.guest.featureAnalyticsTitle") %></h3>
                                <p class="home-auth-feature__copy"><%= t("home.guest.featureAnalyticsCopy") %></p>
                            </div>
                        </div>
                    </div>

                    <div class="home-auth-card">
                        <div class="home-auth-card__header">
                            <h2 class="home-auth-card__title"><%= t("home.guest.continueTitle") %></h2>
                        </div>
                        <div class="home-auth-card__body">
                            <div class="d-grid gap-3">
                                <a class="btn btn-primary" href="/login"><%= t("home.guest.login") %></a>
                                <a class="btn btn-outline-primary" href="/signup"><%= t("home.guest.createAccount") %></a>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <%- include("partials/app-footer") %>
    <% } %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
