<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("home.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body.home-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 28%),
                radial-gradient(circle at top right, rgba(13, 148, 136, 0.10), transparent 22%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .app-topbar,
        .home-topbar {
            background: linear-gradient(180deg, #0f172a 0%, #172235 100%) !important;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
        }

        .app-topbar .navbar-brand,
        .home-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .app-topbar .nav-link {
            color: rgba(226, 232, 240, 0.82);
            font-weight: 600;
            padding: 0.35rem 0.25rem;
            border-bottom: 2px solid transparent;
        }

        .app-topbar .nav-link:hover,
        .app-topbar .nav-link.active {
            color: #ffffff;
            border-bottom-color: rgba(226, 232, 240, 0.8);
        }

        .app-topbar-profile {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.3rem;
            height: 2.3rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
            color: #e2e8f0;
            transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
        }

        .app-topbar-profile:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar-profile__icon {
            width: 1rem;
            height: 1rem;
        }

        .app-topbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            border-color: rgba(148, 163, 184, 0.28);
        }

        .app-topbar .btn-outline-danger {
            color: #fecaca;
            border-color: rgba(248, 113, 113, 0.32);
            background: rgba(127, 29, 29, 0.18);
        }

        .app-topbar .btn-outline-danger:hover {
            color: #fff1f2;
            background: rgba(220, 38, 38, 0.28);
            border-color: rgba(248, 113, 113, 0.45);
        }

        .home-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .home-topbar .btn {
            border-radius: 999px !important;
            padding-inline: 0.95rem;
            font-weight: 600;
            border-width: 1px;
        }

        .home-topbar .btn-outline-light {
            color: #e2e8f0;
            border-color: rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
        }

        .home-topbar .btn-outline-light:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .home-topbar .btn-light {
            color: #e2e8f0;
            border-color: rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
        }

        .home-topbar .btn-light:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .home-auth-card__body .btn {
            border-radius: 999px !important;
        }

        .home-shell {
            display: grid;
            gap: 1.5rem;
        }

        .home-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 1.5rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92)),
                linear-gradient(135deg, rgba(15, 23, 42, 0.02), rgba(30, 64, 175, 0.04));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
            backdrop-filter: blur(10px);
        }

        .home-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .home-title {
            margin: 0;
            font-size: clamp(2rem, 2.8vw, 3rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .home-subtitle {
            margin: 0.75rem 0 0;
            max-width: 44rem;
            font-size: 1rem;
            color: #475569;
        }

        .home-chip-group {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .home-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .home-chip-label {
            color: #64748b;
        }

        .home-tile-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1.2rem;
        }

        .home-tile {
            display: block;
            text-decoration: none;
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
            padding: 1.35rem 1.4rem 1.45rem;
            transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
        }

        .home-tile:hover {
            transform: translateY(-2px);
            border-color: rgba(147, 197, 253, 0.72);
            box-shadow: 0 22px 44px rgba(15, 23, 42, 0.10);
            text-decoration: none;
        }

        .home-tile__eyebrow {
            display: block;
            margin-bottom: 0.35rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .home-tile__title {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .home-tile__copy {
            margin: 0.65rem 0 0;
            font-size: 0.92rem;
            color: #475569;
            line-height: 1.55;
        }

        .home-tile__cta {
            display: inline-flex;
            align-items: center;
            margin-top: 1rem;
            font-size: 0.84rem;
            font-weight: 700;
            color: #2563eb;
            letter-spacing: 0.02em;
        }

        .home-auth-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
            gap: 1.5rem;
            align-items: stretch;
        }

        .home-auth-panel,
        .home-auth-card {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
        }

        .home-auth-panel {
            padding: 1.5rem 1.6rem;
        }

        .home-auth-features {
            display: grid;
            gap: 0.95rem;
            margin-top: 1.3rem;
        }

        .home-auth-feature {
            padding: 1rem 1rem;
            border-radius: 1.1rem;
            background: rgba(248, 250, 252, 0.92);
            border: 1px solid rgba(226, 232, 240, 0.92);
        }

        .home-auth-feature__title {
            margin: 0 0 0.25rem;
            font-size: 0.96rem;
            font-weight: 700;
            color: #0f172a;
        }

        .home-auth-feature__copy {
            margin: 0;
            font-size: 0.9rem;
            color: #64748b;
        }

        .home-auth-card {
            overflow: hidden;
        }

        .home-auth-card__header {
            padding: 1.1rem 1.35rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.88));
        }

        .home-auth-card__title {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .home-auth-card__body {
            padding: 1.35rem;
        }

        .home-auth-card__body .btn {
            border-radius: 999px;
            padding: 0.85rem 1rem;
            font-weight: 700;
        }

        .home-activity-panel {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .home-collab-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1.2rem;
            align-items: start;
        }

        .home-section-header {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: center;
            padding: 1.2rem 1.3rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
        }

        .home-section-title {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
            color: #0f172a;
        }

        .home-section-copy {
            margin: 0.3rem 0 0;
            font-size: 0.9rem;
            color: #64748b;
        }

        .home-section-toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .home-filter-toggle {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.28rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(248, 250, 252, 0.92);
        }

        .home-filter-toggle .btn {
            border-radius: 999px;
            padding-inline: 0.85rem;
            font-weight: 700;
            border-color: transparent;
        }

        .home-filter-toggle .btn.active {
            background: #0f172a;
            color: #f8fafc;
            border-color: #0f172a;
        }

        .home-surface-body {
            padding: 1.1rem 1.25rem 1.25rem;
        }

        .home-surface-body .groups-empty,
        .home-surface-body .groups-preview-card,
        .home-surface-body .groups-preview-kicker,
        .home-surface-body .groups-preview-title,
        .home-surface-body .groups-preview-copy,
        .home-surface-body .groups-preview-actions {
            all: revert;
        }

        .home-surface-body .groups-empty {
            display: block;
            border: 1px dashed rgba(148, 163, 184, 0.35);
            border-radius: 1.15rem;
            padding: 1rem 1.05rem;
            background: rgba(248, 250, 252, 0.92);
            color: #64748b;
        }

        .home-surface-body .groups-empty strong {
            color: #0f172a;
        }

        .home-surface-body .groups-preview-card {
            display: block;
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 1.15rem;
            padding: 1rem 1.05rem;
            background: rgba(255, 255, 255, 0.88);
        }

        .home-surface-body #home-feed-list {
            display: grid;
            gap: 1rem;
        }

        .home-surface-body #home-group-invites-list {
            display: grid;
            gap: 1rem;
        }

        .home-surface-body .groups-preview-kicker {
            display: block;
            margin-bottom: 0.3rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .home-surface-body .groups-preview-title {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .home-surface-body .groups-preview-copy {
            margin: 0.45rem 0 0;
            font-size: 0.9rem;
            color: #475569;
            line-height: 1.55;
        }

        .home-surface-body .groups-preview-actions {
            display: flex;
            gap: 0.65rem;
            flex-wrap: wrap;
            margin-top: 0.95rem;
        }

        .home-surface-body .groups-preview-actions .btn {
            border-radius: 999px;
            font-weight: 700;
            padding-inline: 0.85rem;
        }

        .app-footer {
            margin-top: 1.5rem;
            text-align: center;
            color: #64748b;
            font-size: 0.88rem;
        }

        .app-footer a {
            color: #475569;
            text-decoration: none;
        }

        .app-footer a:hover {
            color: #0f172a;
            text-decoration: underline;
        }

        @media (max-width: 991.98px) {
            .home-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .home-chip-group {
                justify-content: flex-start;
            }

            .home-tile-grid,
            .home-collab-grid,
            .home-auth-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="home-page">
    <% if (isAuthenticated) { %>
        <%- include("partials/app-topbar", {
            title: "Home",
            currentPage: "home",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <div class="container-fluid px-3 px-xl-4 py-4">
            <div class="home-shell">
                <section class="home-hero">
                    <div>
                        <p class="home-kicker"><%= t("home.auth.heroKicker") %></p>
                        <h1 class="home-title"><%= t("home.auth.heroTitle") %></h1>
                        <p class="home-subtitle">
                            <%= t("home.auth.heroSubtitle") %>
                        </p>
                    </div>

                    <div class="home-chip-group">
                        <span class="home-chip">
                            <span class="home-chip-label"><%= t("home.auth.chipUser") %></span>
                            <span><%= userInfo.display_name || userInfo.email || userInfo.username %></span>
                        </span>
                        <span class="home-chip">
                            <span class="home-chip-label"><%= t("home.auth.chipMode") %></span>
                            <span><%= t("home.auth.chipModeValue") %></span>
                        </span>
                    </div>
                </section>

                <section class="home-tile-grid">
                    <a class="home-tile" href="/dashboard-new">
                        <span class="home-tile__eyebrow"><%= t("home.tiles.workoutEyebrow") %></span>
                        <h2 class="home-tile__title"><%= t("home.tiles.workoutTitle") %></h2>
                        <p class="home-tile__copy">
                            <%= t("home.tiles.workoutCopy") %>
                        </p>
                        <span class="home-tile__cta"><%= t("home.tiles.workoutCta") %></span>
                    </a>

                    <a class="home-tile" href="/segments">
                        <span class="home-tile__eyebrow"><%= t("home.tiles.segmentsEyebrow") %></span>
                        <h2 class="home-tile__title"><%= t("home.tiles.segmentsTitle") %></h2>
                        <p class="home-tile__copy">
                            <%= t("home.tiles.segmentsCopy") %>
                        </p>
                        <span class="home-tile__cta"><%= t("home.tiles.segmentsCta") %></span>
                    </a>

                    <a class="home-tile" href="/analytics">
                        <span class="home-tile__eyebrow"><%= t("home.tiles.analyticsEyebrow") %></span>
                        <h2 class="home-tile__title"><%= t("home.tiles.analyticsTitle") %></h2>
                        <p class="home-tile__copy">
                            <%= t("home.tiles.analyticsCopy") %>
                        </p>
                        <span class="home-tile__cta"><%= t("home.tiles.analyticsCta") %></span>
                    </a>

                    <a class="home-tile" href="/files/uploadUI">
                        <span class="home-tile__eyebrow"><%= t("home.tiles.uploadEyebrow") %></span>
                        <h2 class="home-tile__title"><%= t("home.tiles.uploadTitle") %></h2>
                        <p class="home-tile__copy">
                            <%= t("home.tiles.uploadCopy") %>
                        </p>
                        <span class="home-tile__cta"><%= t("home.tiles.uploadCta") %></span>
                    </a>
                </section>

                <section class="home-collab-grid">
                    <%- include("partials/activity-feed-panel", {
                        idPrefix: "home",
                        surfaceClass: "home-activity-panel",
                        headerClass: "home-section-header",
                        titleClass: "home-section-title",
                        copyClass: "home-section-copy",
                        toolbarClass: "home-section-toolbar",
                        toggleClass: "home-filter-toggle",
                        bodyClass: "home-surface-body",
                        title: t("home.auth.activityTitle"),
                        copy: t("home.auth.activityCopy"),
                        feedLabels: {
                            rangeAria: t("groups.filters.activityRangeAria"),
                            sourceAria: t("groups.filters.activitySourceAria"),
                            lastDay: t("groups.filters.lastDay"),
                            last7Days: t("groups.filters.last7Days"),
                            all: t("groups.filters.all"),
                            allUsers: t("groups.filters.allUsers"),
                            othersOnly: t("groups.filters.othersOnly")
                        },
                        defaultRange: "7d",
                        defaultActorScope: "all"
                    }) %>

                    <section class="home-activity-panel">
                        <div class="home-section-header">
                            <div>
                                <h2 class="home-section-title"><%= t("home.auth.myInvitesTitle") %></h2>
                                <p class="home-section-copy">
                                    <%= t("home.auth.myInvitesCopy") %>
                                </p>
                            </div>
                        </div>

                        <div class="home-surface-body">
                            <div id="home-group-invites-list"></div>
                        </div>
                    </section>
                </section>
            </div>
        </div>

        <%- include("partials/app-footer") %>
        <script>
            window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
        </script>
        <script type="module" src="/js/home-ui.js"></script>
    <% } else { %>
        <nav class="navbar navbar-dark home-topbar">
            <div class="container-fluid px-3 px-xl-4">
                <span class="navbar-brand"><%= t("home.guest.brand") %></span>
                <div class="d-flex align-items-center gap-2">
                    <a class="btn btn-outline-light btn-sm" href="/login"><%= t("home.guest.login") %></a>
                    <a class="btn btn-light btn-sm" href="/signup"><%= t("home.guest.signUp") %></a>
                </div>
            </div>
        </nav>

        <div class="container py-4 py-lg-5">
            <div class="home-shell">
                <section class="home-hero">
                    <div>
                        <p class="home-kicker"><%= t("home.guest.heroKicker") %></p>
                        <h1 class="home-title"><%= t("home.guest.heroTitle") %></h1>
                        <p class="home-subtitle">
                            <%= t("home.guest.heroSubtitle") %>
                        </p>
                    </div>

                    <div class="home-chip-group">
                        <span class="home-chip">
                            <span class="home-chip-label"><%= t("home.guest.chipFocus") %></span>
                            <span><%= t("home.guest.chipFocusValue") %></span>
                        </span>
                    </div>
                </section>

                <section class="home-auth-grid">
                    <div class="home-auth-panel">
                        <p class="home-kicker"><%= t("home.guest.platformKicker") %></p>
                        <h2 class="home-title" style="font-size: clamp(1.7rem, 2.2vw, 2.3rem);"><%= t("home.guest.platformTitle") %></h2>
                        <p class="home-subtitle" style="max-width:none;">
                            <%= t("home.guest.platformCopy") %>
                        </p>

                        <div class="home-auth-features">
                            <div class="home-auth-feature">
                                <h3 class="home-auth-feature__title"><%= t("home.guest.featureUploadTitle") %></h3>
                                <p class="home-auth-feature__copy"><%= t("home.guest.featureUploadCopy") %></p>
                            </div>
                            <div class="home-auth-feature">
                                <h3 class="home-auth-feature__title"><%= t("home.guest.featureSegmentsTitle") %></h3>
                                <p class="home-auth-feature__copy"><%= t("home.guest.featureSegmentsCopy") %></p>
                            </div>
                            <div class="home-auth-feature">
                                <h3 class="home-auth-feature__title"><%= t("home.guest.featureAnalyticsTitle") %></h3>
                                <p class="home-auth-feature__copy"><%= t("home.guest.featureAnalyticsCopy") %></p>
                            </div>
                        </div>
                    </div>

                    <div class="home-auth-card">
                        <div class="home-auth-card__header">
                            <h2 class="home-auth-card__title"><%= t("home.guest.continueTitle") %></h2>
                        </div>
                        <div class="home-auth-card__body">
                            <div class="d-grid gap-3">
                                <a class="btn btn-primary" href="/login"><%= t("home.guest.login") %></a>
                                <a class="btn btn-outline-primary" href="/signup"><%= t("home.guest.createAccount") %></a>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <%- include("partials/app-footer") %>
    <% } %>
</body>

</html>
