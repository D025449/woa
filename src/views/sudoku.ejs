<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t("sudokuPage.title") %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/sudoku.css">
</head>

<body class="sudoku-page">
    <% if (isAuthenticated) { %>
        <%- include("partials/app-topbar", {
            title: t("sudokuPage.topbarTitle"),
            currentPage: "sudoku",
            userInfo
        }) %>
    <% } else { %>
        <nav class="navbar navbar-dark home-topbar fixed-top">
            <div class="container-fluid px-3 px-xl-4">
                <span class="navbar-brand"><%= t("home.guest.brand") %></span>
                <div class="d-flex align-items-center gap-2">
                    <a class="btn btn-outline-light btn-sm" href="/login?redirect=%2Ffun%2Fsudoku"><%= t("home.guest.login") %></a>
                    <a class="btn btn-light btn-sm" href="/signup"><%= t("home.guest.signUp") %></a>
                </div>
            </div>
        </nav>
    <% } %>

    <main class="container-fluid px-3 px-xl-4 py-4 home-client-container">
        <section class="sudoku-hero">
            <div class="sudoku-hero__copy">
                <span class="sudoku-hero__kicker"><%= t("sudokuPage.heroKicker") %></span>
                <h1 class="sudoku-hero__title"><%= t("sudokuPage.heroTitle") %></h1>
                <p class="sudoku-hero__subtitle"><%= t("sudokuPage.heroSubtitle") %></p>
            </div>
            <div class="sudoku-hero__art" aria-hidden="true">
                <div class="sudoku-hero__art-grid">
                    <span>5</span><span></span><span>9</span>
                    <span></span><span>7</span><span></span>
                    <span>2</span><span></span><span>4</span>
                </div>
            </div>
        </section>

        <section
            class="sudoku-shell"
            id="sudoku-app"
            data-label-new="<%= t('sudokuPage.newPuzzle') %>"
            data-label-reset="<%= t('sudokuPage.resetPuzzle') %>"
            data-label-check="<%= t('sudokuPage.checkPuzzle') %>"
            data-label-solve="<%= t('sudokuPage.solvePuzzle') %>"
            data-label-notes="<%= t('sudokuPage.notesMode') %>"
            data-label-clear="<%= t('sudokuPage.clearCell') %>"
            data-status-ready="<%= t('sudokuPage.statusReady') %>"
            data-status-solved="<%= t('sudokuPage.statusSolved') %>"
            data-status-invalid="<%= t('sudokuPage.statusInvalid') %>"
            data-status-incomplete="<%= t('sudokuPage.statusIncomplete') %>"
            data-status-reset="<%= t('sudokuPage.statusReset') %>"
            data-status-solved-reveal="<%= t('sudokuPage.statusSolvedReveal') %>"
            data-difficulty-label="<%= t('sudokuPage.difficultyLabel') %>"
            data-difficulty-easy="<%= t('sudokuPage.difficultyEasy') %>"
            data-difficulty-medium="<%= t('sudokuPage.difficultyMedium') %>"
            data-difficulty-hard="<%= t('sudokuPage.difficultyHard') %>"
            data-legend-given="<%= t('sudokuPage.legendGiven') %>"
            data-legend-filled="<%= t('sudokuPage.legendFilled') %>"
            data-legend-conflict="<%= t('sudokuPage.legendConflict') %>"
            data-legend-notes="<%= t('sudokuPage.legendNotes') %>"
            data-number-pad-label="<%= t('sudokuPage.numberPadLabel') %>">
            <div class="sudoku-main-card">
                <div class="sudoku-toolbar">
                    <div class="sudoku-toolbar__group">
                        <label for="sudoku-difficulty" class="sudoku-toolbar__label"><%= t("sudokuPage.difficultyLabel") %></label>
                        <select id="sudoku-difficulty" class="form-select form-select-sm sudoku-toolbar__select">
                            <option value="easy"><%= t("sudokuPage.difficultyEasy") %></option>
                            <option value="medium" selected><%= t("sudokuPage.difficultyMedium") %></option>
                            <option value="hard"><%= t("sudokuPage.difficultyHard") %></option>
                        </select>
                    </div>
                    <div class="sudoku-toolbar__actions">
                        <button id="sudoku-new" class="btn btn-dark btn-sm" type="button"><%= t("sudokuPage.newPuzzle") %></button>
                        <button id="sudoku-reset" class="btn btn-outline-dark btn-sm" type="button"><%= t("sudokuPage.resetPuzzle") %></button>
                        <button id="sudoku-check" class="btn btn-outline-dark btn-sm" type="button"><%= t("sudokuPage.checkPuzzle") %></button>
                        <button id="sudoku-solve" class="btn btn-outline-dark btn-sm" type="button"><%= t("sudokuPage.solvePuzzle") %></button>
                    </div>
                </div>

                <div class="sudoku-game">
                    <div class="sudoku-board-wrap">
                        <div id="sudoku-board" class="sudoku-board" role="grid" aria-label="Sudoku"></div>
                    </div>

                    <aside class="sudoku-sidepanel">
                        <div class="sudoku-status-card">
                            <div class="sudoku-status-card__row">
                                <span class="sudoku-status-card__label"><%= t("sudokuPage.helpTitle") %></span>
                                <button id="sudoku-notes" class="btn btn-outline-dark btn-sm" type="button" aria-pressed="false"><%= t("sudokuPage.notesMode") %></button>
                            </div>
                            <p id="sudoku-status" class="sudoku-status-card__status"><%= t("sudokuPage.statusReady") %></p>
                            <p class="sudoku-status-card__help"><%= t("sudokuPage.helpCopy") %></p>
                            <button id="sudoku-clear" class="btn btn-outline-secondary btn-sm" type="button"><%= t("sudokuPage.clearCell") %></button>
                        </div>

                        <div class="sudoku-legend">
                            <span class="sudoku-legend__item"><i class="sudoku-swatch sudoku-swatch--given"></i><%= t("sudokuPage.legendGiven") %></span>
                            <span class="sudoku-legend__item"><i class="sudoku-swatch sudoku-swatch--filled"></i><%= t("sudokuPage.legendFilled") %></span>
                            <span class="sudoku-legend__item"><i class="sudoku-swatch sudoku-swatch--conflict"></i><%= t("sudokuPage.legendConflict") %></span>
                            <span class="sudoku-legend__item"><i class="sudoku-swatch sudoku-swatch--notes"></i><%= t("sudokuPage.legendNotes") %></span>
                        </div>

                        <div class="sudoku-pad-card">
                            <span class="sudoku-pad-card__label"><%= t("sudokuPage.numberPadLabel") %></span>
                            <div id="sudoku-pad" class="sudoku-pad"></div>
                        </div>
                    </aside>
                </div>
            </div>
        </section>
    </main>

    <script type="module" src="/js/sudoku-ui.js"></script>
</body>

</html>
