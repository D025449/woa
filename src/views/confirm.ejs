<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("confirm.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/auth.css">

</head>

<body class="auth-page">

    <nav class="navbar navbar-dark auth-topbar">
        <div class="container-fluid px-3 px-xl-4">
            <span class="navbar-brand"><%= t("confirm.brand") %></span>
        </div>
    </nav>

    <div class="container py-4 py-lg-5">
        <div class="auth-shell">
            <section class="auth-hero mb-4">
                <div>
                    <p class="auth-kicker"><%= t("confirm.heroKicker") %></p>
                    <h1 class="auth-title"><%= t("confirm.heroTitle") %></h1>
                    <p class="auth-subtitle">
                        <%= t("confirm.heroSubtitle") %>
                    </p>
                </div>

                <div>
                    <span class="auth-chip">
                        <span class="auth-chip-label"><%= t("confirm.chipLabel") %></span>
                        <span><%= t("confirm.chipValue") %></span>
                    </span>
                </div>
            </section>

            <div class="row justify-content-center">
                <div class="col-12">
                    <div class="auth-card">
                        <div class="auth-card-header">
                            <h5 class="auth-card-title"><%= t("confirm.cardTitle") %></h5>
                        </div>

                        <div class="auth-card-body">
                            <% if (typeof error !=="undefined" && error) { %>
                                <div class="alert alert-danger">
                                    <%= error %>
                                </div>
                                <% } %>
                                    <form method="POST" action="/confirm">

                                        <div class="mb-3">
                                            <label class="form-label"><%= t("confirm.username") %></label>
                                            <input type="text" class="form-control" name="username" value="<%= username %>" readonly>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label"><%= t("confirm.code") %></label>
                                            <input type="text" class="form-control" name="code" required>
                                        </div>

                                        <button class="btn btn-primary w-100 auth-primary-btn">
                                            <%= t("confirm.submit") %>
                                        </button>

                                    </form>

                        </div>
                    </div>

                </div>
            </div>

            <div class="text-center text-muted small mt-4">
                <a href="/impressum?<%= new URLSearchParams({ returnTo: currentUrl || "/confirm" }).toString() %>" class="text-decoration-none"><%= t("common.footer.legalNotice") %></a>
                <span class="mx-2">·</span>
                <a href="/datenschutz?<%= new URLSearchParams({ returnTo: currentUrl || "/confirm" }).toString() %>" class="text-decoration-none"><%= t("common.footer.privacy") %></a>
            </div>
        </div>
    </div>

</body>

</html>
