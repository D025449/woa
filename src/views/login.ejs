<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("login.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body.auth-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 28%),
                radial-gradient(circle at top right, rgba(13, 148, 136, 0.10), transparent 22%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .auth-topbar {
            background: linear-gradient(180deg, #0f172a 0%, #172235 100%) !important;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
        }

        .auth-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .auth-shell {
            max-width: 1080px;
            margin: 0 auto;
        }

        .auth-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 1.5rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92)),
                linear-gradient(135deg, rgba(15, 23, 42, 0.02), rgba(30, 64, 175, 0.04));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        }

        .auth-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .auth-title {
            margin: 0;
            font-size: clamp(2rem, 2.5vw, 2.85rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .auth-subtitle {
            margin: 0.75rem 0 0;
            max-width: 36rem;
            font-size: 0.98rem;
            color: #475569;
        }

        .auth-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .auth-chip-label {
            color: #64748b;
        }

        .auth-card {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .auth-card-header {
            padding: 1.1rem 1.4rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.88));
        }

        .auth-card-title {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .auth-card-body {
            padding: 1.35rem 1.4rem 1.5rem;
        }

        .auth-card-body .form-label {
            font-size: 0.84rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #475569;
        }

        .auth-card-body .form-control {
            border-radius: 1rem;
            padding: 0.85rem 1rem;
            border-color: rgba(148, 163, 184, 0.35);
            box-shadow: none;
        }

        .auth-primary-btn {
            border-radius: 999px;
            padding: 0.85rem 1rem;
            font-weight: 700;
        }

        .auth-divider {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            margin: 1rem 0;
            color: #94a3b8;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .auth-divider::before,
        .auth-divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: rgba(203, 213, 225, 0.9);
        }

        .auth-google-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.7rem;
            width: 100%;
            border-radius: 999px;
            padding: 0.82rem 1rem;
            font-weight: 700;
            border: 1px solid rgba(203, 213, 225, 0.95);
            background: #ffffff;
            color: #0f172a;
            text-decoration: none;
            transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
        }

        .auth-google-btn:hover {
            color: #0f172a;
            border-color: rgba(59, 130, 246, 0.3);
            box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
            transform: translateY(-1px);
            text-decoration: none;
        }

        .auth-google-icon {
            width: 1.15rem;
            height: 1.15rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }
    </style>

</head>

<body class="auth-page">

    <nav class="navbar navbar-dark auth-topbar">
        <div class="container-fluid px-3 px-xl-4">
            <span class="navbar-brand"><%= t("login.brand") %></span>
        </div>
    </nav>

    <div class="container py-4 py-lg-5">
        <div class="auth-shell">
            <section class="auth-hero mb-4">
                <div>
                    <p class="auth-kicker"><%= t("login.heroKicker") %></p>
                    <h1 class="auth-title"><%= t("login.heroTitle") %></h1>
                    <p class="auth-subtitle">
                        <%= t("login.heroSubtitle") %>
                    </p>
                </div>

                <div>
                    <span class="auth-chip">
                        <span class="auth-chip-label"><%= t("login.chipLabel") %></span>
                        <span><%= t("login.chipValue") %></span>
                    </span>
                </div>
            </section>

            <div class="row justify-content-center">
                <div class="col-12">
                    <div class="auth-card">
                        <div class="auth-card-header">
                            <h5 class="auth-card-title"><%= t("login.cardTitle") %></h5>
                        </div>

                        <div class="auth-card-body">

                            <% if (typeof error !== "undefined" && error) { %>
                                <div class="alert alert-danger">
                                    <%= error %>
                                </div>
                                <% } %>

                                    <form method="POST" action="/login">
                                    <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '' %>">
                                        <div class="mb-3">
                                            <label class="form-label"><%= t("login.emailOrUsername") %></label>
                                            <input type="text" class="form-control" name="email" autocomplete="username" required>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label"><%= t("login.password") %></label>
                                            <input type="password" class="form-control" name="password" autocomplete="current-password" required>
                                        </div>

                                        <button class="btn btn-primary w-100 auth-primary-btn">
                                            <%= t("login.submit") %>
                                        </button>

                                    </form>

                                    <div class="auth-divider"><%= t("login.divider") %></div>

                                    <a
                                        class="auth-google-btn"
                                        href="/auth/google<%= typeof redirect !== 'undefined' && redirect ? `?redirect=${encodeURIComponent(redirect)}` : '' %>"
                                    >
                                        <span class="auth-google-icon">G</span>
                                        <span><%= t("login.continueWithGoogle") %></span>
                                    </a>

                                    <div class="text-center mt-3">

                                        <a href="/signup">
                                            <%= t("login.createAccount") %>
                                        </a>

                                    </div>

                        </div>
                    </div>

                </div>
            </div>

            <div class="text-center text-muted small mt-4">
                <a href="/impressum?<%= new URLSearchParams({ returnTo: currentUrl || "/login" }).toString() %>" class="text-decoration-none"><%= t("login.legalNotice") %></a>
                <span class="mx-2">·</span>
                <a href="/datenschutz?<%= new URLSearchParams({ returnTo: currentUrl || "/login" }).toString() %>" class="text-decoration-none"><%= t("login.privacy") %></a>
            </div>
        </div>
    </div>

</body>

</html>
