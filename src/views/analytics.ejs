<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Workout Analytics</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

</head>

<body class="bg-light">

    <% if (isAuthenticated) { %>

        <!-- Navbar -->

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">

                <span class="navbar-brand">Workout Analysis</span>

                <div class="ms-auto d-flex align-items-center gap-3">

                    <span class="text-white">
                        <%= userInfo.username %>
                    </span>

                    <a class="btn btn-outline-light btn-sm" href="/files/uploadUI">
                        Upload
                    </a>
                    <a class="btn btn-outline-light btn-sm" href="/dashboard">
                        Dashboard
                    </a>
                    <a class="btn btn-outline-danger btn-sm" href="/logout">
                        Logout
                    </a>

                </div>

            </div>
        </nav>

        <!-- Content -->

        <div class="container py-4">

            <div class="row g-4">

                <!-- Workout Table -->

                <div class="col-12">



                    <div class="card shadow-sm">

                        <div class="card-header d-flex justify-content-between align-items-center">

                            <h5 class="mb-0">FTP Analytics</h5>

                            <!-- Grouping Toggle -->
                            <div class="btn-group" role="group">

                                <input type="radio" class="btn-check" name="grouping0" id="g-week0" value="week">
                                <label class="btn btn-outline-primary btn-sm" for="g-week0">Week</label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-month0" value="month">
                                <label class="btn btn-outline-primary btn-sm" for="g-month0">Month</label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-quarter0" value="quarter">
                                <label class="btn btn-outline-primary btn-sm" for="g-quarter0">Quarter</label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-year0" value="year" checked>
                                <label class="btn btn-outline-primary btn-sm" for="g-year0">Year</label>

                            </div>

                        </div>

                        <div class="card-body">

                            <div id="ftp-chart" style="height:400px;"></div>

                        </div>


                    </div>



                    <div class="card shadow-sm">

                        <div class="card-header d-flex justify-content-between align-items-center">

                            <h5 class="mb-0">Critical Power Analytics</h5>

                            <!-- Grouping Toggle -->
                            <div class="btn-group" role="group">

                                <input type="radio" class="btn-check" name="grouping" id="g-week" value="year_week" >
                                <label class="btn btn-outline-primary btn-sm" for="g-week">Week</label>

                                <input type="radio" class="btn-check" name="grouping" id="g-month" value="year_month">
                                <label class="btn btn-outline-primary btn-sm" for="g-month">Month</label>

                                <input type="radio" class="btn-check" name="grouping" id="g-quarter"
                                    value="year_quarter">
                                <label class="btn btn-outline-primary btn-sm" for="g-quarter">Quarter</label>

                                <input type="radio" class="btn-check" name="grouping" id="g-year" value="year" checked>
                                <label class="btn btn-outline-primary btn-sm" for="g-year">Year</label>

                            </div>

                        </div>

                        <div class="card-body">

                            <div id="cp-chart" style="height:400px;"></div>

                        </div>


                    </div>

                </div>

                <!-- Chart -->

                <div class="col-12">

                    <div class="card shadow-sm">

                        <div class="card-header">
                            <h5 class="mb-0">Workout Data</h5>
                        </div>

                        <div class="card-body">

                            <div id="workout-chart" style="height:500px;"></div>

                        </div>

                    </div>
                    <div class="card shadow-sm mt-4">
                        <div class="card-header">
                            <h5 class="mb-0">Route Map</h5>
                        </div>

                        <div class="card-body p-0">
                            <div id="workout-map" style="height:400px;"></div>
                        </div>
                    </div>
                </div>



            </div>

        </div>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4">Please log in</h3>

                <a class="btn btn-primary" href="/login">
                    Login
                </a>

            </div>

            <% } %>


                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
                <script type="module" src="/js/analytics-view.js"></script>
                <!--script type="module" src="/js/dashboard-table.js"></script-->

</body>

</html>