<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("analyticsPage.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        body.analytics-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 28%),
                radial-gradient(circle at top right, rgba(13, 148, 136, 0.10), transparent 22%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .app-topbar {
            background: linear-gradient(180deg, #0f172a 0%, #172235 100%) !important;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
        }

        .app-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .app-topbar-profile {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.3rem;
            height: 2.3rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
            color: #e2e8f0;
            transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
        }

        .app-topbar-profile:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar-profile__icon {
            width: 1rem;
            height: 1rem;
        }

        .app-topbar .nav-link {
            color: rgba(226, 232, 240, 0.82);
            font-weight: 600;
            padding: 0.35rem 0.25rem;
            border-bottom: 2px solid transparent;
        }

        .app-topbar .nav-link:hover,
        .app-topbar .nav-link.active {
            color: #ffffff;
            border-bottom-color: rgba(226, 232, 240, 0.8);
        }

        .app-topbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            border-color: rgba(148, 163, 184, 0.28);
        }

        .app-topbar .btn-outline-light {
            color: #e2e8f0;
            border-color: rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
        }

        .app-topbar .btn-outline-light:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar .btn-outline-danger {
            color: #fecaca;
            border-color: rgba(248, 113, 113, 0.32);
            background: rgba(127, 29, 29, 0.18);
        }

        .app-topbar .btn-outline-danger:hover {
            color: #fff1f2;
            background: rgba(220, 38, 38, 0.28);
            border-color: rgba(248, 113, 113, 0.45);
        }

        .analytics-shell {
            display: grid;
            gap: 1.5rem;
        }

        .app-footer {
            margin-top: 1.5rem;
            text-align: center;
            color: #64748b;
            font-size: 0.88rem;
        }

        .app-footer a {
            color: #475569;
            text-decoration: none;
        }

        .app-footer a:hover {
            color: #0f172a;
            text-decoration: underline;
        }

        .analytics-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 1.5rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92)),
                linear-gradient(135deg, rgba(15, 23, 42, 0.02), rgba(30, 64, 175, 0.04));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
            backdrop-filter: blur(10px);
        }

        .analytics-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .analytics-title {
            margin: 0;
            font-size: clamp(2rem, 2.5vw, 2.85rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .analytics-subtitle {
            margin: 0.75rem 0 0;
            max-width: 48rem;
            font-size: 0.98rem;
            color: #475569;
        }

        .analytics-hero-meta {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .analytics-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .analytics-chip-label {
            color: #64748b;
        }

        .analytics-surface {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .analytics-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.1rem 1.4rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.88));
        }

        .analytics-eyebrow {
            display: block;
            margin-bottom: 0.2rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .analytics-section-title {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .analytics-section-copy {
            margin: 0.35rem 0 0;
            font-size: 0.9rem;
            color: #64748b;
        }

        .analytics-toggle-group .btn {
            border-radius: 999px !important;
            font-weight: 600;
            padding-inline: 0.85rem;
        }

        .analytics-body {
            padding: 0;
        }

        .analytics-chart-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.5rem;
        }

        .analytics-focus-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.7fr) minmax(340px, 1fr);
            gap: 1.5rem;
            align-items: stretch;
        }

        #ctl-chart,
        #ftp-chart,
        #cp-chart {
            height: 400px !important;
        }

        #workout-chart {
            height: 560px !important;
        }

        #workout-map {
            height: 560px !important;
        }

        @media (max-width: 1199.98px) {
            .analytics-chart-grid,
            .analytics-focus-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 991.98px) {
            .analytics-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .analytics-hero-meta {
                justify-content: flex-start;
            }

            #workout-chart,
            #workout-map {
                height: 460px !important;
            }
        }
    </style>

</head>

<body class="analytics-page">

    <% if (isAuthenticated) { %>

        <%- include("partials/app-topbar", {
            title: t("analyticsPage.topbarTitle"),
            currentPage: "analytics",
            userInfo,
            showDashboardNewLink: true
        }) %>
        <!-- Content -->
        <div class="container-fluid px-3 px-xl-4 py-4">
            <div class="analytics-shell">

                <section class="analytics-hero">
                    <div>
                        <p class="analytics-kicker"><%= t("analyticsPage.kicker") %></p>
                        <h1 class="analytics-title"><%= t("analyticsPage.mainTitle") %></h1>
                        <p class="analytics-subtitle">
                            <%= t("analyticsPage.subtitle") %>
                        </p>
                    </div>

                    <div class="analytics-hero-meta">
                        <span class="analytics-chip">
                            <span class="analytics-chip-label"><%= t("analyticsPage.chipUser") %></span>
                            <span><%= ((typeof userInfo !== "undefined" && userInfo) ? (userInfo.display_name || userInfo.email) : t("analyticsPage.chipUnknownUser")) %></span>
                        </span>
                        <span class="analytics-chip">
                            <span class="analytics-chip-label"><%= t("analyticsPage.chipFocus") %></span>
                            <span><%= t("analyticsPage.chipFocusValue") %></span>
                        </span>
                        <span class="analytics-chip">
                            <span class="analytics-chip-label"><%= t("analyticsPage.chipWorkspace") %></span>
                            <span><%= t("analyticsPage.chipWorkspaceValue") %></span>
                        </span>
                    </div>
                </section>

                <section class="analytics-chart-grid">
                    <article class="analytics-surface">
                        <div class="analytics-section-header">
                            <div>
                                <span class="analytics-eyebrow"><%= t("analyticsPage.loadModelEyebrow") %></span>
                                <h2 class="analytics-section-title"><%= t("analyticsPage.loadModelTitle") %></h2>
                                <p class="analytics-section-copy">
                                    <%= t("analyticsPage.loadModelCopy") %>
                                </p>
                            </div>

                            <div class="btn-group analytics-toggle-group" role="group">
                                <input type="radio" class="btn-check" name="grouping1" id="g-date1" value="date" checked>
                                <label class="btn btn-outline-primary btn-sm" for="g-date1"><%= t("analyticsPage.toggleDate") %></label>

                                <input type="radio" class="btn-check" name="grouping1" id="g-week1" value="week">
                                <label class="btn btn-outline-primary btn-sm" for="g-week1"><%= t("analyticsPage.toggleWeek") %></label>

                                <input type="radio" class="btn-check" name="grouping1" id="g-month1" value="month">
                                <label class="btn btn-outline-primary btn-sm" for="g-month1"><%= t("analyticsPage.toggleMonth") %></label>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="ctl-chart"></div>
                        </div>
                    </article>

                    <article class="analytics-surface">
                        <div class="analytics-section-header">
                            <div>
                                <span class="analytics-eyebrow"><%= t("analyticsPage.thresholdEyebrow") %></span>
                                <h2 class="analytics-section-title"><%= t("analyticsPage.thresholdTitle") %></h2>
                                <p class="analytics-section-copy">
                                    <%= t("analyticsPage.thresholdCopy") %>
                                </p>
                            </div>

                            <div class="btn-group analytics-toggle-group" role="group">
                                <input type="radio" class="btn-check" name="grouping0" id="g-week0" value="week">
                                <label class="btn btn-outline-primary btn-sm" for="g-week0"><%= t("analyticsPage.toggleWeek") %></label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-month0" value="month">
                                <label class="btn btn-outline-primary btn-sm" for="g-month0"><%= t("analyticsPage.toggleMonth") %></label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-quarter0" value="quarter">
                                <label class="btn btn-outline-primary btn-sm" for="g-quarter0"><%= t("analyticsPage.toggleQuarter") %></label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-year0" value="year" checked>
                                <label class="btn btn-outline-primary btn-sm" for="g-year0"><%= t("analyticsPage.toggleYear") %></label>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="ftp-chart"></div>
                        </div>
                    </article>

                    <article class="analytics-surface">
                        <div class="analytics-section-header">
                            <div>
                                <span class="analytics-eyebrow"><%= t("analyticsPage.powerCurveEyebrow") %></span>
                                <h2 class="analytics-section-title"><%= t("analyticsPage.powerCurveTitle") %></h2>
                                <p class="analytics-section-copy">
                                    <%= t("analyticsPage.powerCurveCopy") %>
                                </p>
                            </div>

                            <div class="btn-group analytics-toggle-group" role="group">
                                <input type="radio" class="btn-check" name="grouping" id="g-week" value="year_week">
                                <label class="btn btn-outline-primary btn-sm" for="g-week"><%= t("analyticsPage.toggleWeek") %></label>

                                <input type="radio" class="btn-check" name="grouping" id="g-month" value="year_month">
                                <label class="btn btn-outline-primary btn-sm" for="g-month"><%= t("analyticsPage.toggleMonth") %></label>

                                <input type="radio" class="btn-check" name="grouping" id="g-quarter" value="year_quarter">
                                <label class="btn btn-outline-primary btn-sm" for="g-quarter"><%= t("analyticsPage.toggleQuarter") %></label>

                                <input type="radio" class="btn-check" name="grouping" id="g-year" value="year" checked>
                                <label class="btn btn-outline-primary btn-sm" for="g-year"><%= t("analyticsPage.toggleYear") %></label>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="cp-chart"></div>
                        </div>
                    </article>
                </section>

                <section class="analytics-focus-grid">
                    <article class="analytics-surface">
                        <div class="analytics-section-header">
                            <div>
                                <span class="analytics-eyebrow"><%= t("analyticsPage.workoutContextEyebrow") %></span>
                                <h2 class="analytics-section-title"><%= t("analyticsPage.workoutContextTitle") %></h2>
                                <p class="analytics-section-copy">
                                    <%= t("analyticsPage.workoutContextCopy") %>
                                </p>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="workout-chart"></div>
                        </div>
                    </article>

                    <aside class="analytics-surface">
                        <div class="analytics-section-header">
                            <div>
                                <span class="analytics-eyebrow"><%= t("analyticsPage.spatialEyebrow") %></span>
                                <h2 class="analytics-section-title"><%= t("analyticsPage.spatialTitle") %></h2>
                                <p class="analytics-section-copy">
                                    <%= t("analyticsPage.spatialCopy") %>
                                </p>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="workout-map"></div>
                        </div>
                    </aside>
                </section>
            </div>
        </div>

        <%- include("partials/app-footer") %>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4"><%= t("common.auth.pleaseSignIn") %></h3>

                <a class="btn btn-primary" href="/login">
                    <%= t("analyticsPage.signIn") %>
                </a>

            </div>

            <% } %>

        
                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
                <script>
                    window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
                </script>
                <script type="module" src="/js/analytics-ui.js"></script>
                <!--script type="module" src="/js/dashboard-table.js"></script-->

</body>

</html>
