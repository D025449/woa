<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("analyticsPage.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/analytics.css">

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

</head>

<body class="analytics-page">

    <% if (isAuthenticated) { %>

        <%- include("partials/app-topbar", {
            title: t("analyticsPage.topbarTitle"),
            currentPage: "analytics",
            userInfo,
            showDashboardNewLink: true
        }) %>
        <!-- Content -->
        <div class="container-fluid px-3 px-xl-4 py-4">
            <div id="analytics-shell" class="analytics-shell ui-page-shell">

                <section id="analytics-hero" class="analytics-hero ui-hero ui-hero--compact">
                    <div>
                        <p class="analytics-kicker ui-hero__kicker"><%= t("analyticsPage.kicker") %></p>
                        <h1 class="analytics-title ui-hero__title"><%= t("analyticsPage.mainTitle") %></h1>
                        <p class="analytics-subtitle ui-hero__subtitle">
                            <%= t("analyticsPage.subtitle") %>
                        </p>
                    </div>
                    <div class="ui-hero__art" aria-hidden="true">
                        <svg viewBox="0 0 64 64" fill="none">
                            <defs>
                                <linearGradient id="analyticsHeroGradient" x1="10" y1="50" x2="54" y2="12" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#0f766e" />
                                    <stop offset="1" stop-color="#2563eb" />
                                </linearGradient>
                            </defs>
                            <path d="M12 50H54" stroke="rgba(148,163,184,0.34)" stroke-width="3" stroke-linecap="round" />
                            <path d="M16 42L26 31L34 35L48 19" stroke="url(#analyticsHeroGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M16 28L24 24L32 27L44 16" stroke="rgba(37,99,235,0.26)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                            <circle cx="48" cy="19" r="4" fill="#2563eb" />
                        </svg>
                    </div>
                </section>

                <section id="analytics-chart-grid" class="analytics-chart-grid">
                    <article class="analytics-surface ui-surface ui-surface--gradient analytics-grid-panel">
                        <div class="analytics-section-header ui-section-header">
                            <div>
                                <span class="analytics-eyebrow ui-eyebrow"><%= t("analyticsPage.loadModelEyebrow") %></span>
                                <h2 class="analytics-section-title ui-title"><%= t("analyticsPage.loadModelTitle") %></h2>
                                <p class="analytics-section-copy ui-copy">
                                    <%= t("analyticsPage.loadModelCopy") %>
                                </p>
                            </div>

                            <div class="btn-group analytics-toggle-group ui-toggle-group" role="group">
                                <input type="radio" class="btn-check" name="grouping1" id="g-date1" value="date" checked>
                                <label class="btn btn-outline-primary btn-sm" for="g-date1"><%= t("analyticsPage.toggleDate") %></label>

                                <input type="radio" class="btn-check" name="grouping1" id="g-week1" value="week">
                                <label class="btn btn-outline-primary btn-sm" for="g-week1"><%= t("analyticsPage.toggleWeek") %></label>

                                <input type="radio" class="btn-check" name="grouping1" id="g-month1" value="month">
                                <label class="btn btn-outline-primary btn-sm" for="g-month1"><%= t("analyticsPage.toggleMonth") %></label>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="ctl-chart"></div>
                        </div>
                    </article>

                    <article class="analytics-surface ui-surface ui-surface--gradient analytics-grid-panel">
                        <div class="analytics-section-header ui-section-header">
                            <div>
                                <span class="analytics-eyebrow ui-eyebrow"><%= t("analyticsPage.thresholdEyebrow") %></span>
                                <h2 class="analytics-section-title ui-title"><%= t("analyticsPage.thresholdTitle") %></h2>
                                <p class="analytics-section-copy ui-copy">
                                    <%= t("analyticsPage.thresholdCopy") %>
                                </p>
                            </div>

                            <div class="btn-group analytics-toggle-group ui-toggle-group" role="group">
                                <input type="radio" class="btn-check" name="grouping0" id="g-week0" value="week">
                                <label class="btn btn-outline-primary btn-sm" for="g-week0"><%= t("analyticsPage.toggleWeek") %></label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-month0" value="month">
                                <label class="btn btn-outline-primary btn-sm" for="g-month0"><%= t("analyticsPage.toggleMonth") %></label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-quarter0" value="quarter">
                                <label class="btn btn-outline-primary btn-sm" for="g-quarter0"><%= t("analyticsPage.toggleQuarter") %></label>

                                <input type="radio" class="btn-check" name="grouping0" id="g-year0" value="year" checked>
                                <label class="btn btn-outline-primary btn-sm" for="g-year0"><%= t("analyticsPage.toggleYear") %></label>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="ftp-chart"></div>
                        </div>
                    </article>

                    <article class="analytics-surface ui-surface ui-surface--gradient analytics-grid-panel">
                        <div class="analytics-section-header ui-section-header">
                            <div>
                                <span class="analytics-eyebrow ui-eyebrow"><%= t("analyticsPage.powerCurveEyebrow") %></span>
                                <h2 class="analytics-section-title ui-title"><%= t("analyticsPage.powerCurveTitle") %></h2>
                                <p class="analytics-section-copy ui-copy">
                                    <%= t("analyticsPage.powerCurveCopy") %>
                                </p>
                            </div>

                            <div class="btn-group analytics-toggle-group ui-toggle-group" role="group">
                                <input type="radio" class="btn-check" name="grouping" id="g-week" value="year_week">
                                <label class="btn btn-outline-primary btn-sm" for="g-week"><%= t("analyticsPage.toggleWeek") %></label>

                                <input type="radio" class="btn-check" name="grouping" id="g-month" value="year_month">
                                <label class="btn btn-outline-primary btn-sm" for="g-month"><%= t("analyticsPage.toggleMonth") %></label>

                                <input type="radio" class="btn-check" name="grouping" id="g-quarter" value="year_quarter">
                                <label class="btn btn-outline-primary btn-sm" for="g-quarter"><%= t("analyticsPage.toggleQuarter") %></label>

                                <input type="radio" class="btn-check" name="grouping" id="g-year" value="year" checked>
                                <label class="btn btn-outline-primary btn-sm" for="g-year"><%= t("analyticsPage.toggleYear") %></label>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="cp-chart"></div>
                        </div>
                    </article>
                </section>

                <section id="analytics-focus-grid" class="analytics-focus-grid">
                    <article class="analytics-surface ui-surface ui-surface--gradient analytics-focus-panel">
                        <div class="analytics-section-header ui-section-header">
                            <div>
                                <span class="analytics-eyebrow ui-eyebrow"><%= t("analyticsPage.workoutContextEyebrow") %></span>
                                <h2 class="analytics-section-title ui-title"><%= t("analyticsPage.workoutContextTitle") %></h2>
                                <p class="analytics-section-copy ui-copy">
                                    <%= t("analyticsPage.workoutContextCopy") %>
                                </p>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="workout-chart"></div>
                        </div>
                    </article>

                    <aside class="analytics-surface ui-surface ui-surface--gradient analytics-focus-panel">
                        <div class="analytics-section-header ui-section-header">
                            <div>
                                <span class="analytics-eyebrow ui-eyebrow"><%= t("analyticsPage.spatialEyebrow") %></span>
                                <h2 class="analytics-section-title ui-title"><%= t("analyticsPage.spatialTitle") %></h2>
                                <p class="analytics-section-copy ui-copy">
                                    <%= t("analyticsPage.spatialCopy") %>
                                </p>
                            </div>
                        </div>

                        <div class="analytics-body">
                            <div id="workout-map"></div>
                        </div>
                    </aside>
                </section>
            </div>
        </div>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4"><%= t("common.auth.pleaseSignIn") %></h3>

                <a class="btn btn-primary" href="/login">
                    <%= t("analyticsPage.signIn") %>
                </a>

            </div>

            <% } %>

        
                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
                <script>
                    window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
                </script>
                <script type="module" src="/js/analytics-ui.js"></script>
                <!--script type="module" src="/js/dashboard-table.js"></script-->

</body>

</html>
