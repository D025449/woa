<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("groups.hero.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body.groups-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 28%),
                radial-gradient(circle at top right, rgba(13, 148, 136, 0.10), transparent 22%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .app-topbar {
            background: linear-gradient(180deg, #0f172a 0%, #172235 100%) !important;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
        }

        .app-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .app-topbar .nav-link {
            color: rgba(226, 232, 240, 0.82);
            font-weight: 600;
            padding: 0.35rem 0.25rem;
            border-bottom: 2px solid transparent;
        }

        .app-topbar .nav-link:hover,
        .app-topbar .nav-link.active {
            color: #ffffff;
            border-bottom-color: rgba(226, 232, 240, 0.8);
        }

        .app-topbar-profile {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.3rem;
            height: 2.3rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
            color: #e2e8f0;
            transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
        }

        .app-topbar-profile:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar-profile__icon {
            width: 1rem;
            height: 1rem;
        }

        .app-topbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            border-color: rgba(148, 163, 184, 0.28);
        }

        .app-topbar .btn-outline-danger {
            color: #fecaca;
            border-color: rgba(248, 113, 113, 0.32);
            background: rgba(127, 29, 29, 0.18);
        }

        .app-topbar .btn-outline-danger:hover {
            color: #fff1f2;
            background: rgba(220, 38, 38, 0.28);
            border-color: rgba(248, 113, 113, 0.45);
        }

        .groups-shell {
            display: grid;
            gap: 1.5rem;
        }

        .groups-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 1.5rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92)),
                linear-gradient(135deg, rgba(15, 23, 42, 0.02), rgba(30, 64, 175, 0.04));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        }

        .groups-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .groups-title {
            margin: 0;
            font-size: clamp(2rem, 2.8vw, 3rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .groups-subtitle {
            margin: 0.75rem 0 0;
            max-width: 44rem;
            font-size: 1rem;
            color: #475569;
        }

        .groups-hero-meta {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .groups-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .groups-chip-label {
            color: #64748b;
        }

        .groups-grid {
            display: grid;
            grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.78fr);
            gap: 1.5rem;
        }

        .groups-surface {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
            overflow: hidden;
        }

        .groups-section-header {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: center;
            padding: 1.2rem 1.3rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
        }

        .groups-section-title {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 700;
            color: #0f172a;
        }

        .groups-section-copy {
            margin: 0.3rem 0 0;
            font-size: 0.9rem;
            color: #64748b;
        }

        .groups-surface-body {
            padding: 1.1rem 1.25rem 1.25rem;
        }

        .groups-action-btn {
            border-radius: 999px;
            font-weight: 700;
            padding-inline: 0.95rem;
        }

        .groups-toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .groups-filter-toggle {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.28rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(248, 250, 252, 0.92);
        }

        .groups-filter-toggle .btn {
            border-radius: 999px;
            padding-inline: 0.85rem;
            font-weight: 700;
            border-color: transparent;
        }

        .groups-filter-toggle .btn.active {
            background: #0f172a;
            color: #f8fafc;
            border-color: #0f172a;
        }

        .groups-section-toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .groups-empty {
            border: 1px dashed rgba(148, 163, 184, 0.35);
            border-radius: 1.15rem;
            padding: 1rem 1.05rem;
            background: rgba(248, 250, 252, 0.92);
            color: #64748b;
        }

        .groups-empty strong {
            color: #0f172a;
        }

        .groups-stack {
            display: grid;
            gap: 1rem;
        }

        .groups-preview-card {
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 1.15rem;
            padding: 1rem 1.05rem;
            background: rgba(255, 255, 255, 0.88);
        }

        .groups-preview-kicker {
            display: block;
            margin-bottom: 0.3rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .groups-preview-title {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .groups-preview-copy {
            margin: 0.45rem 0 0;
            font-size: 0.9rem;
            color: #475569;
            line-height: 1.55;
        }

        .groups-member-summary {
            margin-top: 0.9rem;
        }

        .groups-member-summary__label {
            margin-bottom: 0.45rem;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #64748b;
        }

        .groups-member-summary__items {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .groups-member-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.32rem 0.68rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(248, 250, 252, 0.95);
            font-size: 0.82rem;
            font-weight: 600;
            color: #1e293b;
        }

        .groups-member-pill--more {
            color: #475569;
            background: rgba(241, 245, 249, 0.95);
        }

        .groups-preview-actions {
            display: flex;
            gap: 0.65rem;
            flex-wrap: wrap;
            margin-top: 0.95rem;
        }

        .groups-preview-actions .btn {
            border-radius: 999px;
            font-weight: 700;
            padding-inline: 0.85rem;
        }

        .groups-preview-actions .btn-success {
            background: rgba(5, 150, 105, 0.12);
            border-color: rgba(5, 150, 105, 0.28);
            color: #047857;
        }

        .groups-preview-actions .btn-success:hover {
            background: rgba(5, 150, 105, 0.18);
            border-color: rgba(5, 150, 105, 0.38);
            color: #065f46;
        }

        .groups-form-note {
            margin-top: 0.35rem;
            font-size: 0.84rem;
            color: #64748b;
        }

        .groups-modal .modal-content {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.35rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.96));
            box-shadow: 0 22px 48px rgba(15, 23, 42, 0.16);
        }

        .groups-modal .modal-header,
        .groups-modal .modal-footer {
            border-color: rgba(226, 232, 240, 0.85);
        }

        .groups-modal .form-control,
        .groups-modal .form-select {
            border-radius: 0.95rem;
            border-color: rgba(148, 163, 184, 0.35);
            padding: 0.72rem 0.9rem;
        }

        .groups-modal .form-control:focus,
        .groups-modal .form-select:focus {
            border-color: rgba(37, 99, 235, 0.45);
            box-shadow: 0 0 0 0.25rem rgba(37, 99, 235, 0.12);
        }

        .app-footer {
            margin-top: 1.5rem;
            text-align: center;
            color: #64748b;
            font-size: 0.88rem;
        }

        .app-footer a {
            color: #475569;
            text-decoration: none;
        }

        .app-footer a:hover {
            color: #0f172a;
            text-decoration: underline;
        }

        @media (max-width: 991.98px) {
            .groups-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .groups-hero-meta {
                justify-content: flex-start;
            }

            .groups-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="groups-page">

    <% if (isAuthenticated) { %>

        <%- include("partials/app-topbar", {
            title: t("groups.hero.title"),
            currentPage: "groups",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <div class="container-fluid px-3 px-xl-4 py-4">
            <div class="groups-shell">
                <section class="groups-hero">
                    <div>
                        <p class="groups-kicker"><%= t("groups.hero.kicker") %></p>
                        <h1 class="groups-title"><%= t("groups.hero.title") %></h1>
                        <p class="groups-subtitle">
                            <%= t("groups.hero.subtitle") %>
                        </p>
                    </div>

                    <div class="groups-hero-meta">
                        <span class="groups-chip">
                            <span class="groups-chip-label"><%= t("groups.hero.chipUser") %></span>
                            <span><%= ((typeof userInfo !== "undefined" && userInfo) ? (userInfo.display_name || userInfo.email) : t("groups.hero.unknownUser")) %></span>
                        </span>
                        <span class="groups-chip">
                            <span class="groups-chip-label"><%= t("groups.hero.chipPhase") %></span>
                            <span><%= t("groups.hero.phaseValue") %></span>
                        </span>
                        <span class="groups-chip">
                            <span class="groups-chip-label"><%= t("groups.hero.chipFocus") %></span>
                            <span><%= t("groups.hero.focusValue") %></span>
                        </span>
                    </div>
                </section>

                <section class="groups-grid">
                    <div class="groups-surface">
                        <div class="groups-section-header">
                            <div>
                                <h2 class="groups-section-title"><%= t("groups.sections.myGroupsTitle") %></h2>
                                <p class="groups-section-copy">
                                    <%= t("groups.sections.myGroupsCopy") %>
                                </p>
                            </div>

                            <div class="groups-toolbar">
                                <div class="groups-filter-toggle" role="group" aria-label="<%= t("groups.filters.groupFilterAria") %>">
                                    <button
                                        class="btn btn-sm btn-outline-secondary active"
                                        type="button"
                                        id="groups-filter-all"
                                        data-filter-value="all">
                                        <%= t("groups.filters.allGroups") %>
                                    </button>
                                    <button
                                        class="btn btn-sm btn-outline-secondary"
                                        type="button"
                                        id="groups-filter-owned"
                                        data-filter-value="owned">
                                        <%= t("groups.filters.ownedByMe") %>
                                    </button>
                                </div>

                                <button class="btn btn-primary groups-action-btn" type="button" id="groups-create-button">
                                    <%= t("groups.buttons.createGroup") %>
                                </button>
                            </div>
                        </div>

                        <div class="groups-surface-body">
                            <div id="groups-list"></div>
                        </div>
                    </div>

                    <div class="groups-stack">
                        <div class="groups-surface">
                            <%- include("partials/activity-feed-panel", {
                                idPrefix: "group",
                                surfaceClass: "groups-surface",
                                headerClass: "groups-section-header",
                                titleClass: "groups-section-title",
                                copyClass: "groups-section-copy",
                                toolbarClass: "groups-section-toolbar",
                                toggleClass: "groups-filter-toggle",
                                bodyClass: "groups-surface-body",
                                title: t("groups.sections.activityTitle"),
                                copy: t("groups.sections.activityCopy"),
                                feedLabels: {
                                    rangeAria: t("groups.filters.activityRangeAria"),
                                    sourceAria: t("groups.filters.activitySourceAria"),
                                    lastDay: t("groups.filters.lastDay"),
                                    last7Days: t("groups.filters.last7Days"),
                                    all: t("groups.filters.all"),
                                    allUsers: t("groups.filters.allUsers"),
                                    othersOnly: t("groups.filters.othersOnly")
                                },
                                defaultRange: "7d",
                                defaultActorScope: "all"
                            }) %>
                        </div>

                        <div class="groups-surface">
                            <div class="groups-section-header">
                                <div>
                                    <h2 class="groups-section-title"><%= t("groups.sections.myInvitesTitle") %></h2>
                                    <p class="groups-section-copy">
                                        <%= t("groups.sections.myInvitesCopy") %>
                                    </p>
                                </div>
                            </div>

                            <div class="groups-surface-body">
                                <div id="group-invites-list"></div>
                            </div>
                        </div>

                        <div class="groups-surface">
                            <div class="groups-section-header">
                                <div>
                                    <h2 class="groups-section-title"><%= t("groups.sections.sentByMeTitle") %></h2>
                                    <p class="groups-section-copy">
                                        <%= t("groups.sections.sentByMeCopy") %>
                                    </p>
                                </div>
                            </div>

                            <div class="groups-surface-body">
                                <div id="group-sent-invites-list"></div>
                            </div>
                        </div>

                        <div class="groups-preview-card">
                            <span class="groups-preview-kicker"><%= t("groups.sections.detailsKicker") %></span>
                            <h3 class="groups-preview-title"><%= t("groups.sections.detailsTitle") %></h3>
                            <p class="groups-preview-copy">
                                <%= t("groups.sections.detailsCopy") %>
                            </p>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <%- include("partials/app-footer") %>

        <div class="modal fade groups-modal" id="create-group-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <form id="create-group-form">
                        <div class="modal-header">
                            <div>
                                <p class="groups-kicker mb-1"><%= t("groups.modal.groupsLabel") %></p>
                                <h2 class="groups-section-title mb-0"><%= t("groups.modal.createTitle") %></h2>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <div class="modal-body">
                            <div id="create-group-error" class="alert alert-danger d-none" role="alert"></div>

                            <div class="mb-3">
                                <label class="form-label"><%= t("groups.modal.nameLabel") %></label>
                                <input
                                    type="text"
                                    class="form-control"
                                    name="name"
                                    maxlength="120"
                                    required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label"><%= t("groups.modal.descriptionLabel") %></label>
                                <textarea
                                    class="form-control"
                                    name="description"
                                    rows="4"
                                    placeholder="<%= t("groups.modal.descriptionPlaceholderCreate") %>"></textarea>
                            </div>

                            <div class="mb-0">
                                <label class="form-label"><%= t("groups.modal.visibilityLabel") %></label>
                                <select class="form-select" name="visibility">
                                    <option value="private" selected><%= t("groups.modal.visibilityPrivate") %></option>
                                    <option value="discoverable"><%= t("groups.modal.visibilityDiscoverable") %></option>
                                </select>
                                <div class="groups-form-note">
                                    <%= t("groups.modal.visibilityHint") %>
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary groups-action-btn" data-bs-dismiss="modal">
                                <%= t("groups.buttons.cancel") %>
                            </button>
                            <button type="submit" class="btn btn-primary groups-action-btn" id="create-group-submit">
                                <%= t("groups.buttons.createGroup") %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade groups-modal" id="edit-group-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <form id="edit-group-form">
                        <input type="hidden" name="groupId">

                        <div class="modal-header">
                            <div>
                                <p class="groups-kicker mb-1"><%= t("groups.modal.groupsLabel") %></p>
                                <h2 class="groups-section-title mb-0"><%= t("groups.modal.editTitle") %></h2>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <div class="modal-body">
                            <div id="edit-group-error" class="alert alert-danger d-none" role="alert"></div>

                            <div class="mb-3">
                                <label class="form-label"><%= t("groups.modal.nameLabel") %></label>
                                <input
                                    type="text"
                                    class="form-control"
                                    name="name"
                                    maxlength="120"
                                    required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label"><%= t("groups.modal.descriptionLabel") %></label>
                                <textarea
                                    class="form-control"
                                    name="description"
                                    rows="4"
                                    maxlength="500"
                                    placeholder="<%= t("groups.modal.descriptionPlaceholderEdit") %>"></textarea>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary groups-action-btn" data-bs-dismiss="modal">
                                <%= t("groups.buttons.cancel") %>
                            </button>
                            <button type="submit" class="btn btn-primary groups-action-btn" id="edit-group-submit">
                                <%= t("groups.buttons.saveChanges") %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade groups-modal" id="invite-group-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <form id="invite-group-form">
                        <input type="hidden" name="groupId">

                        <div class="modal-header">
                            <div>
                                <p class="groups-kicker mb-1"><%= t("groups.modal.groupsLabel") %></p>
                                <h2 class="groups-section-title mb-0"><%= t("groups.modal.inviteTitle") %></h2>
                                <p class="groups-section-copy mb-0" id="invite-group-context"></p>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <div class="modal-body">
                            <div id="invite-group-error" class="alert alert-danger d-none" role="alert"></div>

                            <div class="mb-3">
                                <label class="form-label"><%= t("groups.modal.inviteEmailLabel") %></label>
                                <input
                                    type="email"
                                    class="form-control"
                                    name="invitedEmail"
                                    required
                                    placeholder="<%= t("groups.modal.inviteEmailPlaceholder") %>">
                                <div class="groups-form-note">
                                    <%= t("groups.modal.inviteHint") %>
                                </div>
                            </div>

                            <div class="mb-0">
                                <label class="form-label"><%= t("groups.modal.inviteMessageLabel") %></label>
                                <textarea
                                    class="form-control"
                                    name="message"
                                    rows="4"
                                    placeholder="<%= t("groups.modal.inviteMessagePlaceholder") %>"></textarea>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary groups-action-btn" data-bs-dismiss="modal">
                                <%= t("groups.buttons.cancel") %>
                            </button>
                            <button type="submit" class="btn btn-primary groups-action-btn" id="invite-group-submit">
                                <%= t("groups.buttons.sendInvite") %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade groups-modal" id="publish-group-content-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <form id="publish-group-content-form">
                        <div class="modal-header">
                            <div>
                                <p class="groups-kicker mb-1"><%= t("groups.modal.groupsLabel") %></p>
                                <h2 class="groups-section-title mb-0"><%= t("groups.modal.publishTitle") %></h2>
                                <p class="groups-section-copy mb-0" id="publish-group-content-context"></p>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <div class="modal-body">
                            <div id="publish-group-content-error" class="alert alert-danger d-none" role="alert"></div>

                            <div class="mb-3">
                                <label class="form-label"><%= t("groups.modal.contentTypeLabel") %></label>
                                <select class="form-select" id="publish-group-content-type" name="contentType">
                                    <option value="workouts"><%= t("groups.modal.contentTypeWorkouts") %></option>
                                    <option value="segments"><%= t("groups.modal.contentTypeSegments") %></option>
                                </select>
                            </div>

                            <div class="mb-0" id="publish-group-workout-preset-wrapper">
                                <label class="form-label"><%= t("groups.modal.selectionLabel") %></label>
                                <select class="form-select" name="workoutPreset">
                                    <option value="training-30d"><%= t("groups.modal.presetTraining30d") %></option>
                                    <option value="training-90d"><%= t("groups.modal.presetTraining90d") %></option>
                                    <option value="uploaded-7d"><%= t("groups.modal.presetUploaded7d") %></option>
                                    <option value="uploaded-90d"><%= t("groups.modal.presetUploaded90d") %></option>
                                    <option value="all"><%= t("groups.modal.presetAll") %></option>
                                </select>
                                <div class="groups-form-note">
                                <%= t("groups.modal.presetHint") %>
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary groups-action-btn" data-bs-dismiss="modal">
                                <%= t("groups.buttons.cancel") %>
                            </button>
                            <button type="submit" class="btn btn-primary groups-action-btn" id="publish-group-content-submit">
                                <%= t("groups.buttons.publish") %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade groups-modal" id="leave-group-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <div>
                            <p class="groups-kicker mb-1"><%= t("groups.modal.groupsLabel") %></p>
                            <h2 class="groups-section-title mb-0"><%= t("groups.modal.leaveTitle") %></h2>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <div id="leave-group-error" class="alert alert-danger d-none" role="alert"></div>
                        <p id="leave-group-context" class="mb-0 text-muted"></p>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary groups-action-btn" data-bs-dismiss="modal">
                            <%= t("groups.buttons.cancel") %>
                        </button>
                        <button type="button" class="btn btn-danger groups-action-btn" id="leave-group-confirm">
                            <%= t("groups.buttons.leaveGroupConfirm") %>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade groups-modal" id="delete-group-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <div>
                            <p class="groups-kicker mb-1"><%= t("groups.modal.groupsLabel") %></p>
                            <h2 class="groups-section-title mb-0"><%= t("groups.modal.deleteTitle") %></h2>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <div id="delete-group-error" class="alert alert-danger d-none" role="alert"></div>
                        <p id="delete-group-context" class="mb-0 text-muted"></p>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary groups-action-btn" data-bs-dismiss="modal">
                            <%= t("groups.buttons.cancel") %>
                        </button>
                        <button type="button" class="btn btn-danger groups-action-btn" id="delete-group-confirm">
                            <%= t("groups.buttons.deleteGroupConfirm") %>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    <% } %>

    <script>
        window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
    </script>
    <script type="module" src="/js/groups-ui.js"></script>
</body>

</html>
