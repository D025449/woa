<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Workout Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        body.dashboard-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 28%),
                radial-gradient(circle at top right, rgba(13, 148, 136, 0.10), transparent 22%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .app-topbar {
            background: linear-gradient(180deg, #0f172a 0%, #172235 100%) !important;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
        }

        .app-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .app-topbar-user {
            color: rgba(226, 232, 240, 0.82);
            font-size: 0.92rem;
            font-weight: 500;
        }

        .app-topbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            border-color: rgba(148, 163, 184, 0.28);
        }

        .app-topbar .btn-outline-light {
            color: #e2e8f0;
            border-color: rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
        }

        .app-topbar .btn-outline-light:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar .btn-outline-danger {
            color: #fecaca;
            border-color: rgba(248, 113, 113, 0.32);
            background: rgba(127, 29, 29, 0.18);
        }

        .app-topbar .btn-outline-danger:hover {
            color: #fff1f2;
            background: rgba(220, 38, 38, 0.28);
            border-color: rgba(248, 113, 113, 0.45);
        }

        .dashboard-shell {
            display: grid;
            gap: 1.5rem;
        }

        .app-footer {
            margin-top: 1.5rem;
            text-align: center;
            color: #64748b;
            font-size: 0.88rem;
        }

        .app-footer a {
            color: #475569;
            text-decoration: none;
        }

        .app-footer a:hover {
            color: #0f172a;
            text-decoration: underline;
        }

        .dashboard-toast {
            border-radius: 1rem;
            border: 1px solid rgba(251, 191, 36, 0.35);
            background: rgba(255, 251, 235, 0.96);
            color: #7c2d12;
            box-shadow: 0 18px 35px rgba(15, 23, 42, 0.16);
            backdrop-filter: blur(10px);
        }

        .dashboard-toast .toast-body {
            font-weight: 600;
        }

        .dashboard-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 1.5rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92)),
                linear-gradient(135deg, rgba(15, 23, 42, 0.02), rgba(30, 64, 175, 0.04));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
            backdrop-filter: blur(10px);
        }

        .dashboard-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .dashboard-title {
            margin: 0;
            font-size: clamp(2rem, 2.5vw, 2.85rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .dashboard-subtitle {
            margin: 0.75rem 0 0;
            max-width: 44rem;
            font-size: 0.98rem;
            color: #475569;
        }

        .dashboard-hero-meta {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .dashboard-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .dashboard-chip-label {
            color: #64748b;
        }

        .dashboard-section {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
            overflow: hidden;
        }

        .dashboard-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.1rem 1.4rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.88));
        }

        .dashboard-section-header--compact {
            padding-bottom: 0.9rem;
        }

        .dashboard-eyebrow {
            display: block;
            margin-bottom: 0.2rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .dashboard-section-title {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .dashboard-section-copy {
            margin: 0.35rem 0 0;
            font-size: 0.9rem;
            color: #64748b;
        }

        .dashboard-toolbar {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 0.55rem;
        }

        .dashboard-toolbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            box-shadow: none;
        }

        .dashboard-table-body {
            padding: 1rem 1.2rem 1.2rem;
        }

        .dashboard-table-body .tabulator {
            border: 0;
            border-radius: 1rem;
            background: transparent;
            color: #0f172a;
            font-size: 0.92rem;
        }

        .dashboard-table-body .tabulator .tabulator-header {
            border-bottom: 1px solid rgba(226, 232, 240, 0.9);
            background: transparent;
        }

        .dashboard-table-body .tabulator .tabulator-header .tabulator-col {
            background: transparent;
            border-right: 0;
            padding-block: 0.15rem;
        }

        .dashboard-table-body .tabulator .tabulator-header .tabulator-col .tabulator-col-content {
            padding: 0.45rem 0.8rem 0.65rem;
        }

        .dashboard-table-body .tabulator .tabulator-header .tabulator-col .tabulator-col-title {
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
        }

        .dashboard-table-body .tabulator .tabulator-header .tabulator-header-filter input {
            min-height: 2rem;
            border: 1px solid rgba(203, 213, 225, 0.75);
            border-radius: 999px;
            padding-inline: 0.75rem;
            background: rgba(248, 250, 252, 0.95);
            color: #334155;
            font-size: 0.82rem;
            box-shadow: none;
        }

        .dashboard-table-body .tabulator .tabulator-tableholder {
            background: transparent;
        }

        .dashboard-table-body .tabulator .tabulator-row {
            min-height: 58px;
            border-bottom: 1px solid rgba(241, 245, 249, 0.95);
            background: rgba(255, 255, 255, 0.62);
            transition: background-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
        }

        .dashboard-table-body .tabulator .tabulator-row:nth-child(even) {
            background: rgba(248, 250, 252, 0.78);
        }

        .dashboard-table-body .tabulator .tabulator-row:hover {
            background: rgba(239, 246, 255, 0.92);
            box-shadow: inset 0 0 0 1px rgba(191, 219, 254, 0.75);
        }

        .dashboard-table-body .tabulator .tabulator-row .tabulator-cell {
            border-right: 0;
            padding: 0.85rem 0.8rem;
            display: flex;
            align-items: center;
        }

        .dashboard-table-body .tabulator-row.tabulator-selected {
            background: rgba(219, 234, 254, 0.98);
        }

        .dashboard-table-body .tabulator-row.tabulator-selected .tabulator-cell {
            color: #0f172a;
        }

        .dashboard-table-primary {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .dashboard-table-secondary {
            margin-top: 0.12rem;
            font-size: 0.8rem;
            color: #64748b;
        }

        .dashboard-table-number {
            width: 100%;
            display: inline-block;
            text-align: right;
            font-variant-numeric: tabular-nums;
            color: #0f172a;
        }

        .dashboard-table-body .delete-btn {
            border-radius: 999px;
            padding-inline: 0.85rem;
            font-weight: 600;
            margin-left: auto;
        }

        .dashboard-visual-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.7fr) minmax(340px, 1fr);
            gap: 1.5rem;
            align-items: stretch;
        }

        .dashboard-surface {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .dashboard-surface-body {
            padding: 0;
        }

        #workout-chart,
        #workout-map {
            height: 560px !important;
        }

        @media (max-width: 991.98px) {
            .dashboard-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .dashboard-hero-meta {
                justify-content: flex-start;
            }

            .dashboard-visual-grid {
                grid-template-columns: 1fr;
            }

            #workout-chart,
            #workout-map {
                height: 460px !important;
            }
        }
    </style>

</head>

<body class="dashboard-page">

    <% if (isAuthenticated) { %>

        <!-- Navbar -->

        <nav class="navbar navbar-expand-lg navbar-dark app-topbar">
            <div class="container-fluid px-3 px-xl-4">

                <span class="navbar-brand">Workout Dashboard</span>

                <div class="ms-auto d-flex align-items-center gap-3">

                    <span class="app-topbar-user">
                        <%= userInfo.username %>
                    </span>

                    <a class="btn btn-outline-light btn-sm" href="/files/uploadUI">
                        Upload
                    </a>
                    <a class="btn btn-outline-light btn-sm" href="/analytics">
                        Analytics
                    </a>
                    <a class="btn btn-outline-light btn-sm" href="/segments">
                        Segments
                    </a>

                    <a class="btn btn-outline-danger btn-sm" href="/logout">
                        Logout
                    </a>

                </div>

            </div>
        </nav>

        <!-- Content -->

        <div class="container-fluid px-3 px-xl-4 py-4">

            <div class="dashboard-shell">

                <section class="dashboard-hero">
                    <div>
                        <p class="dashboard-kicker">Performance Analysis Console</p>
                        <h1 class="dashboard-title">Workout Dashboard</h1>
                        <p class="dashboard-subtitle">
                            Wähle ein Workout und analysiere Leistung, Route und Segmentlogik in einer ruhigen,
                            datenfokussierten Arbeitsfläche.
                        </p>
                    </div>

                    <div class="dashboard-hero-meta">
                        <span class="dashboard-chip">
                            <span class="dashboard-chip-label">Ansicht</span>
                            <span>Desktop Focus</span>
                        </span>
                        <span class="dashboard-chip">
                            <span class="dashboard-chip-label">Workflow</span>
                            <span>Analyse · Segmente · Karte</span>
                        </span>
                    </div>
                </section>

                <section class="dashboard-section">
                    <div class="dashboard-section-header dashboard-section-header--compact">
                        <div>
                            <span class="dashboard-eyebrow">Workout Library</span>
                            <h2 id="files_header" class="dashboard-section-title">Workouts</h2>
                            <p class="dashboard-section-copy">
                                Öffne ein Workout aus der Liste und springe direkt in Chart- und Kartenanalyse.
                            </p>
                        </div>
                    </div>

                    <div class="dashboard-table-body">
                        <div id="file-table"></div>
                    </div>
                </section>

                <section class="dashboard-visual-grid">
                    <article class="dashboard-surface">
                        <div class="dashboard-section-header">
                            <div>
                                <span class="dashboard-eyebrow">Primary Analysis</span>
                                <h2 class="dashboard-section-title">Workout Data</h2>
                                <p class="dashboard-section-copy">
                                    Leistung, Herzfrequenz, Kadenz, Speed und Höhe mit direkter Segment-Interaktion.
                                </p>
                            </div>

                            <div class="dashboard-toolbar">
                                <button id="draw-segment-toggle" class="btn btn-sm btn-outline-primary"
                                    title="Create-Segment-Modus aktivieren.">
                                    ＋ Create Segment
                                </button>
                                <button id="draw-gps-segment-toggle" class="btn btn-sm btn-outline-success"
                                    title="Create-GPS-Segment-Modus aktivieren." disabled>
                                    🛰 Create GPS Segment
                                </button>
                                <button id="delete-segments" class="btn btn-sm btn-outline-danger">
                                    🗑 Delete Segment
                                </button>
                            </div>
                        </div>

                        <div class="dashboard-surface-body">
                            <div id="workout-chart"></div>
                        </div>
                    </article>

                    <aside class="dashboard-surface">
                        <div class="dashboard-section-header">
                            <div>
                                <span class="dashboard-eyebrow">Spatial Context</span>
                                <h2 class="dashboard-section-title">Route Map</h2>
                                <p class="dashboard-section-copy">
                                    Track, Segmentbereiche und Kartenkontext als ergänzende Analysefläche.
                                </p>
                            </div>
                        </div>

                        <div class="dashboard-surface-body">
                            <div id="workout-map"></div>
                        </div>
                    </aside>
                </section>
            </div>

        </div>

        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="dashboard-toast" class="toast dashboard-toast border-0" role="alert" aria-live="assertive"
                aria-atomic="true">
                <div class="toast-body" id="dashboard-toast-body"></div>
            </div>
        </div>

        <footer class="app-footer pb-4">
            <a href="/impressum">Impressum</a>
            <span class="mx-2">·</span>
            <a href="/datenschutz">Datenschutz</a>
        </footer>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4">Please log in</h3>

                <a class="btn btn-primary" href="/login">
                    Login
                </a>

            </div>

            <% } %>
                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

                <script type="module" src="/js/dashboard-ui.js"></script>

</body>

</html>
