<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FIT-Datei hochladen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
    <link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">



</head>

<body>

    <div>
        <% if (isAuthenticated) { %>
            <div class="container mt-5">
                <h2>Welcome, <%= userInfo.name || userInfo.email %>
                </h2>
            </div>


            <div class="container mt-5">
                <h2 class="mb-4">Loaded Workouts</h2>
                <div id="file-table"></div>

                <div id="workout-chart" style="height:600px;"></div>
                <a href="/files/uploadUI">Upload Files...</a>
                <a href="/logout">Logout</a>

            </div>

            <% } else { %>
                <div class="container mt-5"></div>
                <p>Please log in to continue</p>
                <a href="/login">Login</a>
    </div>
    <% } %>
        </div>
        <!-- ECharts -->
        <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

        <!-- Dein Script -->
        <script src="/js/dashboard-table.js"></script>

        <!--script>
            //   const jwtToken = "<%= userInfo.access_token %>"; // jetzt enthält er den Access Token
            import Tabulator from "tabulator-tables";
            import "tabulator-tables/dist/css/tabulator.min.css";
        </script-->
</body>

</html>