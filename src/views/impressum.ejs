<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Legal Notice</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/legal.css">
</head>

<body>
    <div class="container py-5">
        <div class="legal-shell mx-auto">
            <div class="legal-surface">
                <div class="legal-header">
                    <span class="legal-kicker">Legal Information</span>
                    <h1 class="legal-title">Legal Notice</h1>
                </div>

                <div class="legal-body">
                    <div class="legal-note mb-4">
                        This page is a technical template. Replace the details below with your real legal and contact data.
                    </div>

                    <h2 class="h5">Information According to § 5 TMG</h2>
                    <p>
                        Max Mustermann<br>
                        Musterstraße 1<br>
                        12345 Musterstadt<br>
                        Deutschland
                    </p>

                    <h2 class="h5">Kontakt</h2>
                    <p>
                        E-Mail: kontakt@example.com<br>
                        Telefon: +49 0000 000000
                    </p>

                    <h2 class="h5">Responsible for Content</h2>
                    <p>
                        Max Mustermann<br>
                        Musterstraße 1<br>
                        12345 Musterstadt
                    </p>

                    <div class="mt-4">
                        <a class="btn btn-outline-primary btn-sm" href="<%= returnTo %>">Back to application</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
