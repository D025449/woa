<%
    const tr = typeof t === "function" ? t : ((key) => key);
    const labels = feedLabels || {};
    const rangeAriaLabel = labels.rangeAria || tr("groups.filters.activityRangeAria");
    const sourceAriaLabel = labels.sourceAria || tr("groups.filters.activitySourceAria");
    const lastDayLabel = labels.lastDay || tr("groups.filters.lastDay");
    const last7DaysLabel = labels.last7Days || tr("groups.filters.last7Days");
    const allLabel = labels.all || tr("groups.filters.all");
    const allUsersLabel = labels.allUsers || tr("groups.filters.allUsers");
    const othersOnlyLabel = labels.othersOnly || tr("groups.filters.othersOnly");
%>
<section class="<%= surfaceClass %>">
    <div class="<%= headerClass %>">
        <div>
            <% if (idPrefix === "home") { %>
                <a class="home-panel-icon home-panel-icon--activity home-panel-icon--link" href="/groups" aria-label="<%= tr('home.auth.activityTitle') %>">
                    <svg viewBox="0 0 64 64" fill="none">
                        <defs>
                            <linearGradient id="homePanelActivityGradient" x1="12" y1="48" x2="52" y2="18" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#0f766e" />
                                <stop offset="1" stop-color="#2563eb" />
                            </linearGradient>
                        </defs>
                        <path d="M14 42H22L27 28L34 40L41 22L46 33H52" stroke="url(#homePanelActivityGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M14 50H52" stroke="rgba(148,163,184,0.34)" stroke-width="3" stroke-linecap="round" />
                    </svg>
                </a>
            <% } %>
            <h2 class="<%= titleClass %>"><%= title %></h2>
            <p class="<%= copyClass %>"><%= copy %></p>
        </div>

        <div class="<%= toolbarClass %>">
            <div class="<%= toggleClass %>" role="group" aria-label="<%= rangeAriaLabel %>">
                <button
                    class="btn btn-sm btn-outline-secondary <%= defaultRange === '1d' ? 'active' : '' %>"
                    type="button"
                    id="<%= idPrefix %>-feed-filter-1d"
                    data-feed-filter-value="1d">
                    <%= lastDayLabel %>
                </button>
                <button
                    class="btn btn-sm btn-outline-secondary <%= defaultRange === '7d' ? 'active' : '' %>"
                    type="button"
                    id="<%= idPrefix %>-feed-filter-7d"
                    data-feed-filter-value="7d">
                    <%= last7DaysLabel %>
                </button>
                <button
                    class="btn btn-sm btn-outline-secondary <%= defaultRange === 'all' ? 'active' : '' %>"
                    type="button"
                    id="<%= idPrefix %>-feed-filter-all"
                    data-feed-filter-value="all">
                    <%= allLabel %>
            </button>
            </div>

            <div class="<%= toggleClass %>" role="group" aria-label="<%= sourceAriaLabel %>">
                <button
                    class="btn btn-sm btn-outline-secondary <%= defaultActorScope !== 'others' ? 'active' : '' %>"
                    type="button"
                    id="<%= idPrefix %>-feed-actor-all"
                    data-feed-actor-value="all">
                    <%= allUsersLabel %>
                </button>
                <button
                    class="btn btn-sm btn-outline-secondary <%= defaultActorScope === 'others' ? 'active' : '' %>"
                    type="button"
                    id="<%= idPrefix %>-feed-actor-others"
                    data-feed-actor-value="others">
                    <%= othersOnlyLabel %>
                </button>
            </div>
        </div>
    </div>

    <div class="<%= bodyClass %>">
        <div id="<%= idPrefix %>-feed-list"></div>
    </div>
</section>
