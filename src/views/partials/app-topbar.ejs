<nav class="navbar navbar-expand-lg navbar-dark app-topbar">
    <div class="container-fluid px-3 px-xl-4">

        <span class="navbar-brand"><%= title %></span>

        <div class="ms-auto d-flex align-items-center gap-3">

            <span class="app-topbar-user">
                <%= userInfo.username || userInfo.email %>
            </span>

            <% if (typeof showUploadLink === "undefined" || showUploadLink !== false) { %>
                <a class="btn btn-outline-light btn-sm" href="/files/uploadUI">
                    Upload
                </a>
            <% } %>

            <% if (typeof showAnalyticsLink === "undefined" || showAnalyticsLink !== false) { %>
                <a class="btn btn-outline-light btn-sm" href="/analytics">
                    Analytics
                </a>
            <% } %>

            <% if (typeof showSegmentsLink === "undefined" || showSegmentsLink !== false) { %>
                <a class="btn btn-outline-light btn-sm" href="/segments">
                    Segments
                </a>
            <% } %>

            <% if (currentPage === "dashboard-new") { %>
                <a class="btn btn-outline-light btn-sm" href="/dashboard">
                    Classic
                </a>
            <% } else if (typeof showDashboardLink === "undefined" || showDashboardLink !== false) { %>
                <a class="btn btn-outline-light btn-sm" href="/dashboard">
                    Dashboard
                </a>
            <% } %>

            <% if (currentPage !== "dashboard-new" && typeof showDashboardNewLink !== "undefined" && showDashboardNewLink) { %>
                <a class="btn btn-outline-light btn-sm" href="/dashboard-new">
                    Dashboard New
                </a>
            <% } %>

            <a class="btn btn-outline-danger btn-sm" href="/logout">
                Logout
            </a>

        </div>

    </div>
</nav>
