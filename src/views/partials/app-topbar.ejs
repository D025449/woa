<%
    const tr = typeof t === "function" ? t : ((key) => key);
%>
<link rel="stylesheet" href="/css/app-chrome.css">
<nav class="navbar navbar-expand-lg navbar-dark app-topbar fixed-top">
    <div class="container-fluid px-3 px-xl-4">

        <a
            class="navbar-brand d-inline-flex align-items-center gap-2"
            href="/"
            aria-label="<%= title || tr('common.nav.brand') %>">
            <svg
                width="26"
                height="26"
                viewBox="0 0 26 26"
                aria-hidden="true"
                focusable="false">
                <rect x="1" y="1" width="24" height="24" rx="8" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.18)"></rect>
                <path
                    d="M5.5 16.5 9.5 13.5 12.25 14.4 17 8.9 20.5 10.75"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                <circle cx="9.5" cy="13.5" r="1.35" fill="currentColor"></circle>
                <circle cx="17" cy="8.9" r="1.35" fill="currentColor"></circle>
            </svg>
            <span><%= tr("common.nav.brand") %></span>
        </a>

        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#appTopbarNav" aria-controls="appTopbarNav" aria-expanded="false" aria-label="<%= tr('common.nav.openNavigation') %>">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-end" id="appTopbarNav">
            <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2 gap-lg-3 mt-3 mt-lg-0 w-100 justify-content-lg-end">
                <ul class="navbar-nav flex-column flex-lg-row align-items-lg-center gap-lg-2 me-lg-2">
                    <li class="nav-item">
                        <a class="nav-link <%= currentPage === 'home' ? 'active' : '' %>" href="/">
                            <%= tr("common.nav.home") %>
                        </a>
                    </li>

                    <% if (typeof showDashboardNewLink === "undefined" || showDashboardNewLink !== false) { %>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'dashboard-new' ? 'active' : '' %>" href="/dashboard-new">
                                <%= tr("common.nav.workouts") %>
                            </a>
                        </li>
                    <% } %>

                    <% if (typeof showSegmentsLink === "undefined" || showSegmentsLink !== false) { %>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'segments' ? 'active' : '' %>" href="/segments">
                                <%= tr("common.nav.segments") %>
                            </a>
                        </li>
                    <% } %>

                    <% if (typeof showAnalyticsLink === "undefined" || showAnalyticsLink !== false) { %>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'analytics' ? 'active' : '' %>" href="/analytics">
                                <%= tr("common.nav.analytics") %>
                            </a>
                        </li>
                    <% } %>

                    <% if (typeof showCoachingLink === "undefined" || showCoachingLink !== false) { %>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'coaching' ? 'active' : '' %>" href="/coaching">
                                <%= tr("common.nav.coaching") %>
                            </a>
                        </li>
                    <% } %>

                    <% if (typeof showUploadLink === "undefined" || showUploadLink !== false) { %>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'upload' ? 'active' : '' %>" href="/files/uploadUI">
                                <%= tr("common.nav.upload") %>
                            </a>
                        </li>
                    <% } %>

                    <% if (typeof showGroupsLink === "undefined" || showGroupsLink !== false) { %>
                        <li class="nav-item">
                            <a class="nav-link <%= currentPage === 'groups' ? 'active' : '' %>" href="/groups">
                                <%= tr("common.nav.groups") %>
                            </a>
                        </li>
                    <% } %>

                    <li class="nav-item">
                        <details class="app-topbar-menu">
                            <summary class="nav-link app-topbar-menu__summary">
                                <%= tr("common.nav.about") %>
                            </summary>
                            <div class="app-topbar-dropdown">
                                <a class="app-topbar-dropdown__item" href="/impressum">
                                    <%= tr("common.footer.legalNotice") %>
                                </a>
                                <a class="app-topbar-dropdown__item" href="/datenschutz">
                                    <%= tr("common.footer.privacy") %>
                                </a>
                            </div>
                        </details>
                    </li>
                </ul>

                <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2">
                    <a
                        href="/profile"
                        class="app-topbar-profile"
                        data-bs-toggle="tooltip"
                        data-bs-placement="bottom"
                        data-bs-title="<%= [[userInfo.display_name, userInfo.email].filter(Boolean).join(' · '), tr('common.nav.openProfile')].filter(Boolean).join(' · ') %>">
                        <svg class="app-topbar-profile__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M12 12.25a4.25 4.25 0 1 0-4.25-4.25A4.25 4.25 0 0 0 12 12.25Zm0 2c-3.79 0-6.87 2.08-7.34 4.95a.75.75 0 0 0 .74.87h13.2a.75.75 0 0 0 .74-.87C18.87 16.33 15.79 14.25 12 14.25Z" fill="currentColor"></path>
                        </svg>
                    </a>

                    <a class="btn btn-outline-danger btn-sm" href="/logout">
                        <%= tr("common.nav.logout") %>
                    </a>
                </div>
            </div>
        </div>

    </div>
</nav>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function syncAppTopbarOffset() {
        const topbar = document.querySelector(".app-topbar.fixed-top");
        if (!topbar) return;

        const updateOffset = () => {
            const height = Math.ceil(topbar.getBoundingClientRect().height);
            document.documentElement.style.setProperty("--app-topbar-offset", `${height + 12}px`);
            document.body.classList.add("has-fixed-app-topbar");
        };

        updateOffset();
        window.addEventListener("resize", updateOffset, { passive: true });
    })();

    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
        bootstrap.Tooltip.getOrCreateInstance(el);
    });
</script>
