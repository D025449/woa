<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("dashboardNewPage.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/dashboard-new.css">

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

</head>

<body class="dashboard-page">

    <% if (isAuthenticated) { %>

        <%- include("partials/app-topbar", {
            title: t("dashboardNewPage.topbarTitle"),
            currentPage: "dashboard-new",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <!-- Content -->

        <div class="container-fluid px-3 px-xl-4 py-4">

            <div class="dashboard-shell">

                <section class="dashboard-hero">
                    <div>
                        <p class="dashboard-kicker"><%= t("dashboardNewPage.kicker") %></p>
                        <h1 class="dashboard-title"><%= t("dashboardNewPage.titleMain") %></h1>
                        <p class="dashboard-subtitle"><%= t("dashboardNewPage.subtitle") %></p>
                    </div>
                </section>

                <section class="dashboard-master-detail">
                    <button id="dashboard-mobile-library-toggle" class="btn btn-outline-dark dashboard-mobile-library-toggle" type="button" aria-expanded="false">
                        <%= t("dashboardNewPage.mobileLibraryOpen") %>
                    </button>
                    <div class="dashboard-library-column">
                        <section class="dashboard-section dashboard-library-section">
                            <div class="dashboard-section-header dashboard-section-header--compact">
                                <div>
                                    <span class="dashboard-eyebrow"><%= t("dashboardNewPage.libraryEyebrow") %></span>
                                    <h2 id="files_header" class="dashboard-section-title"><%= t("dashboardNewPage.libraryTitle") %></h2>
                                    <p class="dashboard-section-copy">
                                        <%= t("dashboardNewPage.libraryCopy") %>
                                    </p>
                                </div>
                            </div>

                            <div class="dashboard-table-body">
                                <div class="workout-library-toolbar">
                                    <div class="workout-library-scope-toggle" role="group" aria-label="<%= t('dashboardNewPage.filterAria') %>">
                                        <button
                                            id="workout-library-scope-mine"
                                            class="btn btn-sm btn-outline-secondary active"
                                            type="button"
                                            data-workout-scope="mine">
                                            <%= t("dashboardNewPage.filterMine") %>
                                        </button>
                                        <button
                                            id="workout-library-scope-shared"
                                            class="btn btn-sm btn-outline-secondary"
                                            type="button"
                                            data-workout-scope="shared">
                                            <%= t("dashboardNewPage.filterShared") %>
                                        </button>
                                        <button
                                            id="workout-library-scope-all"
                                            class="btn btn-sm btn-outline-secondary"
                                            type="button"
                                            data-workout-scope="all">
                                            <%= t("dashboardNewPage.filterAll") %>
                                        </button>
                                    </div>
                                    <input
                                        id="workout-library-search"
                                        class="form-control workout-library-input"
                                        type="search"
                                        placeholder="<%= t('dashboardNewPage.searchPlaceholder') %>"
                                    >
                                    <div id="workout-library-active-filters" class="workout-library-active-filters" hidden></div>
                                    <div class="workout-library-hint">
                                        <span class="workout-library-hint__label"><%= t("dashboardNewPage.library.searchHintLabel") %></span>
                                        <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-example="power:225">power:225</button>
                                        <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-example="power > 200">power &gt; 200</button>
                                        <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-example="hr <= 150">hr &lt;= 150</button>
                                        <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-example="date:2018-03">date:2018-03</button>
                                        <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-scope="power">power:</button>
                                        <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-scope="np">np:</button>
                                        <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-scope="hr">hr:</button>
                                        <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-scope="date">date:</button>
                                    </div>
                                    <select id="workout-library-sort" class="form-select workout-library-select">
                                        <option value="newest"><%= t("dashboardNewPage.sortNewest") %></option>
                                        <option value="uploaded"><%= t("dashboardNewPage.sortUploaded") %></option>
                                        <option value="oldest"><%= t("dashboardNewPage.sortOldest") %></option>
                                        <option value="distance"><%= t("dashboardNewPage.sortDistance") %></option>
                                        <option value="duration"><%= t("dashboardNewPage.sortDuration") %></option>
                                        <option value="power"><%= t("dashboardNewPage.sortPower") %></option>
                                        <option value="np"><%= t("dashboardNewPage.sortNp") %></option>
                                    </select>
                                </div>

                                <div class="workout-library-scroll">
                                    <div id="workout-library" class="workout-library-grid"></div>
                                    <div id="workout-library-load-more" class="workout-library-load-more d-none">
                                        <button class="btn btn-outline-primary" type="button"><%= t("dashboardNewPage.loadMore") %></button>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>

                    <section class="dashboard-detail-grid">
                        <article id="dashboard-workspace-panel" class="dashboard-surface dashboard-workspace-panel">
                        <div class="dashboard-section-header">
                            <div class="dashboard-workspace-header">
                                <div>
                                <span class="dashboard-eyebrow"><%= t("dashboardNewPage.primaryEyebrow") %></span>
                                <h2 class="dashboard-section-title"><%= t("dashboardNewPage.workoutDataTitle") %></h2>
                                <p id="dashboard-detail-copy" class="dashboard-section-copy">
                                    <%= t("dashboardNewPage.messages.ownedWorkoutDetailCopy") %>
                                </p>
                                <div id="dashboard-shared-meta" class="dashboard-shared-meta d-none">
                                    <span class="dashboard-shared-meta__eyebrow"><%= t("dashboardNewPage.sharedWorkoutEyebrow") %></span>
                                    <span id="dashboard-shared-meta-text"></span>
                                </div>
                                </div>
                                <div id="dashboard-workspace-summary" class="dashboard-workspace-summary is-idle">
                                    <div id="dashboard-workspace-summary-title" class="dashboard-workspace-summary__title"><%= t("dashboardNewPage.libraryTitle") %></div>
                                    <div id="dashboard-workspace-summary-meta" class="dashboard-workspace-summary__meta"><%= t("dashboardNewPage.messages.ownedWorkoutDetailCopy") %></div>
                                    <div id="dashboard-workspace-summary-chips" class="dashboard-workspace-summary__chips"></div>
                                </div>
                            </div>

                            <div class="dashboard-toolbar dashboard-workspace-toolbar">
                                <button id="draw-segment-toggle" class="btn btn-sm btn-outline-primary"
                                    title="<%= t('dashboardNewPage.btnCreateSegmentTitle') %>">
                                    <%= t("dashboardNewPage.btnCreateSegment") %>
                                </button>
                                <button id="draw-gps-segment-toggle" class="btn btn-sm btn-outline-success"
                                    title="<%= t('dashboardNewPage.btnCreateGpsTitle') %>" disabled>
                                    <%= t("dashboardNewPage.btnCreateGps") %>
                                </button>
                                <button id="delete-segments" class="btn btn-sm btn-outline-danger">
                                    <%= t("dashboardNewPage.btnDeleteSegment") %>
                                </button>
                            </div>
                        </div>

                        <div class="dashboard-surface-body ui-surface-body ui-surface-body--flush">
                            <div id="workout-chart"></div>
                        </div>
                        </article>

                        <aside class="dashboard-surface">
                            <div class="dashboard-section-header">
                                <div>
                                    <span class="dashboard-eyebrow"><%= t("dashboardNewPage.spatialEyebrow") %></span>
                                    <h2 class="dashboard-section-title"><%= t("dashboardNewPage.routeMapTitle") %></h2>
                                    <p class="dashboard-section-copy"><%= t("dashboardNewPage.mapCopy") %></p>
                                </div>
                            </div>

                        <div class="dashboard-surface-body ui-surface-body ui-surface-body--flush">
                                <div id="workout-map"></div>
                            </div>
                        </aside>
                    </section>
                </section>
                <div id="dashboard-mobile-library-backdrop" class="dashboard-mobile-library-backdrop"></div>
            </div>

        </div>

        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="dashboard-toast" class="toast dashboard-toast border-0" role="alert" aria-live="assertive"
                aria-atomic="true">
                <div class="toast-body" id="dashboard-toast-body"></div>
            </div>
        </div>

        <%- include("partials/app-footer") %>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4"><%= t("common.auth.pleaseSignIn") %></h3>

                <a class="btn btn-primary" href="/login">
                    <%= t("dashboardNewPage.signIn") %>
                </a>

            </div>

            <% } %>
                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
                <script>
                    window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
                </script>

                <script type="module" src="/js/dashboard-new-ui.js"></script>

</body>

</html>
