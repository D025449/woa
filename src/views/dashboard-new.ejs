<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Workouts</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        body.dashboard-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 28%),
                radial-gradient(circle at top right, rgba(13, 148, 136, 0.10), transparent 22%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .app-topbar {
            background: linear-gradient(180deg, #0f172a 0%, #172235 100%) !important;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
        }

        .app-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .app-topbar-profile {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.3rem;
            height: 2.3rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
            color: #e2e8f0;
            transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
        }

        .app-topbar-profile:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar-profile__icon {
            width: 1rem;
            height: 1rem;
        }

        .app-topbar .nav-link {
            color: rgba(226, 232, 240, 0.82);
            font-weight: 600;
            padding: 0.35rem 0.25rem;
            border-bottom: 2px solid transparent;
        }

        .app-topbar .nav-link:hover,
        .app-topbar .nav-link.active {
            color: #ffffff;
            border-bottom-color: rgba(226, 232, 240, 0.8);
        }

        .app-topbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            border-color: rgba(148, 163, 184, 0.28);
        }

        .app-topbar .btn-outline-light {
            color: #e2e8f0;
            border-color: rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
        }

        .app-topbar .btn-outline-light:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar .btn-outline-danger {
            color: #fecaca;
            border-color: rgba(248, 113, 113, 0.32);
            background: rgba(127, 29, 29, 0.18);
        }

        .app-topbar .btn-outline-danger:hover {
            color: #fff1f2;
            background: rgba(220, 38, 38, 0.28);
            border-color: rgba(248, 113, 113, 0.45);
        }

        .dashboard-shell {
            display: grid;
            gap: 1.5rem;
        }

        .app-footer {
            margin-top: 1.5rem;
            text-align: center;
            color: #64748b;
            font-size: 0.88rem;
        }

        .app-footer a {
            color: #475569;
            text-decoration: none;
        }

        .app-footer a:hover {
            color: #0f172a;
            text-decoration: underline;
        }

        .dashboard-toast {
            border-radius: 1rem;
            border: 1px solid rgba(251, 191, 36, 0.35);
            background: rgba(255, 251, 235, 0.96);
            color: #7c2d12;
            box-shadow: 0 18px 35px rgba(15, 23, 42, 0.16);
            backdrop-filter: blur(10px);
        }

        .dashboard-toast .toast-body {
            font-weight: 600;
        }

        .dashboard-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 1.5rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92)),
                linear-gradient(135deg, rgba(15, 23, 42, 0.02), rgba(30, 64, 175, 0.04));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
            backdrop-filter: blur(10px);
        }

        .dashboard-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .dashboard-title {
            margin: 0;
            font-size: clamp(2rem, 2.5vw, 2.85rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .dashboard-subtitle {
            margin: 0.75rem 0 0;
            max-width: 44rem;
            font-size: 0.98rem;
            color: #475569;
        }

        .dashboard-hero-meta {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .dashboard-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .dashboard-chip-label {
            color: #64748b;
        }

        .dashboard-section {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
            overflow: hidden;
        }

        .dashboard-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.1rem 1.4rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.88));
        }

        .dashboard-section-header--compact {
            padding-bottom: 0.9rem;
        }

        .dashboard-eyebrow {
            display: block;
            margin-bottom: 0.2rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .dashboard-section-title {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .dashboard-section-copy {
            margin: 0.35rem 0 0;
            font-size: 0.9rem;
            color: #64748b;
        }

        .dashboard-shared-meta {
            margin-top: 0.55rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
            padding: 0.42rem 0.72rem;
            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 999px;
            background: rgba(248, 250, 252, 0.92);
            color: #334155;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .dashboard-shared-meta__eyebrow {
            color: #64748b;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .dashboard-toolbar {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 0.55rem;
        }

        .dashboard-toolbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            box-shadow: none;
        }

        .dashboard-table-body {
            padding: 1rem 1.2rem 1.2rem;
        }

        .dashboard-master-detail {
            display: grid;
            grid-template-columns: minmax(320px, 0.95fr) minmax(0, 1.45fr);
            gap: 1.5rem;
            align-items: start;
        }

        .dashboard-library-column {
            min-height: 0;
        }

        .dashboard-library-section {
            position: sticky;
            top: 1.1rem;
        }

        .workout-library-toolbar {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }

        .workout-library-scope-toggle {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.28rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(248, 250, 252, 0.92);
        }

        .workout-library-scope-toggle .btn {
            border-radius: 999px;
            padding-inline: 0.85rem;
            font-weight: 700;
            border-color: transparent;
        }

        .workout-library-scope-toggle .btn.active {
            background: #0f172a;
            color: #f8fafc;
            border-color: #0f172a;
        }

        .workout-library-input,
        .workout-library-select {
            min-height: 2.75rem;
            border: 1px solid rgba(203, 213, 225, 0.82);
            border-radius: 999px;
            background: rgba(248, 250, 252, 0.96);
            color: #0f172a;
            box-shadow: none;
        }

        .workout-library-input {
            flex: 1 1 280px;
            padding-inline: 1rem;
        }

        .workout-library-select {
            min-width: 210px;
            padding-inline: 0.95rem 2.2rem;
        }

        .workout-library-input:focus,
        .workout-library-select:focus {
            border-color: rgba(59, 130, 246, 0.45);
            box-shadow: 0 0 0 0.22rem rgba(59, 130, 246, 0.12);
            outline: 0;
        }

        .workout-library-grid {
            display: grid;
            gap: 0.85rem;
        }

        .workout-library-scroll {
            max-height: calc(100vh - 21rem);
            overflow: auto;
            padding-right: 0.25rem;
        }

        .workout-library-scroll::-webkit-scrollbar {
            width: 10px;
        }

        .workout-library-scroll::-webkit-scrollbar-thumb {
            background: rgba(148, 163, 184, 0.42);
            border-radius: 999px;
            border: 2px solid transparent;
            background-clip: padding-box;
        }

        .workout-library-card {
            width: 100%;
            border: 1px solid rgba(226, 232, 240, 0.95);
            border-radius: 1.35rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.96));
            box-shadow: 0 12px 26px rgba(15, 23, 42, 0.05);
            padding: 1rem 1.1rem 1rem;
            text-align: left;
            transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
            cursor: pointer;
        }

        .workout-library-card:hover {
            transform: translateY(-1px);
            border-color: rgba(191, 219, 254, 0.95);
            box-shadow: 0 16px 34px rgba(15, 23, 42, 0.08);
        }

        .workout-library-card.is-selected {
            border-color: rgba(59, 130, 246, 0.45);
            background:
                linear-gradient(180deg, rgba(239, 246, 255, 0.98), rgba(248, 250, 252, 0.98));
            box-shadow: 0 18px 38px rgba(37, 99, 235, 0.12);
        }

        .workout-library-card__head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 0.9rem;
        }

        .workout-library-card__title {
            font-size: 1.02rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .workout-library-card__meta {
            margin-top: 0.18rem;
            font-size: 0.86rem;
            color: #64748b;
        }

        .workout-library-card__owner {
            margin-top: 0.28rem;
            font-size: 0.82rem;
            font-weight: 600;
            color: #334155;
        }

        .workout-library-card__primary-metrics {
            display: flex;
            align-items: stretch;
            justify-content: flex-end;
            gap: 0.55rem;
            flex-wrap: wrap;
        }

        .workout-library-kpi {
            min-width: 110px;
            padding: 0.62rem 0.78rem;
            border: 1px solid rgba(226, 232, 240, 0.92);
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.86);
        }

        .workout-library-kpi__label {
            display: block;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.09em;
            text-transform: uppercase;
            color: #64748b;
            margin-bottom: 0.2rem;
        }

        .workout-library-kpi__value {
            display: block;
            font-size: 0.98rem;
            font-weight: 700;
            color: #0f172a;
            font-variant-numeric: tabular-nums;
        }

        .workout-library-stat-row {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .workout-library-stat {
            display: inline-flex;
            align-items: baseline;
            gap: 0.42rem;
        }

        .workout-library-stat__label {
            font-size: 0.76rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
        }

        .workout-library-stat__value {
            font-size: 0.96rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            color: #0f172a;
        }

        .workout-library-card__footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-top: 0.9rem;
        }

        .workout-library-actions {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
        }

        .workout-library-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.45rem;
        }

        .workout-library-tag {
            display: inline-flex;
            align-items: center;
            padding: 0.35rem 0.72rem;
            border-radius: 999px;
            background: rgba(226, 232, 240, 0.65);
            color: #334155;
            font-size: 0.76rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .workout-library-card .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
        }

        .workout-share-inline {
            margin-top: 0.95rem;
            padding: 0.95rem 1rem;
            border: 1px solid rgba(226, 232, 240, 0.95);
            border-radius: 1rem;
            background: rgba(248, 250, 252, 0.95);
            display: grid;
            gap: 0.8rem;
        }

        .workout-share-inline__row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .workout-share-inline__groups {
            display: flex;
            flex-wrap: wrap;
            gap: 0.55rem;
        }

        .workout-share-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.45rem 0.72rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.28);
            background: rgba(255, 255, 255, 0.95);
            color: #334155;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .workout-share-chip input {
            margin: 0;
        }

        .workout-share-inline__actions {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .workout-share-inline__status {
            min-height: 1.2rem;
            color: #b45309;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .workout-library-empty {
            padding: 1.2rem 0.4rem 0.6rem;
            color: #64748b;
            font-size: 0.95rem;
        }

        .workout-library-load-more {
            margin-top: 1rem;
            display: flex;
            justify-content: center;
        }

        .workout-library-load-more .btn {
            border-radius: 999px;
            padding-inline: 1rem;
            font-weight: 600;
        }

        .dashboard-detail-grid {
            display: grid;
            gap: 1.5rem;
            align-items: stretch;
        }

        .dashboard-surface {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .dashboard-surface-body {
            padding: 0;
        }

        #workout-chart {
            height: 420px !important;
        }

        #workout-map {
            height: 340px !important;
        }

        @media (max-width: 991.98px) {
            .dashboard-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .dashboard-hero-meta {
                justify-content: flex-start;
            }

            .dashboard-master-detail {
                grid-template-columns: 1fr;
            }

            .dashboard-library-section {
                position: static;
            }

            .workout-library-scroll {
                max-height: none;
                overflow: visible;
                padding-right: 0;
            }

            #workout-chart,
            #workout-map {
                height: 460px !important;
            }
        }
    </style>

</head>

<body class="dashboard-page">

    <% if (isAuthenticated) { %>

        <%- include("partials/app-topbar", {
            title: "Workouts",
            currentPage: "dashboard-new",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <!-- Content -->

        <div class="container-fluid px-3 px-xl-4 py-4">

            <div class="dashboard-shell">

                <section class="dashboard-hero">
                    <div>
                        <p class="dashboard-kicker">Workout Library</p>
                        <h1 class="dashboard-title">Workouts</h1>
                        <p class="dashboard-subtitle">
                            Eine edlere Listenansicht für Workouts mit klarer KPI-Hierarchie, kompakter Suche
                            und direktem Einstieg in Chart- und Kartenanalyse.
                        </p>
                    </div>

                    <div class="dashboard-hero-meta">
                        <span class="dashboard-chip">
                            <span class="dashboard-chip-label">User</span>
                            <span><%= ((typeof userInfo !== "undefined" && userInfo) ? (userInfo.display_name || userInfo.email) : "Unknown") %></span>
                        </span>
                        <span class="dashboard-chip">
                            <span class="dashboard-chip-label">Ansicht</span>
                            <span>Workout Library</span>
                        </span>
                        <span class="dashboard-chip">
                            <span class="dashboard-chip-label">Workflow</span>
                            <span>Search · Sort · Analyse</span>
                        </span>
                    </div>
                </section>

                <section class="dashboard-master-detail">
                    <div class="dashboard-library-column">
                        <section class="dashboard-section dashboard-library-section">
                            <div class="dashboard-section-header dashboard-section-header--compact">
                                <div>
                                    <span class="dashboard-eyebrow">Workout Library</span>
                                    <h2 id="files_header" class="dashboard-section-title">Workouts</h2>
                                    <p class="dashboard-section-copy">
                                        Edle Listenansicht mit KPI-Karten statt klassischer Tabelle.
                                    </p>
                                </div>
                            </div>

                            <div class="dashboard-table-body">
                                <div class="workout-library-toolbar">
                                    <div class="workout-library-scope-toggle" role="group" aria-label="Workout-Filter">
                                        <button
                                            id="workout-library-scope-mine"
                                            class="btn btn-sm btn-outline-secondary active"
                                            type="button"
                                            data-workout-scope="mine">
                                            Meine
                                        </button>
                                        <button
                                            id="workout-library-scope-shared"
                                            class="btn btn-sm btn-outline-secondary"
                                            type="button"
                                            data-workout-scope="shared">
                                            Geteilte
                                        </button>
                                        <button
                                            id="workout-library-scope-all"
                                            class="btn btn-sm btn-outline-secondary"
                                            type="button"
                                            data-workout-scope="all">
                                            Alle
                                        </button>
                                    </div>
                                    <input
                                        id="workout-library-search"
                                        class="form-control workout-library-input"
                                        type="search"
                                        placeholder="Suche nach Workout, Datum oder Kennzahl ..."
                                    >
                                    <select id="workout-library-sort" class="form-select workout-library-select">
                                        <option value="newest">Neueste zuerst</option>
                                        <option value="uploaded">Zuletzt hochgeladen</option>
                                        <option value="oldest">Älteste zuerst</option>
                                        <option value="distance">Größte Distanz</option>
                                        <option value="duration">Längste Dauer</option>
                                        <option value="power">Höchste Ø Power</option>
                                        <option value="np">Höchste NP</option>
                                    </select>
                                </div>

                                <div class="workout-library-scroll">
                                    <div id="workout-library" class="workout-library-grid"></div>
                                    <div id="workout-library-load-more" class="workout-library-load-more d-none">
                                        <button class="btn btn-outline-primary" type="button">Mehr laden</button>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>

                    <section class="dashboard-detail-grid">
                        <article class="dashboard-surface">
                        <div class="dashboard-section-header">
                            <div>
                                <span class="dashboard-eyebrow">Primary Analysis</span>
                                <h2 class="dashboard-section-title">Workout Data</h2>
                                <p id="dashboard-detail-copy" class="dashboard-section-copy">
                                    Leistung, Herzfrequenz, Kadenz, Speed und Höhe mit direkter Segment-Interaktion.
                                </p>
                                <div id="dashboard-shared-meta" class="dashboard-shared-meta d-none">
                                    <span class="dashboard-shared-meta__eyebrow">Shared Workout</span>
                                    <span id="dashboard-shared-meta-text"></span>
                                </div>
                            </div>

                            <div class="dashboard-toolbar">
                                <button id="draw-segment-toggle" class="btn btn-sm btn-outline-primary"
                                    title="Create-Segment-Modus aktivieren.">
                                    ＋ Create Segment
                                </button>
                                <button id="draw-gps-segment-toggle" class="btn btn-sm btn-outline-success"
                                    title="Create-GPS-Segment-Modus aktivieren." disabled>
                                    🛰 Create GPS Segment
                                </button>
                                <button id="delete-segments" class="btn btn-sm btn-outline-danger">
                                    🗑 Delete Segment
                                </button>
                            </div>
                        </div>

                        <div class="dashboard-surface-body">
                            <div id="workout-chart"></div>
                        </div>
                        </article>

                        <aside class="dashboard-surface">
                            <div class="dashboard-section-header">
                                <div>
                                    <span class="dashboard-eyebrow">Spatial Context</span>
                                    <h2 class="dashboard-section-title">Route Map</h2>
                                    <p class="dashboard-section-copy">
                                        Track, Segmentbereiche und Kartenkontext als ergänzende Analysefläche.
                                    </p>
                                </div>
                            </div>

                            <div class="dashboard-surface-body">
                                <div id="workout-map"></div>
                            </div>
                        </aside>
                    </section>
                </section>
            </div>

        </div>

        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="dashboard-toast" class="toast dashboard-toast border-0" role="alert" aria-live="assertive"
                aria-atomic="true">
                <div class="toast-body" id="dashboard-toast-body"></div>
            </div>
        </div>

        <%- include("partials/app-footer") %>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4">Please log in</h3>

                <a class="btn btn-primary" href="/login">
                    Login
                </a>

            </div>

            <% } %>
