<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= t("dashboardNewPage.title") %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/dashboard-new.css">

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

</head>

<body class="dashboard-page">

    <% if (isAuthenticated) { %>

        <%- include("partials/app-topbar", {
            title: t("dashboardNewPage.topbarTitle"),
            currentPage: "dashboard-new",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <!-- Content -->

        <div class="container-fluid px-3 px-xl-4 py-4">

            <div id="dashboard-shell" class="dashboard-shell">

                <section id="dashboard-hero" class="dashboard-hero">
                    <div>
                        <h1 id="dashboard-workout-count" class="dashboard-title"><%= t("dashboardNewPage.titleMain") %></h1>
                        <div id="dashboard-quick-access" class="dashboard-quick-access" hidden>
                            <div class="dashboard-quick-access__group">
                                <span class="dashboard-quick-access__label"><%= t("dashboardNewPage.quickRecent") %></span>
                                <div id="dashboard-recent-workouts" class="dashboard-quick-access__chips"></div>
                            </div>
                            <div class="dashboard-quick-access__group">
                                <span class="dashboard-quick-access__label"><%= t("dashboardNewPage.quickFavorites") %></span>
                                <div id="dashboard-favorite-workouts" class="dashboard-quick-access__chips"></div>
                            </div>
                        </div>
                    </div>
                    <div class="ui-hero__art" aria-hidden="true">
                        <svg viewBox="0 0 64 64" fill="none">
                            <defs>
                                <linearGradient id="dashboardHeroWorkoutsGradient" x1="8" y1="50" x2="56" y2="14" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#0f766e" />
                                    <stop offset="1" stop-color="#2563eb" />
                                </linearGradient>
                            </defs>
                            <path d="M10 46C16 37 21 30 28 31C34 32 35 42 42 42C48 42 51 32 54 18" stroke="url(#dashboardHeroWorkoutsGradient)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M10 51H54" stroke="rgba(148,163,184,0.38)" stroke-width="3" stroke-linecap="round" />
                            <circle cx="28" cy="31" r="4" fill="#2563eb" />
                            <circle cx="42" cy="42" r="4" fill="#0f766e" />
                        </svg>
                    </div>
                </section>

                <section id="dashboard-master-detail" class="dashboard-master-detail">
                    <button id="dashboard-mobile-library-toggle" class="btn btn-outline-dark dashboard-mobile-library-toggle" type="button" aria-expanded="false">
                        <%= t("dashboardNewPage.mobileLibraryOpen") %>
                    </button>
                    <div class="dashboard-library-column">
                        <section class="dashboard-section dashboard-library-section">
                            <div class="dashboard-table-body">
                                <div class="workout-library-toolbar">
                                    <div id="workout-library-bulk-bar" class="workout-library-bulk-bar d-none">
                                        <div class="workout-library-bulk-bar__lead">
                                            <button
                                                id="workout-library-bulk-exit"
                                                class="workout-library-selection-toggle workout-library-selection-toggle--exit"
                                                type="button"
                                                aria-label="<%= t('dashboardNewPage.bulkCancel') %>">
                                                <svg viewBox="0 0 20 20" aria-hidden="true">
                                                    <rect x="3.5" y="3.5" width="13" height="13" rx="3" fill="none" stroke="currentColor" stroke-width="1.5"></rect>
                                                    <path d="M6.4 6.4L13.6 13.6M13.6 6.4L6.4 13.6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
                                                </svg>
                                            </button>
                                            <span id="workout-library-bulk-count" class="workout-library-bulk-bar__count"><%= t("dashboardNewPage.bulkNoneSelected") %></span>
                                        </div>
                                        <div class="workout-library-bulk-bar__actions">
                                            <div id="workout-library-bulk-share-inline" class="workout-library-bulk-share-inline d-none">
                                                <span class="small text-muted"><%= t("dashboardNewPage.library.visibility") %></span>
                                                <select id="workout-library-bulk-share-mode" class="form-select form-select-sm" style="width: 140px;">
                                                    <option value="private"><%= t("dashboardNewPage.library.sharePrivate") %></option>
                                                    <option value="groups"><%= t("dashboardNewPage.library.shareGroups") %></option>
                                                </select>
                                                <div id="workout-library-bulk-share-groups" class="workout-library-bulk-share-groups"></div>
                                                <button id="workout-library-bulk-share-cancel" class="btn btn-sm btn-outline-secondary" type="button"><%= t("dashboardNewPage.bulkCancel") %></button>
                                                <button id="workout-library-bulk-share-apply" class="btn btn-sm btn-primary" type="button"><%= t("dashboardNewPage.library.apply") %></button>
                                            </div>
                                            <details id="workout-library-bulk-actions-menu" class="workout-library-bulk-menu">
                                                <summary class="workout-library-bulk-menu__trigger" aria-label="<%= t('dashboardNewPage.bulkActions') %>">
                                                    <span></span><span></span><span></span>
                                                </summary>
                                                <div class="workout-library-bulk-menu__panel">
                                                    <button id="workout-library-select-all-visible" class="workout-library-bulk-menu__item" type="button"><%= t("dashboardNewPage.bulkSelectAllVisible") %></button>
                                                    <button id="workout-library-clear-selection" class="workout-library-bulk-menu__item" type="button"><%= t("dashboardNewPage.bulkClearSelection") %></button>
                                                    <button id="workout-library-bulk-publish-toggle" class="workout-library-bulk-menu__item" type="button"><%= t("dashboardNewPage.bulkPublish") %></button>
                                                    <button id="workout-library-bulk-delete" class="workout-library-bulk-menu__item workout-library-bulk-menu__item--danger" type="button"><%= t("dashboardNewPage.bulkDelete") %></button>
                                                </div>
                                            </details>
                                        </div>
                                    </div>
                                    <div id="workout-library-toolbar-default" class="workout-library-toolbar__default">
                                        <button
                                            id="workout-library-selection-toggle"
                                            class="workout-library-selection-toggle"
                                            type="button"
                                            aria-pressed="false"
                                            aria-label="<%= t('dashboardNewPage.bulkSelectMode') %>">
                                            <svg viewBox="0 0 20 20" aria-hidden="true">
                                                <rect x="3.5" y="3.5" width="13" height="13" rx="3" fill="none" stroke="currentColor" stroke-width="1.5"></rect>
                                                <path d="M6.75 10.15L8.95 12.35L13.35 7.95" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
                                            </svg>
                                        </button>
                                        <button
                                            id="workout-library-favorites-filter"
                                            class="workout-library-selection-toggle workout-library-selection-toggle--favorite"
                                            type="button"
                                            aria-pressed="false"
                                            aria-label="<%= t('dashboardNewPage.favoriteFilterLabel') %>">
                                            <svg viewBox="0 0 20 20" aria-hidden="true">
                                                <path d="M10 2.9l2.15 4.36 4.81.7-3.48 3.39.82 4.79L10 14.02 5.7 16.14l.82-4.79L3.04 7.96l4.81-.7L10 2.9z" fill="currentColor"></path>
                                            </svg>
                                        </button>
                                        <div class="workout-library-scope-toggle" role="group" aria-label="<%= t('dashboardNewPage.filterAria') %>">
                                            <button
                                                id="workout-library-scope-mine"
                                                class="btn btn-sm btn-outline-secondary active"
                                                type="button"
                                                data-workout-scope="mine">
                                                <%= t("dashboardNewPage.filterMine") %>
                                            </button>
                                            <button
                                                id="workout-library-scope-shared"
                                                class="btn btn-sm btn-outline-secondary"
                                                type="button"
                                                data-workout-scope="shared">
                                                <%= t("dashboardNewPage.filterShared") %>
                                            </button>
                                            <button
                                                id="workout-library-scope-all"
                                                class="btn btn-sm btn-outline-secondary"
                                                type="button"
                                                data-workout-scope="all">
                                                <%= t("dashboardNewPage.filterAll") %>
                                            </button>
                                        </div>
                                        <div class="workout-library-search-wrap">
                                            <input
                                                id="workout-library-search"
                                                class="form-control workout-library-input"
                                                type="search"
                                                placeholder="<%= t('dashboardNewPage.searchPlaceholder') %>"
                                            >
                                            <details class="workout-library-search-help">
                                                <summary class="workout-library-search-help__trigger" aria-label="<%= t('dashboardNewPage.library.searchHintOpen') %>">
                                                    <svg viewBox="0 0 20 20" aria-hidden="true">
                                                        <circle cx="10" cy="10" r="8" fill="none" stroke="currentColor" stroke-width="1.5"></circle>
                                                        <path d="M7.9 7.35C8.15 6.55 8.88 6 9.92 6C11.22 6 12.1 6.72 12.1 7.82C12.1 8.6 11.72 9.04 10.78 9.61C9.86 10.16 9.55 10.58 9.55 11.35V11.6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                                                        <circle cx="9.55" cy="14.25" r="0.9" fill="currentColor"></circle>
                                                    </svg>
                                                </summary>
                                                <div class="workout-library-hint__panel workout-library-search-help__panel">
                                                    <div class="workout-library-hint__group">
                                                        <span class="workout-library-hint__group-title"><%= t("dashboardNewPage.library.searchHintCompareTitle") %></span>
                                                        <div class="workout-library-hint__chips">
                                                            <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-example="power > 200">power &gt; 200</button>
                                                            <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-example="hr <= 150">hr &lt;= 150</button>
                                                        </div>
                                                    </div>
                                                    <div class="workout-library-hint__group">
                                                        <span class="workout-library-hint__group-title"><%= t("dashboardNewPage.library.searchHintScopedTitle") %></span>
                                                        <div class="workout-library-hint__chips">
                                                            <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-example="power:225">power:225</button>
                                                            <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-example="date:2018-03">date:2018-03</button>
                                                            <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-scope="power">power:</button>
                                                            <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-scope="np">np:</button>
                                                            <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-scope="hr">hr:</button>
                                                            <button class="workout-library-hint__chip workout-library-hint__chip--action" type="button" data-search-scope="date">date:</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </details>
                                        </div>
                                        <div id="workout-library-active-filters" class="workout-library-active-filters" hidden></div>
                                        <div class="workout-library-sort">
                                            <button id="workout-library-sort-trigger" class="workout-library-sort__trigger" type="button" aria-haspopup="menu" aria-expanded="false">
                                                <span id="workout-library-sort-trigger-label"><%= t("dashboardNewPage.sortNewest") %></span>
                                                <svg viewBox="0 0 20 20" aria-hidden="true">
                                                    <path d="M5.5 7.5L10 12l4.5-4.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                                                </svg>
                                            </button>
                                            <div id="workout-library-sort-menu" class="workout-library-sort__menu" hidden>
                                                <button class="workout-library-sort__option" type="button" data-sort-option="newest">
                                                    <span class="workout-library-sort__option-title"><%= t("dashboardNewPage.sortNewest") %></span>
                                                </button>
                                                <button class="workout-library-sort__option" type="button" data-sort-option="uploaded">
                                                    <span class="workout-library-sort__option-title"><%= t("dashboardNewPage.sortUploaded") %></span>
                                                </button>
                                                <button class="workout-library-sort__option" type="button" data-sort-option="oldest">
                                                    <span class="workout-library-sort__option-title"><%= t("dashboardNewPage.sortOldest") %></span>
                                                </button>
                                                <button class="workout-library-sort__option" type="button" data-sort-option="distance">
                                                    <span class="workout-library-sort__option-title"><%= t("dashboardNewPage.sortDistance") %></span>
                                                </button>
                                                <button class="workout-library-sort__option" type="button" data-sort-option="duration">
                                                    <span class="workout-library-sort__option-title"><%= t("dashboardNewPage.sortDuration") %></span>
                                                </button>
                                                <button class="workout-library-sort__option" type="button" data-sort-option="power">
                                                    <span class="workout-library-sort__option-title"><%= t("dashboardNewPage.sortPower") %></span>
                                                </button>
                                                <button class="workout-library-sort__option" type="button" data-sort-option="np">
                                                    <span class="workout-library-sort__option-title"><%= t("dashboardNewPage.sortNp") %></span>
                                                </button>
                                            </div>
                                            <select id="workout-library-sort" class="form-select workout-library-select workout-library-sort__native">
                                                <option value="newest"><%= t("dashboardNewPage.sortNewest") %></option>
                                                <option value="uploaded"><%= t("dashboardNewPage.sortUploaded") %></option>
                                                <option value="oldest"><%= t("dashboardNewPage.sortOldest") %></option>
                                                <option value="distance"><%= t("dashboardNewPage.sortDistance") %></option>
                                                <option value="duration"><%= t("dashboardNewPage.sortDuration") %></option>
                                                <option value="power"><%= t("dashboardNewPage.sortPower") %></option>
                                                <option value="np"><%= t("dashboardNewPage.sortNp") %></option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="workout-library-scroll">
                                    <div id="workout-library" class="workout-library-grid"></div>
                                    <div id="workout-library-load-more" class="workout-library-load-more d-none">
                                        <button class="btn btn-outline-primary" type="button"><%= t("dashboardNewPage.loadMore") %></button>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>

                    <div
                        id="dashboard-splitter"
                        class="dashboard-splitter"
                        role="separator"
                        aria-orientation="vertical"
                        aria-label="<%= t('dashboardNewPage.library.splitterAria') %>">
                    </div>

                    <section id="dashboard-detail-grid" class="dashboard-detail-grid">
                        <article id="dashboard-workspace-panel" class="dashboard-surface dashboard-workspace-panel dashboard-detail-panel">
                        <div class="dashboard-section-header">
                            <div class="dashboard-workspace-header">
                                <div>
                                <span class="dashboard-eyebrow"><%= t("dashboardNewPage.primaryEyebrow") %></span>
                                <h2 id="dashboard-workout-title" class="dashboard-section-title"><%= t("dashboardNewPage.workoutDataTitle") %></h2>
                                <p id="dashboard-detail-copy" class="dashboard-section-copy"></p>
                                <div id="dashboard-shared-meta" class="dashboard-shared-meta d-none">
                                    <span class="dashboard-shared-meta__eyebrow"><%= t("dashboardNewPage.sharedWorkoutEyebrow") %></span>
                                    <span id="dashboard-shared-meta-text"></span>
                                </div>
                                </div>
                            </div>

                            <div class="dashboard-toolbar dashboard-workspace-toolbar">
                                <details class="dashboard-actions-menu">
                                    <summary class="dashboard-actions-menu__trigger" aria-label="<%= t('dashboardNewPage.btnCreateSegment') %> / <%= t('dashboardNewPage.btnCreateGps') %> / <%= t('dashboardNewPage.btnDeleteSegment') %>">
                                        <span></span><span></span><span></span>
                                    </summary>
                                    <div class="dashboard-actions-menu__panel">
                                        <button id="draw-segment-toggle" class="dashboard-actions-menu__item dashboard-actions-menu__item--primary" type="button"
                                            title="<%= t('dashboardNewPage.btnCreateSegmentTitle') %>">
                                            <%= t("dashboardNewPage.btnCreateSegment") %>
                                        </button>
                                        <button id="draw-gps-segment-toggle" class="dashboard-actions-menu__item dashboard-actions-menu__item--success" type="button"
                                            title="<%= t('dashboardNewPage.btnCreateGpsTitle') %>" disabled>
                                            <%= t("dashboardNewPage.btnCreateGps") %>
                                        </button>
                                        <button id="delete-segments" class="dashboard-actions-menu__item dashboard-actions-menu__item--danger" type="button">
                                            <%= t("dashboardNewPage.btnDeleteSegment") %>
                                        </button>
                                        <details class="dashboard-actions-submenu">
                                            <summary class="dashboard-actions-submenu__trigger">
                                                <span><%= t("dashboardNewPage.segmentTypesLabel") %></span>
                                                <span class="dashboard-actions-submenu__chevron" aria-hidden="true">›</span>
                                            </summary>
                                            <div class="dashboard-actions-submenu__panel">
                                                <div id="dashboard-segment-toggle-slot" class="dashboard-actions-menu__series-slot"></div>
                                            </div>
                                        </details>
                                        <details class="dashboard-actions-submenu">
                                            <summary class="dashboard-actions-submenu__trigger">
                                                <span><%= t("dashboardNewPage.dataSourcesLabel") %></span>
                                                <span class="dashboard-actions-submenu__chevron" aria-hidden="true">›</span>
                                            </summary>
                                            <div class="dashboard-actions-submenu__panel">
                                                <div id="dashboard-series-toggle-slot" class="dashboard-actions-menu__series-slot"></div>
                                            </div>
                                        </details>
                                        <div class="dashboard-actions-menu__group">
                                            <div class="dashboard-actions-menu__group-label"><%= t("dashboardNewPage.axisModeLabel") %></div>
                                            <div id="dashboard-axis-toggle-slot" class="dashboard-actions-menu__toggle-slot"></div>
                                        </div>
                                    </div>
                                </details>
                            </div>
                        </div>

                        <div class="dashboard-surface-body ui-surface-body ui-surface-body--flush">
                            <div id="workout-chart"></div>
                        </div>
                        </article>

                        <aside class="dashboard-surface dashboard-detail-panel">
                            <div class="dashboard-section-header">
                                <div>
                                    <span class="dashboard-eyebrow"><%= t("dashboardNewPage.spatialEyebrow") %></span>
                                    <h2 class="dashboard-section-title"><%= t("dashboardNewPage.routeMapTitle") %></h2>
                                </div>
                                <div class="dashboard-toolbar dashboard-workspace-toolbar">
                                    <details id="dashboard-map-style-menu" class="dashboard-actions-menu dashboard-actions-menu--map">
                                        <summary class="dashboard-actions-menu__trigger" aria-label="<%= t('dashboardNewPage.mapStyleAria') %>">
                                            <span></span><span></span><span></span>
                                        </summary>
                                        <div class="dashboard-actions-menu__panel">
                                            <div class="dashboard-actions-menu__group">
                                                <div class="dashboard-actions-menu__group-label"><%= t("dashboardNewPage.mapStyleLabel") %></div>
                                                <div id="dashboard-map-style-slot" class="dashboard-actions-menu__series-slot"></div>
                                            </div>
                                        </div>
                                    </details>
                                </div>
                            </div>

                        <div class="dashboard-surface-body ui-surface-body ui-surface-body--flush">
                                <div id="workout-map"></div>
                            </div>
                        </aside>
                    </section>
                </section>
                <div id="dashboard-mobile-library-backdrop" class="dashboard-mobile-library-backdrop"></div>
            </div>

        </div>

        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="dashboard-toast" class="toast dashboard-toast border-0" role="alert" aria-live="assertive"
                aria-atomic="true">
                <div class="toast-body" id="dashboard-toast-body"></div>
            </div>
        </div>

        <% } else { %>

            <div class="container py-5 text-center">

                <h3 class="mb-4"><%= t("common.auth.pleaseSignIn") %></h3>

                <a class="btn btn-primary" href="/login">
                    <%= t("dashboardNewPage.signIn") %>
                </a>

            </div>

            <% } %>
                <!-- Charts -->

                <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
                <script>
                    window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
                </script>

                <script type="module" src="/js/dashboard-new-ui.js"></script>

</body>

</html>
