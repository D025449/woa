<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t("profile.title") %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body.profile-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 28%),
                radial-gradient(circle at top right, rgba(13, 148, 136, 0.10), transparent 22%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .app-topbar {
            background: linear-gradient(180deg, #0f172a 0%, #172235 100%) !important;
            border-bottom: 1px solid rgba(148, 163, 184, 0.18);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
        }

        .app-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f8fafc;
        }

        .app-topbar .nav-link {
            color: rgba(226, 232, 240, 0.82);
            font-weight: 600;
            padding: 0.35rem 0.25rem;
            border-bottom: 2px solid transparent;
        }

        .app-topbar .nav-link:hover,
        .app-topbar .nav-link.active {
            color: #ffffff;
            border-bottom-color: rgba(226, 232, 240, 0.8);
        }

        .app-topbar-profile {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.3rem;
            height: 2.3rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.3);
            background: rgba(255, 255, 255, 0.04);
            color: #e2e8f0;
            transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
        }

        .app-topbar-profile:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(226, 232, 240, 0.36);
        }

        .app-topbar-profile__icon {
            width: 1rem;
            height: 1rem;
        }

        .app-topbar .btn {
            border-radius: 999px;
            padding-inline: 0.9rem;
            font-weight: 600;
            border-color: rgba(148, 163, 184, 0.28);
        }

        .app-topbar .btn-outline-danger {
            color: #fecaca;
            border-color: rgba(248, 113, 113, 0.32);
            background: rgba(127, 29, 29, 0.18);
        }

        .app-topbar .btn-outline-danger:hover {
            color: #fff1f2;
            background: rgba(220, 38, 38, 0.28);
            border-color: rgba(248, 113, 113, 0.45);
        }

        .profile-shell {
            display: grid;
            gap: 1.5rem;
        }

        .app-footer {
            margin-top: 1.5rem;
            text-align: center;
            color: #64748b;
            font-size: 0.88rem;
        }

        .app-footer a {
            color: #475569;
            text-decoration: none;
        }

        .app-footer a:hover {
            color: #0f172a;
            text-decoration: underline;
        }

        .profile-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 1.5rem;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(248, 250, 252, 0.92)),
                linear-gradient(135deg, rgba(15, 23, 42, 0.02), rgba(30, 64, 175, 0.04));
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        }

        .profile-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .profile-title {
            margin: 0;
            font-size: clamp(2rem, 2.5vw, 2.85rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .profile-subtitle {
            margin: 0.75rem 0 0;
            max-width: 44rem;
            font-size: 0.98rem;
            color: #475569;
        }

        .profile-chip-group {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .profile-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .profile-chip-label {
            color: #64748b;
        }

        .profile-surface {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.07);
            overflow: hidden;
        }

        .profile-section-header {
            padding: 1.1rem 1.4rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.88));
        }

        .profile-section-title {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .profile-section-copy {
            margin: 0.35rem 0 0;
            font-size: 0.9rem;
            color: #64748b;
        }

        .profile-form {
            padding: 1.2rem 1.35rem 1.35rem;
        }

        .profile-plans-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.95rem;
            margin-top: 1rem;
        }

        .profile-plan-card {
            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 1rem;
            padding: 0.95rem 1rem;
            background: rgba(248, 250, 252, 0.92);
        }

        .profile-plan-card.is-current {
            border-color: rgba(15, 118, 110, 0.4);
            background: rgba(240, 253, 250, 0.95);
        }

        .profile-plan-name {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .profile-plan-price {
            margin: 0.35rem 0 0;
            font-size: 0.95rem;
            font-weight: 700;
            color: #0f766e;
        }

        .profile-plan-copy {
            margin: 0.55rem 0 0;
            font-size: 0.88rem;
            color: #64748b;
            line-height: 1.45;
            min-height: 2.4rem;
        }

        .profile-plan-actions {
            margin-top: 0.8rem;
            display: flex;
            justify-content: flex-end;
        }

        @media (max-width: 992px) {
            .profile-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .profile-chip-group {
                justify-content: flex-start;
            }

            .profile-plans-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="profile-page">

    <%- include("partials/app-topbar", {
        title: t("profile.topbarTitle"),
        currentPage: "profile",
        userInfo: userInfo,
        showDashboardNewLink: true,
        showSegmentsLink: true,
        showAnalyticsLink: true,
        showUploadLink: true,
        showGroupsLink: true
    }) %>

    <main class="container-xl py-4">
        <div class="profile-shell">
            <section class="profile-hero">
                <div>
                    <p class="profile-kicker"><%= t("profile.heroKicker") %></p>
                    <h1 class="profile-title"><%= t("profile.heroTitle") %></h1>
                    <p class="profile-subtitle">
                        <%= t("profile.heroSubtitle") %>
                    </p>
                </div>
                <div class="profile-chip-group">
                    <span class="profile-chip">
                        <span class="profile-chip-label"><%= t("profile.chipUser") %></span>
                        <span><%= ((typeof userInfo !== "undefined" && userInfo) ? (userInfo.display_name || userInfo.email) : t("groups.hero.unknownUser")) %></span>
                    </span>
                    <span class="profile-chip">
                        <span class="profile-chip-label"><%= t("profile.chipScope") %></span>
                        <span><%= t("profile.chipScopeValue") %></span>
                    </span>
                </div>
            </section>

            <section class="profile-surface">
                <div class="profile-section-header">
                    <h2 class="profile-section-title"><%= t("profile.sectionProfileTitle") %></h2>
                    <p class="profile-section-copy"><%= t("profile.sectionProfileCopy") %></p>
                </div>

                <form id="profile-form" class="profile-form">
                    <div id="profile-error" class="alert alert-danger d-none" role="alert"></div>
                    <div id="profile-success" class="alert alert-success d-none" role="alert"><%= t("profile.saved") %></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="profile-display-name"><%= t("profile.displayName") %></label>
                            <input class="form-control" id="profile-display-name" name="displayName" maxlength="100">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="profile-email"><%= t("profile.email") %></label>
                            <input class="form-control" id="profile-email" name="email" readonly>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label" for="profile-phone"><%= t("profile.phone") %></label>
                            <input class="form-control" id="profile-phone" name="phone" maxlength="50">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="profile-dob"><%= t("profile.dob") %></label>
                            <input type="date" class="form-control" id="profile-dob" name="dateOfBirth">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" for="profile-weight"><%= t("profile.weight") %></label>
                            <input type="number" step="0.1" min="0" class="form-control" id="profile-weight" name="weightKg">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" for="profile-height"><%= t("profile.height") %></label>
                            <input type="number" step="0.1" min="0" class="form-control" id="profile-height" name="heightCm">
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="profile-address1"><%= t("profile.address1") %></label>
                            <input class="form-control" id="profile-address1" name="addressLine1" maxlength="255">
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="profile-address2"><%= t("profile.address2") %></label>
                            <input class="form-control" id="profile-address2" name="addressLine2" maxlength="255">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="profile-postal"><%= t("profile.postalCode") %></label>
                            <input class="form-control" id="profile-postal" name="postalCode" maxlength="20">
                        </div>
                        <div class="col-md-5">
                            <label class="form-label" for="profile-city"><%= t("profile.city") %></label>
                            <input class="form-control" id="profile-city" name="city" maxlength="120">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="profile-country"><%= t("profile.country") %></label>
                            <input class="form-control" id="profile-country" name="country" maxlength="120">
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button id="profile-submit" type="submit" class="btn btn-dark"><%= t("profile.save") %></button>
                    </div>
                </form>
            </section>

            <section class="profile-surface">
                <div class="profile-section-header">
                    <h2 class="profile-section-title"><%= t("profile.preferencesTitle") %></h2>
                    <p class="profile-section-copy"><%= t("profile.preferencesCopy") %></p>
                </div>
                <form id="profile-form-preferences" class="profile-form">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label" for="profile-language"><%= t("profile.preferences.language") %></label>
                            <select class="form-control" id="profile-language" name="language">
                                <% const locales = Array.isArray(supportedLocales) && supportedLocales.length ? supportedLocales : ["en", "de"]; %>
                                <% locales.forEach((localeCode) => { %>
                                    <option value="<%= localeCode %>"><%= t(`profile.localeNames.${localeCode}`) %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="profile-distance-unit"><%= t("profile.preferences.distanceUnit") %></label>
                            <select class="form-control" id="profile-distance-unit" name="distanceUnit">
                                <option value="km"><%= t("profile.preferences.distanceUnitKm") %></option>
                                <option value="mi"><%= t("profile.preferences.distanceUnitMi") %></option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="profile-speed-unit"><%= t("profile.preferences.speedUnit") %></label>
                            <select class="form-control" id="profile-speed-unit" name="speedUnit">
                                <option value="kmh"><%= t("profile.preferences.speedUnitKmh") %></option>
                                <option value="mph"><%= t("profile.preferences.speedUnitMph") %></option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="profile-default-workout-scope"><%= t("profile.preferences.defaultWorkoutScope") %></label>
                            <select class="form-control" id="profile-default-workout-scope" name="defaultWorkoutScope">
                                <option value="mine"><%= t("profile.preferences.defaultWorkoutScopeMine") %></option>
                                <option value="shared"><%= t("profile.preferences.defaultWorkoutScopeShared") %></option>
                                <option value="all"><%= t("profile.preferences.defaultWorkoutScopeAll") %></option>
                            </select>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mt-4">
                        <button id="profile-save-preferences" type="button" class="btn btn-dark"><%= t("profile.preferencesSave") %></button>
                    </div>
                </form>
            </section>

            <section class="profile-surface">
                <div class="profile-section-header">
                    <h2 class="profile-section-title"><%= t("profile.sectionUpgradeTitle") %></h2>
                    <p class="profile-section-copy"><%= t("profile.sectionUpgradeCopy") %></p>
                </div>

                <div class="profile-form">
                    <div id="profile-payments-error" class="alert alert-danger d-none" role="alert"></div>
                    <div id="profile-payments-info" class="alert alert-info d-none" role="alert"></div>
                    <div id="profile-membership-summary" class="small text-muted"></div>
                    <div id="profile-plans-grid" class="profile-plans-grid"></div>
                </div>
            </section>
        </div>
    </main>

    <%- include("partials/app-footer") %>

    <script>
        window.profileMessages = {
            loading: "<%= t('profile.ui.loading') %>",
            saving: "<%= t('profile.ui.saving') %>",
            save: "<%= t('profile.save') %>",
            loadProfileError: "<%= t('profile.ui.loadProfileError') %>",
            saveProfileError: "<%= t('profile.ui.saveProfileError') %>",
            profileSaved: "<%= t('profile.saved') %>",
            languageUpdatedReloading: "<%= t('profile.ui.languageUpdatedReloading') %>",
            noActiveSubscription: "<%= t('profile.ui.noActiveSubscription') %>",
            currentPlan: "<%= t('profile.ui.currentPlan') %>",
            loadPlansError: "<%= t('profile.ui.loadPlansError') %>",
            noPlansAvailable: "<%= t('profile.ui.noPlansAvailable') %>",
            active: "<%= t('profile.ui.active') %>",
            upgradeWithPayPal: "<%= t('profile.ui.upgradeWithPayPal') %>",
            starting: "<%= t('profile.ui.starting') %>",
            startCheckoutError: "<%= t('profile.ui.startCheckoutError') %>",
            checkoutCanceled: "<%= t('profile.ui.checkoutCanceled') %>",
            incompleteReturnParameters: "<%= t('profile.ui.incompleteReturnParameters') %>",
            paymentSuccess: "<%= t('profile.ui.paymentSuccess') %>",
            paymentConfirmError: "<%= t('profile.ui.paymentConfirmError') %>",
            missingApprovalUrl: "<%= t('profile.ui.missingApprovalUrl') %>"
        };

        window.profilePlanDescriptions = {
            plus: "<%= t('profile.planDescriptions.plus') %>",
            pro: "<%= t('profile.planDescriptions.pro') %>",
            premium: "<%= t('profile.planDescriptions.premium') %>"
        };

        // Defensive cleanup: if a previous page left a modal backdrop behind,
        // the profile page must never look like a modal overlay.
        document.body.classList.remove("modal-open");
        document.body.style.removeProperty("padding-right");
        document.querySelectorAll(".modal-backdrop").forEach((node) => node.remove());
    </script>
    <script src="/js/profile-ui.js" type="module"></script>
</body>

</html>
