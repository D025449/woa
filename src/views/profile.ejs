<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t("profile.title") %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/ui-system.css">
    <link rel="stylesheet" href="/css/profile.css">
</head>

<body class="profile-page">

    <%- include("partials/app-topbar", {
        title: t("profile.topbarTitle"),
        currentPage: "profile",
        userInfo: userInfo,
        showDashboardNewLink: true,
        showSegmentsLink: true,
        showAnalyticsLink: true,
        showUploadLink: true,
        showGroupsLink: true
    }) %>

    <main class="container-xl py-4">
        <div class="profile-shell ui-page-shell">
            <section class="profile-hero ui-hero">
                <div>
                    <p class="profile-kicker ui-hero__kicker"><%= t("profile.heroKicker") %></p>
                    <h1 class="profile-title ui-hero__title"><%= t("profile.heroTitle") %></h1>
                    <p class="profile-subtitle ui-hero__subtitle">
                        <%= t("profile.heroSubtitle") %>
                    </p>
                </div>
            </section>

            <section class="profile-surface ui-surface">
                <div class="profile-section-header ui-section-header">
                    <h2 class="profile-section-title ui-title"><%= t("profile.sectionProfileTitle") %></h2>
                    <p class="profile-section-copy ui-copy"><%= t("profile.sectionProfileCopy") %></p>
                </div>

                <form id="profile-form" class="profile-form">
                    <div id="profile-error" class="alert alert-danger d-none" role="alert"></div>
                    <div id="profile-success" class="alert alert-success d-none" role="alert"><%= t("profile.saved") %></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="profile-display-name"><%= t("profile.displayName") %></label>
                            <input class="form-control" id="profile-display-name" name="displayName" maxlength="100">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="profile-email"><%= t("profile.email") %></label>
                            <input class="form-control" id="profile-email" name="email" readonly>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label" for="profile-phone"><%= t("profile.phone") %></label>
                            <input class="form-control" id="profile-phone" name="phone" maxlength="50">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="profile-dob"><%= t("profile.dob") %></label>
                            <input type="date" class="form-control" id="profile-dob" name="dateOfBirth">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" for="profile-weight"><%= t("profile.weight") %></label>
                            <input type="number" step="0.1" min="0" class="form-control" id="profile-weight" name="weightKg">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" for="profile-height"><%= t("profile.height") %></label>
                            <input type="number" step="0.1" min="0" class="form-control" id="profile-height" name="heightCm">
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="profile-address1"><%= t("profile.address1") %></label>
                            <input class="form-control" id="profile-address1" name="addressLine1" maxlength="255">
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="profile-address2"><%= t("profile.address2") %></label>
                            <input class="form-control" id="profile-address2" name="addressLine2" maxlength="255">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="profile-postal"><%= t("profile.postalCode") %></label>
                            <input class="form-control" id="profile-postal" name="postalCode" maxlength="20">
                        </div>
                        <div class="col-md-5">
                            <label class="form-label" for="profile-city"><%= t("profile.city") %></label>
                            <input class="form-control" id="profile-city" name="city" maxlength="120">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="profile-country"><%= t("profile.country") %></label>
                            <input class="form-control" id="profile-country" name="country" maxlength="120">
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button id="profile-submit" type="submit" class="btn btn-dark"><%= t("profile.save") %></button>
                    </div>
                </form>
            </section>

            <section class="profile-surface ui-surface">
                <div class="profile-section-header ui-section-header">
                    <h2 class="profile-section-title ui-title"><%= t("profile.preferencesTitle") %></h2>
                    <p class="profile-section-copy ui-copy"><%= t("profile.preferencesCopy") %></p>
                </div>
                <form id="profile-form-preferences" class="profile-form">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label" for="profile-language"><%= t("profile.preferences.language") %></label>
                            <select class="form-control" id="profile-language" name="language">
                                <% const locales = Array.isArray(supportedLocales) && supportedLocales.length ? supportedLocales : ["en", "de"]; %>
                                <% locales.forEach((localeCode) => { %>
                                    <option value="<%= localeCode %>"><%= t(`profile.localeNames.${localeCode}`) %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="profile-distance-unit"><%= t("profile.preferences.distanceUnit") %></label>
                            <select class="form-control" id="profile-distance-unit" name="distanceUnit">
                                <option value="km"><%= t("profile.preferences.distanceUnitKm") %></option>
                                <option value="mi"><%= t("profile.preferences.distanceUnitMi") %></option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="profile-speed-unit"><%= t("profile.preferences.speedUnit") %></label>
                            <select class="form-control" id="profile-speed-unit" name="speedUnit">
                                <option value="kmh"><%= t("profile.preferences.speedUnitKmh") %></option>
                                <option value="mph"><%= t("profile.preferences.speedUnitMph") %></option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="profile-default-workout-scope"><%= t("profile.preferences.defaultWorkoutScope") %></label>
                            <select class="form-control" id="profile-default-workout-scope" name="defaultWorkoutScope">
                                <option value="mine"><%= t("profile.preferences.defaultWorkoutScopeMine") %></option>
                                <option value="shared"><%= t("profile.preferences.defaultWorkoutScopeShared") %></option>
                                <option value="all"><%= t("profile.preferences.defaultWorkoutScopeAll") %></option>
                            </select>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mt-4">
                        <button id="profile-save-preferences" type="button" class="btn btn-dark"><%= t("profile.preferencesSave") %></button>
                    </div>
                </form>
            </section>

            <section class="profile-surface ui-surface">
                <div class="profile-section-header ui-section-header">
                    <h2 class="profile-section-title ui-title"><%= t("profile.sectionUpgradeTitle") %></h2>
                    <p class="profile-section-copy ui-copy"><%= t("profile.sectionUpgradeCopy") %></p>
                </div>

                <div class="profile-form">
                    <div id="profile-payments-error" class="alert alert-danger d-none" role="alert"></div>
                    <div id="profile-payments-info" class="alert alert-info d-none" role="alert"></div>
                    <div id="profile-membership-summary" class="small text-muted"></div>
                    <div id="profile-usage-panel" class="profile-usage-panel"></div>
                    <div id="profile-plans-grid" class="profile-plans-grid"></div>
                </div>
            </section>

            <section class="profile-surface ui-surface">
                <div class="profile-section-header ui-section-header">
                    <h2 class="profile-section-title ui-title"><%= t("profile.sectionDeletionTitle") %></h2>
                    <p class="profile-section-copy ui-copy"><%= t("profile.sectionDeletionCopy") %></p>
                </div>

                <div class="profile-form">
                    <div id="profile-deletion-alert" class="alert alert-warning d-none" role="alert"></div>
                    <div id="profile-deletion-status" class="profile-deletion-status"></div>
                    <div class="profile-deletion-actions">
                        <button id="profile-request-deletion" type="button" class="btn btn-outline-danger">
                            <%= t("profile.requestDeletion") %>
                        </button>
                        <button id="profile-cancel-deletion" type="button" class="btn btn-dark d-none">
                            <%= t("profile.cancelDeletion") %>
                        </button>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <script>
        window.profileMessages = {
            loading: "<%= t('profile.ui.loading') %>",
            saving: "<%= t('profile.ui.saving') %>",
            save: "<%= t('profile.save') %>",
            loadProfileError: "<%= t('profile.ui.loadProfileError') %>",
            saveProfileError: "<%= t('profile.ui.saveProfileError') %>",
            profileSaved: "<%= t('profile.saved') %>",
            languageUpdatedReloading: "<%= t('profile.ui.languageUpdatedReloading') %>",
            noActiveSubscription: "<%= t('profile.ui.noActiveSubscription') %>",
            currentPlan: "<%= t('profile.ui.currentPlan') %>",
            loadPlansError: "<%= t('profile.ui.loadPlansError') %>",
            noPlansAvailable: "<%= t('profile.ui.noPlansAvailable') %>",
            active: "<%= t('profile.ui.active') %>",
            upgradeWithPayPal: "<%= t('profile.ui.upgradeWithPayPal') %>",
            starting: "<%= t('profile.ui.starting') %>",
            startCheckoutError: "<%= t('profile.ui.startCheckoutError') %>",
            checkoutCanceled: "<%= t('profile.ui.checkoutCanceled') %>",
            incompleteReturnParameters: "<%= t('profile.ui.incompleteReturnParameters') %>",
            paymentSuccess: "<%= t('profile.ui.paymentSuccess') %>",
            paymentConfirmError: "<%= t('profile.ui.paymentConfirmError') %>",
            missingApprovalUrl: "<%= t('profile.ui.missingApprovalUrl') %>",
            usageWarningPrefix: "<%= t('profile.ui.usageWarningPrefix') %>",
            includedLimits: "<%= t('profile.ui.includedLimits') %>",
            usageOverview: "<%= t('profile.ui.usageOverview') %>",
            nearLimit: "<%= t('profile.ui.nearLimit') %>",
            limitExceeded: "<%= t('profile.ui.limitExceeded') %>",
            freeTierName: "<%= t('profile.ui.freeTierName') %>",
            expiredPlan: "<%= t('profile.ui.expiredPlan') %>",
            validUntil: "<%= t('profile.ui.validUntil') %>",
            starterDescription: "<%= t('profile.ui.starterDescription') %>",
            featurePlanGenerations: "<%= t('profile.ui.featurePlanGenerations') %>",
            featureCoachCommentary: "<%= t('profile.ui.featureCoachCommentary') %>",
            featureSavedPlans: "<%= t('profile.ui.featureSavedPlans') %>",
            featureStoredWorkouts: "<%= t('profile.ui.featureStoredWorkouts') %>",
            deletionPendingTitle: "<%= t('profile.ui.deletionPendingTitle') %>",
            deletionPendingCopy: "<%= t('profile.ui.deletionPendingCopy') %>",
            deletionRequestCopy: "<%= t('profile.ui.deletionRequestCopy') %>",
            deletionRequested: "<%= t('profile.ui.deletionRequested') %>",
            deletionCanceled: "<%= t('profile.ui.deletionCanceled') %>",
            deletionRequestError: "<%= t('profile.ui.deletionRequestError') %>",
            deletionCancelError: "<%= t('profile.ui.deletionCancelError') %>",
            deletionRequestConfirm: "<%= t('profile.ui.deletionRequestConfirm') %>",
            deletionCancelConfirm: "<%= t('profile.ui.deletionCancelConfirm') %>",
            deletionReadOnly: "<%= t('profile.ui.deletionReadOnly') %>"
        };

        // Defensive cleanup: if a previous page left a modal backdrop behind,
        // the profile page must never look like a modal overlay.
        document.body.classList.remove("modal-open");
        document.body.style.removeProperty("padding-right");
        document.querySelectorAll(".modal-backdrop").forEach((node) => node.remove());
    </script>
    <script src="/js/profile-ui.js" type="module"></script>
</body>

</html>
