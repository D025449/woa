<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t("coachingPage.title") %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body.coaching-page {
            background:
                radial-gradient(circle at top left, rgba(30, 64, 175, 0.08), transparent 26%),
                radial-gradient(circle at top right, rgba(8, 145, 178, 0.10), transparent 24%),
                linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
            color: #10233b;
        }

        .coaching-shell {
            display: grid;
            gap: 1.5rem;
        }

        .coaching-hero,
        .coaching-surface {
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 1.5rem;
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
        }

        .coaching-hero {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 1.5rem;
            padding: 1.5rem 1.75rem;
        }

        .coaching-kicker {
            margin: 0 0 0.4rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: #0f766e;
        }

        .coaching-title {
            margin: 0;
            font-size: clamp(2rem, 2.5vw, 2.85rem);
            font-weight: 700;
            letter-spacing: -0.04em;
            line-height: 0.95;
            color: #0f172a;
        }

        .coaching-subtitle {
            margin: 0.75rem 0 0;
            max-width: 48rem;
            font-size: 0.98rem;
            color: #475569;
        }

        .coaching-hero-meta {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .coaching-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.7rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            font-size: 0.83rem;
            font-weight: 600;
            color: #1e293b;
        }

        .coaching-chip-label {
            color: #64748b;
        }

        .coaching-surface {
            overflow: hidden;
        }

        .coaching-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.1rem 1.4rem 1rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.85);
            background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.88));
        }

        .coaching-eyebrow {
            display: block;
            margin-bottom: 0.2rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .coaching-section-title {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 700;
            color: #0f172a;
        }

        .coaching-section-copy {
            margin: 0.3rem 0 0;
            color: #64748b;
            font-size: 0.92rem;
        }

        .coaching-body {
            padding: 1.35rem 1.4rem 1.45rem;
        }

        .coaching-subgrid {
            display: grid;
            gap: 1.25rem;
        }

        .coaching-fieldset {
            padding: 1.1rem 1.1rem 1rem;
            border: 1px solid rgba(226, 232, 240, 0.92);
            border-radius: 1.15rem;
            background: rgba(248, 250, 252, 0.68);
        }

        .coaching-fieldset-title {
            margin: 0 0 0.85rem;
            font-size: 0.94rem;
            font-weight: 700;
            color: #0f172a;
        }

        .goal-toggle {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .goal-option,
        .style-option {
            position: relative;
        }

        .goal-option input,
        .style-option input,
        .horizon-option input {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

        .goal-option label,
        .style-option label {
            display: block;
            height: 100%;
            padding: 0.95rem 1rem;
            border: 1px solid rgba(203, 213, 225, 0.95);
            border-radius: 1rem;
            background: #ffffff;
            cursor: pointer;
            transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
        }

        .goal-option label:hover,
        .style-option label:hover,
        .horizon-option label:hover {
            border-color: rgba(59, 130, 246, 0.4);
            box-shadow: 0 12px 24px rgba(15, 23, 42, 0.06);
            transform: translateY(-1px);
        }

        .goal-option input:checked + label,
        .style-option input:checked + label,
        .horizon-option input:checked + label {
            border-color: rgba(30, 64, 175, 0.48);
            background: rgba(239, 246, 255, 0.95);
            box-shadow: 0 12px 26px rgba(37, 99, 235, 0.12);
        }

        .goal-option strong,
        .style-option strong {
            display: block;
            color: #0f172a;
            font-size: 0.94rem;
            margin-bottom: 0.2rem;
        }

        .goal-option span,
        .style-option span {
            display: block;
            color: #64748b;
            font-size: 0.85rem;
            line-height: 1.4;
        }

        .coaching-grid-2,
        .coaching-grid-3,
        .coaching-grid-4 {
            display: grid;
            gap: 0.9rem;
        }

        .coaching-grid-2 {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .coaching-grid-3 {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .coaching-grid-4 {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .coaching-form-label {
            margin-bottom: 0.4rem;
            font-size: 0.82rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #64748b;
        }

        .coaching-form-control,
        .coaching-form-select {
            border-radius: 0.95rem;
            border-color: rgba(203, 213, 225, 0.95);
            padding: 0.8rem 0.95rem;
            font-size: 0.95rem;
            box-shadow: none;
        }

        .coaching-weekdays {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
        }

        .weekday-chip {
            position: relative;
        }

        .weekday-chip input {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

        .weekday-chip label,
        .horizon-option label {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 3.15rem;
            padding: 0.72rem 0.95rem;
            border: 1px solid rgba(203, 213, 225, 0.95);
            border-radius: 999px;
            background: #ffffff;
            color: #0f172a;
            font-size: 0.9rem;
            font-weight: 700;
            cursor: pointer;
            transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
        }

        .weekday-chip input:checked + label {
            border-color: rgba(30, 64, 175, 0.48);
            background: rgba(239, 246, 255, 0.95);
            box-shadow: 0 10px 22px rgba(37, 99, 235, 0.12);
        }

        .horizon-toggle,
        .style-toggle {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .placeholder-grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .coaching-history-list {
            display: grid;
            gap: 0.8rem;
        }

        .coaching-history-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.95rem 1rem;
            border: 1px solid rgba(226, 232, 240, 0.92);
            border-radius: 1rem;
            background: rgba(248, 250, 252, 0.7);
        }

        .coaching-history-card__title {
            margin: 0;
            font-size: 0.95rem;
            font-weight: 700;
            color: #0f172a;
        }

        .coaching-history-card__meta {
            margin-top: 0.25rem;
            font-size: 0.85rem;
            color: #64748b;
        }

        .coaching-result-summary__chips {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .coaching-result-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            padding: 0.7rem 0.95rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.28);
            background: rgba(255, 255, 255, 0.8);
            font-size: 0.84rem;
            color: #1e293b;
        }

        .coaching-result-chip strong {
            color: #64748b;
            font-size: 0.78rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .coaching-plan-grid {
            display: grid;
            gap: 1rem;
        }

        .coaching-week-card {
            border: 1px solid rgba(226, 232, 240, 0.92);
            border-radius: 1.2rem;
            background: rgba(255, 255, 255, 0.88);
            overflow: hidden;
        }

        .coaching-week-card__header {
            display: flex;
            align-items: start;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.1rem 0.95rem;
            border-bottom: 1px solid rgba(226, 232, 240, 0.88);
            background: rgba(248, 250, 252, 0.78);
        }

        .coaching-week-card__eyebrow {
            margin-bottom: 0.22rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #64748b;
        }

        .coaching-week-card__title {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
        }

        .coaching-week-card__review-row {
            margin-top: 0.45rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.55rem;
            align-items: center;
        }

        .coaching-week-card__hours {
            font-size: 0.92rem;
            font-weight: 700;
            color: #0f172a;
        }

        .coaching-week-card__sessions {
            display: grid;
            gap: 0.8rem;
            padding: 1rem 1.1rem 1.15rem;
        }

        .coaching-session-card {
            display: grid;
            grid-template-columns: 4rem 1fr;
            gap: 0.85rem;
            align-items: start;
            padding: 0.9rem 1rem;
            border-radius: 1rem;
            border: 1px solid rgba(226, 232, 240, 0.92);
            background: rgba(248, 250, 252, 0.74);
        }

        .coaching-session-card--full {
            grid-template-columns: 1fr;
        }

        .coaching-session-card--hard {
            border-color: rgba(248, 113, 113, 0.25);
            background: rgba(254, 242, 242, 0.78);
        }

        .coaching-session-card--medium {
            border-color: rgba(251, 191, 36, 0.26);
            background: rgba(255, 251, 235, 0.82);
        }

        .coaching-session-card--long {
            border-color: rgba(45, 212, 191, 0.25);
            background: rgba(240, 253, 250, 0.82);
        }

        .coaching-session-card__day {
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
            padding-top: 0.15rem;
        }

        .coaching-session-card__title {
            font-size: 0.96rem;
            font-weight: 700;
            color: #0f172a;
        }

        .coaching-session-card__meta {
            margin-top: 0.18rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.55rem 1rem;
            font-size: 0.84rem;
            font-weight: 700;
            color: #0f766e;
        }

        .coaching-session-card__notes {
            margin-top: 0.3rem;
            font-size: 0.88rem;
            color: #475569;
        }

        .coaching-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.28rem 0.65rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.24);
            background: rgba(241, 245, 249, 0.9);
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: #334155;
        }

        .coaching-status-badge--on-track,
        .coaching-status-badge--completed {
            border-color: rgba(34, 197, 94, 0.24);
            background: rgba(240, 253, 244, 0.96);
            color: #166534;
        }

        .coaching-status-badge--slightly-off,
        .coaching-status-badge--mostly-completed {
            border-color: rgba(245, 158, 11, 0.24);
            background: rgba(255, 251, 235, 0.96);
            color: #b45309;
        }

        .coaching-status-badge--substituted,
        .coaching-status-badge--extra-unplanned {
            border-color: rgba(59, 130, 246, 0.24);
            background: rgba(239, 246, 255, 0.96);
            color: #1d4ed8;
        }

        .coaching-status-badge--off-track,
        .coaching-status-badge--missed {
            border-color: rgba(239, 68, 68, 0.24);
            background: rgba(254, 242, 242, 0.96);
            color: #b91c1c;
        }

        .coaching-metric-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.32rem 0.7rem;
            border-radius: 999px;
            background: rgba(248, 250, 252, 0.92);
            border: 1px solid rgba(203, 213, 225, 0.9);
            color: #334155;
            font-size: 0.78rem;
            font-weight: 700;
        }

        .coaching-metric-pill strong {
            color: #64748b;
            font-size: 0.72rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .coaching-review-panel {
            display: grid;
            gap: 0.75rem;
        }

        .coaching-review-panel__summary {
            font-size: 0.92rem;
            color: #334155;
        }

        .coaching-review-panel__counts {
            display: flex;
            flex-wrap: wrap;
            gap: 0.55rem;
        }

        .coaching-extra-list {
            display: grid;
            gap: 0.55rem;
        }

        .coaching-extra-list__title {
            font-size: 0.88rem;
            font-weight: 800;
            color: #0f172a;
        }

        .coaching-extra-item {
            display: grid;
            gap: 0.4rem;
            padding: 0.8rem 0.9rem;
            border-radius: 0.95rem;
            border: 1px solid rgba(59, 130, 246, 0.18);
            background: rgba(239, 246, 255, 0.6);
        }

        .coaching-extra-item__header {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.55rem;
            justify-content: space-between;
        }

        .coaching-extra-item__title {
            font-size: 0.86rem;
            font-weight: 700;
            color: #0f172a;
        }

        .coaching-advice-list {
            display: grid;
            gap: 0.6rem;
        }

        .coaching-advice-list__title {
            font-size: 0.88rem;
            font-weight: 800;
            color: #0f172a;
        }

        .coaching-advice-item {
            display: grid;
            gap: 0.3rem;
            padding: 0.85rem 0.95rem;
            border-radius: 0.95rem;
            border: 1px solid rgba(148, 163, 184, 0.22);
            background: rgba(248, 250, 252, 0.88);
        }

        .coaching-advice-item--high {
            border-color: rgba(239, 68, 68, 0.2);
            background: rgba(254, 242, 242, 0.88);
        }

        .coaching-advice-item--medium {
            border-color: rgba(245, 158, 11, 0.2);
            background: rgba(255, 251, 235, 0.88);
        }

        .coaching-advice-item--low {
            border-color: rgba(34, 197, 94, 0.2);
            background: rgba(240, 253, 244, 0.88);
        }

        .coaching-advice-item__title {
            font-size: 0.86rem;
            font-weight: 700;
            color: #0f172a;
        }

        .coaching-commentary {
            display: grid;
            gap: 0.7rem;
        }

        .coaching-commentary__title {
            font-size: 0.88rem;
            font-weight: 800;
            color: #0f172a;
        }

        .coaching-commentary__section {
            display: grid;
            gap: 0.28rem;
        }

        .coaching-commentary__label {
            font-size: 0.76rem;
            font-weight: 800;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #64748b;
        }

        .coaching-commentary__list {
            margin: 0;
            padding-left: 1.1rem;
            color: #334155;
            font-size: 0.9rem;
        }

        .coaching-commentary__list li + li {
            margin-top: 0.22rem;
        }

        .coaching-session-card__match {
            margin-top: 0.45rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.55rem;
            align-items: center;
        }

        .coaching-session-card__reason {
            margin-top: 0.35rem;
            font-size: 0.84rem;
            color: #475569;
        }

        .coaching-week-actions {
            display: flex;
            gap: 0.55rem;
            align-items: center;
        }

        .coaching-edit-grid {
            display: grid;
            gap: 0.75rem;
        }

        .coaching-edit-session {
            padding: 0.85rem;
            border: 1px solid rgba(203, 213, 225, 0.9);
            border-radius: 0.9rem;
            background: rgba(255, 255, 255, 0.78);
        }

        .placeholder-card {
            padding: 1rem 1rem 1.05rem;
            border: 1px dashed rgba(148, 163, 184, 0.55);
            border-radius: 1rem;
            background: rgba(248, 250, 252, 0.78);
        }

        .placeholder-card h3 {
            margin: 0 0 0.35rem;
            font-size: 0.98rem;
            font-weight: 700;
            color: #0f172a;
        }

        .placeholder-card p,
        .coaching-placeholder-copy {
            margin: 0;
            color: #64748b;
            font-size: 0.92rem;
        }

        .coaching-placeholder-list {
            margin: 1rem 0 0;
            padding-left: 1.2rem;
            color: #334155;
        }

        .coaching-placeholder-list li + li {
            margin-top: 0.45rem;
        }

        @media (max-width: 991.98px) {
            .coaching-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .coaching-hero-meta {
                justify-content: flex-start;
            }

            .goal-toggle,
            .coaching-grid-2,
            .coaching-grid-3,
            .coaching-grid-4,
            .placeholder-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="coaching-page">
    <% if (isAuthenticated) { %>
        <%- include("partials/app-topbar", {
            title: t("coachingPage.title"),
            currentPage: "coaching",
            userInfo,
            showDashboardNewLink: true
        }) %>

        <div class="container-fluid px-3 px-xl-4 py-4">
            <div class="coaching-shell">
                <section class="coaching-hero">
                    <div>
                        <p class="coaching-kicker"><%= t("coachingPage.heroKicker") %></p>
                        <h1 class="coaching-title"><%= t("coachingPage.title") %></h1>
                        <p class="coaching-subtitle">
                            <%= t("coachingPage.heroSubtitle") %>
                        </p>
                    </div>

                    <div class="coaching-hero-meta">
                        <span class="coaching-chip">
                            <span class="coaching-chip-label"><%= t("coachingPage.chipUser") %></span>
                            <span><%= userInfo.display_name || userInfo.email %></span>
                        </span>
                        <span class="coaching-chip">
                            <span class="coaching-chip-label"><%= t("coachingPage.chipFocus") %></span>
                            <span><%= t("coachingPage.chipFocusValue") %></span>
                        </span>
                        <span class="coaching-chip">
                            <span class="coaching-chip-label"><%= t("coachingPage.chipMode") %></span>
                            <span><%= t("coachingPage.chipModeValue") %></span>
                        </span>
                    </div>
                </section>

                <section class="coaching-surface">
                    <div class="coaching-section-header">
                        <div>
                            <span class="coaching-eyebrow"><%= t("coachingPage.sections.planningInputEyebrow") %></span>
                            <h2 class="coaching-section-title"><%= t("coachingPage.sections.planSetupTitle") %></h2>
                            <p class="coaching-section-copy"><%= t("coachingPage.sections.planSetupCopy") %></p>
                        </div>
                    </div>

                    <div class="coaching-body">
                        <form class="coaching-subgrid" id="coaching-form">
                            <section class="coaching-fieldset">
                                <h3 class="coaching-fieldset-title"><%= t("coachingPage.fieldsets.goal") %></h3>

                                <div class="goal-toggle">
                                    <div class="goal-option">
                                        <input type="radio" id="goal-event" name="primaryGoal" value="event" checked>
                                        <label for="goal-event">
                                            <strong><%= t("coachingPage.goal.eventTitle") %></strong>
                                            <span><%= t("coachingPage.goal.eventCopy") %></span>
                                        </label>
                                    </div>

                                    <div class="goal-option">
                                        <input type="radio" id="goal-power" name="primaryGoal" value="power">
                                        <label for="goal-power">
                                            <strong><%= t("coachingPage.goal.powerTitle") %></strong>
                                            <span><%= t("coachingPage.goal.powerCopy") %></span>
                                        </label>
                                    </div>
                                </div>

                                <div id="power-focus-panel" class="mt-3 d-none">
                                    <label class="coaching-form-label" for="power-focus"><%= t("coachingPage.labels.powerFocus") %></label>
                                    <select class="form-select coaching-form-select" id="power-focus" name="powerFocus">
                                        <option value="sprint"><%= t("coachingPage.powerFocus.sprint") %></option>
                                        <option value="1min"><%= t("coachingPage.powerFocus.1min") %></option>
                                        <option value="4min"><%= t("coachingPage.powerFocus.4min") %></option>
                                        <option value="8min"><%= t("coachingPage.powerFocus.8min") %></option>
                                        <option value="ftp"><%= t("coachingPage.powerFocus.ftp") %></option>
                                    </select>
                                </div>

                                <div id="event-panel" class="mt-3">
                                    <div class="coaching-grid-4">
                                        <div>
                                            <label class="coaching-form-label" for="event-date"><%= t("coachingPage.labels.eventDate") %></label>
                                            <input class="form-control coaching-form-control" id="event-date" name="eventDate" type="date">
                                        </div>

                                        <div>
                                            <label class="coaching-form-label" for="event-duration"><%= t("coachingPage.labels.eventDuration") %></label>
                                            <input class="form-control coaching-form-control" id="event-duration" name="eventDuration" type="number" min="0" step="0.5" placeholder="<%= t('coachingPage.placeholders.eventDuration') %>">
                                        </div>

                                        <div>
                                            <label class="coaching-form-label" for="event-distance"><%= t("coachingPage.labels.eventDistance") %></label>
                                            <input class="form-control coaching-form-control" id="event-distance" name="eventDistance" type="number" min="0" step="1" placeholder="<%= t('coachingPage.placeholders.eventDistance') %>">
                                        </div>

                                        <div>
                                            <label class="coaching-form-label" for="event-elevation"><%= t("coachingPage.labels.eventElevation") %></label>
                                            <input class="form-control coaching-form-control" id="event-elevation" name="eventElevation" type="number" min="0" step="50" placeholder="<%= t('coachingPage.placeholders.eventElevation') %>">
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <label class="coaching-form-label" for="terrain-profile"><%= t("coachingPage.labels.terrainProfile") %></label>
                                        <select class="form-select coaching-form-select" id="terrain-profile" name="terrainProfile">
                                            <option value="flat"><%= t("coachingPage.terrain.flat") %></option>
                                            <option value="rolling"><%= t("coachingPage.terrain.rolling") %></option>
                                            <option value="hilly"><%= t("coachingPage.terrain.hilly") %></option>
                                            <option value="mountainous"><%= t("coachingPage.terrain.mountainous") %></option>
                                        </select>
                                    </div>
                                </div>
                            </section>

                            <section class="coaching-fieldset">
                                <h3 class="coaching-fieldset-title"><%= t("coachingPage.fieldsets.availability") %></h3>

                                <div class="coaching-grid-2">
                                    <div>
                                        <label class="coaching-form-label" for="hours-per-week"><%= t("coachingPage.labels.hoursPerWeek") %></label>
                                        <input class="form-control coaching-form-control" id="hours-per-week" name="hoursPerWeek" type="number" min="1" max="40" step="0.5" placeholder="<%= t('coachingPage.placeholders.hoursPerWeek') %>">
                                    </div>

                                    <div>
                                        <label class="coaching-form-label" for="plan-start-date"><%= t("coachingPage.labels.planStartDate") %></label>
                                        <input class="form-control coaching-form-control" id="plan-start-date" name="planStartDate" type="date">
                                    </div>

                                    <div>
                                        <label class="coaching-form-label"><%= t("coachingPage.labels.availableWeekdays") %></label>
                                        <div class="coaching-weekdays">
                                            <div class="weekday-chip"><input type="checkbox" id="day-mon" name="days" value="mon"><label for="day-mon"><%= t("coachingPage.days.mon") %></label></div>
                                            <div class="weekday-chip"><input type="checkbox" id="day-tue" name="days" value="tue"><label for="day-tue"><%= t("coachingPage.days.tue") %></label></div>
                                            <div class="weekday-chip"><input type="checkbox" id="day-wed" name="days" value="wed"><label for="day-wed"><%= t("coachingPage.days.wed") %></label></div>
                                            <div class="weekday-chip"><input type="checkbox" id="day-thu" name="days" value="thu"><label for="day-thu"><%= t("coachingPage.days.thu") %></label></div>
                                            <div class="weekday-chip"><input type="checkbox" id="day-fri" name="days" value="fri"><label for="day-fri"><%= t("coachingPage.days.fri") %></label></div>
                                            <div class="weekday-chip"><input type="checkbox" id="day-sat" name="days" value="sat"><label for="day-sat"><%= t("coachingPage.days.sat") %></label></div>
                                            <div class="weekday-chip"><input type="checkbox" id="day-sun" name="days" value="sun"><label for="day-sun"><%= t("coachingPage.days.sun") %></label></div>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-3">
                                    <label class="coaching-form-label"><%= t("coachingPage.labels.athleteDataMode") %></label>
                                    <div class="style-toggle">
                                        <div class="style-option">
                                            <input type="radio" id="athlete-mode-current" name="athleteDataMode" value="current" checked>
                                            <label for="athlete-mode-current">
                                                <strong><%= t("coachingPage.athleteMode.currentTitle") %></strong>
                                                <span><%= t("coachingPage.athleteMode.currentCopy") %></span>
                                            </label>
                                        </div>

                                        <div class="style-option">
                                            <input type="radio" id="athlete-mode-historical" name="athleteDataMode" value="historical">
                                            <label for="athlete-mode-historical">
                                                <strong><%= t("coachingPage.athleteMode.historicalTitle") %></strong>
                                                <span><%= t("coachingPage.athleteMode.historicalCopy") %></span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <section class="coaching-fieldset">
                                <h3 class="coaching-fieldset-title"><%= t("coachingPage.fieldsets.preferences") %></h3>

                                <div class="coaching-grid-2">
                                    <div>
                                        <label class="coaching-form-label"><%= t("coachingPage.labels.planHorizon") %></label>
                                        <div class="horizon-toggle">
                                            <div class="horizon-option"><input type="radio" id="horizon-4" name="planHorizon" value="4" checked><label for="horizon-4"><%= t("coachingPage.horizon.4weeks") %></label></div>
                                            <div class="horizon-option"><input type="radio" id="horizon-8" name="planHorizon" value="8"><label for="horizon-8"><%= t("coachingPage.horizon.8weeks") %></label></div>
                                            <div class="horizon-option"><input type="radio" id="horizon-12" name="planHorizon" value="12"><label for="horizon-12"><%= t("coachingPage.horizon.12weeks") %></label></div>
                                        </div>
                                    </div>

                                    <div>
                                        <label class="coaching-form-label"><%= t("coachingPage.labels.planningStyle") %></label>
                                        <div class="style-toggle">
                                            <div class="style-option">
                                                <input type="radio" id="style-conservative" name="planningStyle" value="conservative">
                                                <label for="style-conservative">
                                                    <strong><%= t("coachingPage.style.conservativeTitle") %></strong>
                                                    <span><%= t("coachingPage.style.conservativeCopy") %></span>
                                                </label>
                                            </div>

                                            <div class="style-option">
                                                <input type="radio" id="style-balanced" name="planningStyle" value="balanced" checked>
                                                <label for="style-balanced">
                                                    <strong><%= t("coachingPage.style.balancedTitle") %></strong>
                                                    <span><%= t("coachingPage.style.balancedCopy") %></span>
                                                </label>
                                            </div>

                                            <div class="style-option">
                                                <input type="radio" id="style-ambitious" name="planningStyle" value="ambitious">
                                                <label for="style-ambitious">
                                                    <strong><%= t("coachingPage.style.ambitiousTitle") %></strong>
                                                    <span><%= t("coachingPage.style.ambitiousCopy") %></span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-3">
                                    <label class="coaching-form-label" for="additional-notes"><%= t("coachingPage.labels.additionalNotes") %></label>
                                    <textarea class="form-control coaching-form-control" id="additional-notes" name="additionalNotes" rows="4" placeholder="<%= t('coachingPage.placeholders.additionalNotes') %>"></textarea>
                                </div>
                            </section>

                            <div class="d-flex justify-content-end">
                                <div class="d-flex gap-2">
                                    <button class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-semibold" id="coaching-save-button" type="button" disabled><%= t("coachingPage.actions.savePlan") %></button>
                                    <button class="btn btn-primary px-4 py-2 rounded-pill fw-semibold" id="coaching-generate-button" type="button"><%= t("coachingPage.actions.generatePlan") %></button>
                                </div>
                            </div>
                        </form>
                    </div>
                </section>

                <section class="coaching-surface">
                    <div class="coaching-section-header">
                        <div>
                            <span class="coaching-eyebrow"><%= t("coachingPage.sections.athleteContextEyebrow") %></span>
                            <h2 class="coaching-section-title"><%= t("coachingPage.sections.currentTrainingStateTitle") %></h2>
                            <p class="coaching-section-copy"><%= t("coachingPage.sections.currentTrainingStateCopy") %></p>
                        </div>
                    </div>

                    <div class="coaching-body">
                        <div id="coaching-user-context">
                            <p class="coaching-placeholder-copy"><%= t("coachingPage.placeholders.loadingAthleteContext") %></p>
                        </div>
                    </div>
                </section>

                <section class="coaching-surface">
                    <div class="coaching-section-header">
                        <div>
                            <span class="coaching-eyebrow"><%= t("coachingPage.sections.planHistoryEyebrow") %></span>
                            <h2 class="coaching-section-title"><%= t("coachingPage.sections.savedPlansTitle") %></h2>
                            <p class="coaching-section-copy"><%= t("coachingPage.sections.savedPlansCopy") %></p>
                        </div>
                    </div>

                    <div class="coaching-body">
                        <div id="coaching-plan-history">
                            <p class="coaching-placeholder-copy"><%= t("coachingPage.history.emptyLoaded") %></p>
                        </div>
                    </div>
                </section>

                <section class="coaching-surface">
                    <div class="coaching-section-header">
                        <div>
                            <span class="coaching-eyebrow"><%= t("coachingPage.sections.planOutputEyebrow") %></span>
                            <h2 class="coaching-section-title"><%= t("coachingPage.sections.generatedPlanTitle") %></h2>
                            <p class="coaching-section-copy"><%= t("coachingPage.sections.generatedPlanCopy") %></p>
                        </div>
                    </div>

                    <div class="coaching-body">
                        <div id="coaching-plan-status" class="mb-3"></div>
                        <div id="coaching-plan-summary">
                            <p class="coaching-placeholder-copy">
                                <%= t("coachingPage.placeholders.noPlanGenerated") %>
                            </p>
                        </div>

                        <div id="coaching-plan-result" class="coaching-plan-grid mt-4">
                            <ul class="coaching-placeholder-list">
                                <li><%= t("coachingPage.placeholders.weekStructure") %></li>
                                <li><%= t("coachingPage.placeholders.goalMapping") %></li>
                                <li><%= t("coachingPage.placeholders.extensionPoint") %></li>
                            </ul>

                            <div class="placeholder-grid">
                                <article class="placeholder-card">
                                    <h3><%= t("coachingPage.placeholders.week1Title") %></h3>
                                    <p><%= t("coachingPage.placeholders.week1Copy") %></p>
                                </article>

                                <article class="placeholder-card">
                                    <h3><%= t("coachingPage.placeholders.week2Title") %></h3>
                                    <p><%= t("coachingPage.placeholders.week2Copy") %></p>
                                </article>

                                <article class="placeholder-card">
                                    <h3><%= t("coachingPage.placeholders.week3Title") %></h3>
                                    <p><%= t("coachingPage.placeholders.week3Copy") %></p>
                                </article>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <script>
            window.__I18N = <%- JSON.stringify(i18n || { locale: "en", messages: {} }) %>;
        </script>
        <script type="module">
            import CoachingUI from "/js/coaching-ui.js";
            new CoachingUI();
        </script>
    <% } else { %>
        <div class="container py-5 text-center">
            <h3 class="mb-4"><%= t("common.auth.pleaseSignIn") %></h3>
            <a class="btn btn-primary" href="/login"><%= t("common.auth.signIn") %></a>
        </div>
    <% } %>
</body>

</html>
