{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "src/app.js",
    "src/index.js",
    "src/db-rebuild.js",
    "src/migrate.js",
    "src/routes/**/*.js",
    "src/services/**/*.js",
    "src/workers/**/*.js",
    "src/queue/**/*.js",
    "src/scripts/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "uploads",
    "src/public/**/*.js",
    "src/shared/**/*.js"
  ]
}
